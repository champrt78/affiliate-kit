---
import SiteShell from "@affkit/shared-ui/SiteShell.astro";
import AffiliateDisclosure from "@affkit/shared-ui/AffiliateDisclosure.astro";
// Charcoal + electric blue + amber palette overrides
import "../styles/site-tokens.css";
import siteConfig from "../data/site-config.json";

/* bgTheme — per-page detailing gutter theme. Defaults to "foam-cascade"
   when omitted. The shell paints the body and floats the cream page-shell on
   top; mobile collapses the shell to full-width so the photo doesn't show.
   Source photos hot-linked from Pexels (image policy: scene/atmosphere only,
   never product hero). */
type BgTheme = "foam-cascade" | "wheel-suds" | "suds-closeup" | "interior-detail" | "chrome-reflection" | "solid";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  robotsContent?: string;
  ogType?: string;
  ogImage?: string;
  bgTheme?: BgTheme;
}

const { title, description, canonical, robotsContent, ogType, ogImage, bgTheme = "foam-cascade" } = Astro.props;
const siteName = "DetailerPicks";

/* CSS `background` shorthand: per spec, color value MAY appear ONLY in the
   LAST layer, attached inline (no comma separator). The earlier form
   `<gradient>, <url>, #14181C` treated #14181C as its own layer (invalid)
   and the whole declaration was rejected — the silent root cause of the
   blank-gutter bug. The shell emits the gutter color as a SEPARATE
   background-color declaration (after the shorthand) via its head-slot
   cascade workaround, so this map carries only the image layer(s). */
const themeBackgrounds: Record<typeof bgTheme, string> = {
  "foam-cascade": 'linear-gradient(rgba(20,24,28,0.15), rgba(20,24,28,0.15)), url("https://images.pexels.com/photos/6873174/pexels-photo-6873174.jpeg?auto=compress&cs=tinysrgb&w=2000") center/cover no-repeat fixed',
  "wheel-suds": 'linear-gradient(rgba(20,24,28,0.15), rgba(20,24,28,0.15)), url("https://images.pexels.com/photos/14231678/pexels-photo-14231678.jpeg?auto=compress&cs=tinysrgb&w=2000") center/cover no-repeat fixed',
  "suds-closeup": 'linear-gradient(rgba(20,24,28,0.15), rgba(20,24,28,0.15)), url("https://images.pexels.com/photos/4870702/pexels-photo-4870702.jpeg?auto=compress&cs=tinysrgb&w=2000") center/cover no-repeat fixed',
  "interior-detail": 'linear-gradient(rgba(20,24,28,0.25), rgba(20,24,28,0.25)), url("https://images.pexels.com/photos/6873008/pexels-photo-6873008.jpeg?auto=compress&cs=tinysrgb&w=2000") center/cover no-repeat fixed',
  "chrome-reflection": 'url("https://images.pexels.com/photos/27317283/pexels-photo-27317283.jpeg?auto=compress&cs=tinysrgb&w=2000") center/cover no-repeat fixed',
  "solid": "none",
};
const pageBg = themeBackgrounds[bgTheme];

// Primary nav: Home + each pillar (/topics/<slug>/) + About — matches the
// satellite pattern. Guides/Reviews indexes stay reachable via the footer.
const navItems = [
  { href: "/", label: "Home" },
  ...siteConfig.navigation.pillars.map((p) => ({
    href: `/topics/${p.slug}/`,
    label: p.label,
  })),
  { href: "/about/", label: "About" },
];

const footerBlurb =
  "Honest, cross-brand car-detailing picks for home detailers and weekend enthusiasts. We compare specs, frame fit, and link to where you can actually buy them.";

const footerColumns = [
  {
    heading: "Explore",
    links: [
      { href: "/buyers-guides/", label: "Buying guides" },
      { href: "/reviews/", label: "Single-product reviews" },
      { href: "/how-we-evaluate/", label: "How we evaluate" },
      { href: "/about/", label: "About this site" },
    ],
  },
  {
    heading: "Fine print",
    links: [
      { href: "/disclosure/", label: "Affiliate disclosure" },
      { href: "/privacy/", label: "Privacy" },
      { href: "/contact/", label: "Contact" },
    ],
  },
];

// Chrome & Suds editorial register — Instrument Serif + Inter Tight.
const fontsHref = "https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter+Tight:wght@400;500;600;700&display=swap";
---
<SiteShell
  title={title}
  description={description}
  canonical={canonical}
  siteName={siteName}
  robotsContent={robotsContent}
  ogType={ogType}
  ogImage={ogImage}
  themeColor="#F4F2EE"
  fontsHref={fontsHref}
  navItems={navItems}
  footerColumns={footerColumns}
  footerBlurb={footerBlurb}
  pageBg={pageBg}
  gutterColor="#14181C"
>
  {/* Brand markup is authored HERE so DTP's scoped .brand* CSS (below) matches
      it — Astro scopes slot styles to the authoring component, not SiteShell. */}
  <a href="/" class="brand" slot="brand">
    <span class="brand__type">
      <span class="brand__name">Detailer<em>Picks</em></span>
      <span class="brand__tag">Car detailing, by use case</span>
    </span>
  </a>

  <AffiliateDisclosure slot="footer-legal" siteName={siteName} variant="footer" />

  <slot />
</SiteShell>

<style>
  /* Brand: editorial serif wordmark with italic-steel "Picks" mark. Lives in
     this layout (not SiteShell) because the brand markup is slotted from here —
     Astro scopes these styles to the markup THIS file authors. */
  .brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-paper-ink);
  }
  .brand:hover .brand__name em { color: var(--color-forest-mid); }
  .brand__type {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .brand__name {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 26px;
    letter-spacing: -0.01em;
    color: var(--color-paper-ink);
  }
  .brand__name em {
    font-style: italic;
    color: var(--color-forest);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .brand__tag {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--color-muted);
    margin-top: 4px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
  }
  @media (max-width: 760px) {
    .brand__tag { display: none; }
  }
</style>
