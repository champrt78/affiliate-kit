---
import MainLayout from "../layouts/MainLayout.astro";
import { cloakedLink } from "@affkit/shared-utils";

const picks = [
  {
    slug: "quickpicks-soap",
    name: "Chemical Guys Mr. Pink",
    category: "Car wash soap",
    blurb: "Pink, foamy, gentle on paint. Pour a cap into a bucket, mix with your hose, you're done. No fancy dilution math.",
  },
  {
    slug: "best-interior-cleaner-for-home-detailers",
    name: "Chemical Guys InnerClean",
    category: "Interior cleaner",
    blurb: "Works on every surface inside the car. No greasy finish, smells great. Spray onto a microfiber, wipe, done.",
  },
  {
    slug: "quickpicks-wheel",
    name: "Meguiar's Ultimate All Wheel Cleaner",
    category: "Wheel cleaner",
    blurb: "Ten bucks at AutoZone. Turns purple on brake dust so you can see it working. Safe on every wheel finish.",
  },
  {
    slug: "quickpicks-microfiber",
    name: "Meguiar's Supreme Shine Microfiber Towels (6-pack)",
    category: "Detailing rags",
    blurb: "Six 16x16 towels. Use one for soap, one for drying, rotate clean ones in. Do not drop on the ground. If you do, that one is dead.",
  },
  {
    slug: "quickpicks-mitt",
    name: "Chemical Guys Chenille Microfiber Wash Mitt",
    category: "Wash mitt",
    blurb: "Wash with this, not a sponge. Sponges drag dirt back across paint. A mitt holds the dirt away from the fibers touching your car.",
  },
  {
    slug: "quickpicks-glass",
    name: "Stoner Invisible Glass",
    category: "Glass cleaner (optional)",
    blurb: "Aerosol can, five bucks. Sprays foamy, wipes streak-free. Do not use on tinted rear windshields — it can eat the tint film over time.",
  },
];
---
<MainLayout
  title="Quick Picks · DetailerPicks"
  description="No time to read? These six products are inexpensive, mass-retail accessible, and work perfectly for a weekend driveway car wash without ruining your paint or wheels."
>
  <section class="qp-hero">
    <div class="qp-hero__inner">
      <div class="qp-hero__eyebrow">Quick Picks</div>
      <h1 class="qp-hero__title">No time to read? <em>Just buy these.</em></h1>
      <p class="qp-hero__lede">
        Six products you can buy on Amazon for under $80 total. Mass-retail
        accessible, safe on paint, ceramic-coating friendly, and good enough
        that a weekend driveway wash leaves your car better than the
        automatic carwash ever will.
      </p>
      <p class="qp-hero__sub">
        Each link goes through our affiliate redirect to Amazon. We earn a
        small commission at no extra cost to you, and we picked each one
        because it actually works, not because it pays the best.
      </p>
    </div>
  </section>

  <section class="qp-grid-wrap">
    <div class="qp-grid">
      {picks.map((p) => (
        <article class="qp-card">
          <div class="qp-card__category">{p.category}</div>
          <h2 class="qp-card__name">{p.name}</h2>
          <p class="qp-card__blurb">{p.blurb}</p>
          <a
            href={cloakedLink({ slug: p.slug })}
            class="qp-card__buy"
            rel="sponsored noopener"
            target="_blank"
          >
            Buy on Amazon
            <span class="qp-card__arrow" aria-hidden="true">&rarr;</span>
          </a>
        </article>
      ))}

      <article class="qp-card qp-card--tip">
        <div class="qp-card__category">Pro tip · no purchase needed</div>
        <h2 class="qp-card__name">Use newspaper on the windshield.</h2>
        <p class="qp-card__blurb">
          Crumpled newspaper cleans glass better than most microfiber towels.
          The ink does not transfer to glass anymore (modern ink chemistry),
          the paper is mildly abrasive without scratching, and it leaves zero
          streaks. Spray your glass cleaner, wipe with newspaper, throw the
          paper away. Done.
        </p>
        <div class="qp-card__tip-tag">Editor's note</div>
      </article>
    </div>
  </section>

  <section class="qp-after">
    <div class="qp-after__inner">
      <h2 class="qp-after__title">Want the deep version?</h2>
      <p class="qp-after__lede">
        These six picks are the no-brainer starter kit. If you want the
        full editorial deep-dive on any of these categories with spec
        comparisons across 5 to 7 products and reader-segment fit, the
        buying guides go deeper.
      </p>
      <div class="qp-after__links">
        <a href="/buyers-guides/best-car-wash-soap-for-home-detailers/" class="qp-after__link">Best car wash soap &rarr;</a>
        <a href="/buyers-guides/best-interior-cleaner-for-home-detailers/" class="qp-after__link">Best interior cleaner &rarr;</a>
        <a href="/buyers-guides/best-wheel-cleaner-for-home-detailers/" class="qp-after__link">Best wheel cleaner &rarr;</a>
        <a href="/buyers-guides/best-foam-cannon-for-home-detailers/" class="qp-after__link">Best foam cannon &rarr;</a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* Hero */
  .qp-hero {
    background: var(--color-paper);
    padding: var(--space-12) var(--space-6) var(--space-8);
    border-bottom: 1px solid var(--color-sage-light);
  }
  .qp-hero__inner {
    max-width: 740px;
    margin: 0 auto;
  }
  .qp-hero__eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-forest);
    margin-bottom: var(--space-4);
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .qp-hero__eyebrow::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 1px;
    background: var(--color-forest);
  }
  .qp-hero__title {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    line-height: 1.04;
    letter-spacing: -0.02em;
    color: var(--color-paper-ink);
    margin: 0 0 var(--space-5);
    font-weight: 400;
  }
  .qp-hero__title em {
    font-style: italic;
    color: var(--color-forest);
  }
  .qp-hero__lede {
    font-family: var(--font-sans);
    font-size: 1.1875rem;
    line-height: 1.55;
    color: var(--color-paper-ink);
    margin: 0 0 var(--space-4);
  }
  .qp-hero__sub {
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-muted);
    margin: 0;
    font-style: italic;
  }

  /* Grid */
  .qp-grid-wrap {
    background: var(--color-paper);
    padding: var(--space-10) var(--space-6);
  }
  .qp-grid {
    max-width: var(--container-max, 1240px);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-5);
  }

  /* Card */
  .qp-card {
    background: var(--color-cream);
    border: 1px solid var(--color-sage-light);
    border-radius: 4px;
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: border-color 200ms ease, transform 200ms ease;
  }
  .qp-card:hover {
    border-color: var(--color-forest);
    transform: translateY(-2px);
  }
  .qp-card__category {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-forest);
  }
  .qp-card__name {
    font-family: var(--font-serif);
    font-size: 24px;
    line-height: 1.15;
    letter-spacing: -0.012em;
    color: var(--color-paper-ink);
    margin: 0;
    font-weight: 400;
  }
  .qp-card__blurb {
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-paper-ink);
    margin: 0;
    flex-grow: 1;
  }
  .qp-card__buy {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-cream);
    background: var(--color-paper-ink);
    padding: var(--space-3) var(--space-4);
    border-radius: 2px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-2);
    transition: background 200ms ease, transform 200ms ease;
    align-self: flex-start;
  }
  .qp-card__buy:hover {
    background: var(--color-forest);
    transform: translateX(2px);
  }
  .qp-card__arrow {
    transition: transform 180ms ease;
  }
  .qp-card__buy:hover .qp-card__arrow {
    transform: translateX(3px);
  }

  /* Pro-tip card variant */
  .qp-card--tip {
    background: var(--color-paper-ink);
    color: var(--color-cream);
    border-color: var(--color-paper-ink);
    position: relative;
  }
  .qp-card--tip .qp-card__category {
    color: var(--color-brass-soft, #F7E9C8);
  }
  .qp-card--tip .qp-card__name {
    color: var(--color-cream);
    font-style: italic;
  }
  .qp-card--tip .qp-card__blurb {
    color: rgba(251, 250, 247, 0.85);
  }
  .qp-card__tip-tag {
    font-family: var(--font-mono, "JetBrains Mono", ui-monospace, Consolas, monospace);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-brass-soft, #F7E9C8);
    margin-top: var(--space-2);
    opacity: 0.7;
  }
  .qp-card--tip:hover {
    transform: translateY(-2px);
    border-color: var(--color-paper-ink);
  }

  /* After-section / links to deep guides */
  .qp-after {
    background: var(--color-paper-muted);
    padding: var(--space-12) var(--space-6);
    border-top: 1px solid var(--color-sage-light);
  }
  .qp-after__inner {
    max-width: 740px;
    margin: 0 auto;
  }
  .qp-after__title {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    line-height: 1.1;
    color: var(--color-paper-ink);
    margin: 0 0 var(--space-4);
    font-weight: 400;
    letter-spacing: -0.012em;
  }
  .qp-after__lede {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.55;
    color: var(--color-paper-ink);
    margin: 0 0 var(--space-6);
  }
  .qp-after__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .qp-after__link {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--color-forest);
    text-decoration: none;
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-sage-light);
    transition: color 180ms ease, padding-left 180ms ease;
  }
  .qp-after__link:hover {
    color: var(--color-forest-mid);
    padding-left: var(--space-2);
  }
  .qp-after__link:last-child {
    border-bottom: 0;
  }

  @media (max-width: 760px) {
    .qp-hero,
    .qp-after {
      padding: var(--space-10) var(--space-4);
    }
    .qp-grid-wrap {
      padding: var(--space-8) var(--space-4);
    }
  }
</style>
