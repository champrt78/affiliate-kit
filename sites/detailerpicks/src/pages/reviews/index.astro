---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import ReviewCard from "@affkit/shared-ui/ReviewCard.astro";

const entries = await getCollection("reviews");
const sorted = entries.sort((a, b) => {
  const aTime = a.data.pubDate instanceof Date ? a.data.pubDate.getTime() : new Date(a.data.pubDate).getTime();
  const bTime = b.data.pubDate instanceof Date ? b.data.pubDate.getTime() : new Date(b.data.pubDate).getTime();
  return bTime - aTime;
});
---
<MainLayout
  title="Reviews"
  description="Spec-verified product reviews. What each one does well, where it falls short, and who it actually fits."
>
  <div class="page-inner">
    <header class="page-header">
      <h1>Reviews</h1>
      <p class="lede">Spec-verified product reviews. What each one does well, where it falls short, and who it actually fits.</p>
    </header>

    {sorted.length === 0 ? (
      <p class="empty">No reviews yet. Check back soon.</p>
    ) : (
      <div class="grid">
        {sorted.map((entry) => <ReviewCard entry={entry} />)}
      </div>
    )}
  </div>
</MainLayout>

<style>
  /* Centered, padded shell so the heading + grid don't sit flush against the
     page-shell edge. Matches the horizontal gutter the article pages carry. */
  .page-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6) var(--space-20);
  }
  .page-header { margin-bottom: var(--space-8); }
  .page-header h1 { font-size: var(--text-3xl); margin: 0 0 var(--space-3); }
  .lede { font-size: var(--text-lg); color: var(--color-muted); margin: 0; }
  .empty { color: var(--color-muted); }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
  }
  @media (max-width: 760px) {
    .page-inner { padding: var(--space-10) var(--space-4) var(--space-16); }
  }
</style>
