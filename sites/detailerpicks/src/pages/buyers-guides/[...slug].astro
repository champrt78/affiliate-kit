---
import { getCollection, type CollectionEntry } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import CTA from "@affkit/shared-ui/CTA.astro";
import BottomLine from "@affkit/shared-ui/BottomLine.astro";
import Media from "@affkit/shared-ui/Media.astro";
import { cloakedLink } from "@affkit/shared-utils";
import { productSchema } from "@affkit/shared-utils";

export async function getStaticPaths() {
  const entries = await getCollection("buyers-guides");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"buyers-guides">;
}

const { entry } = Astro.props;
const { data, body } = entry;
const { Content } = await entry.render();

const BOTTOMLINE_PLACEHOLDER = "_The Bottom Line is being written._";
const isDraft = !data.bottomLine
  || !data.bottomLine.verdict
  || data.bottomLine.verdict.trim() === ""
  || data.bottomLine.verdict.includes(BOTTOMLINE_PLACEHOLDER);

const productLds = data.products.map((p) =>
  productSchema({
    name: p.name,
    brand: p.brand,
    sku: p.name,
    image: (p as any).image ?? "",
    description: data.description,
    offerUrl: p.affiliateUrl,
  })
);

const cloakedHref = cloakedLink({ slug: entry.slug });
const robotsContent = isDraft ? "noindex, nofollow" : "index, follow";

const formattedUpdated = data.lastUpdated instanceof Date
  ? data.lastUpdated.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })
  : String(data.lastUpdated);
const isoUpdated = data.lastUpdated instanceof Date
  ? data.lastUpdated.toISOString()
  : String(data.lastUpdated);

const totalPicks = data.products.length;
const fmtPrice = (n?: number) => (typeof n === "number" && n > 0) ? `$${n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : null;
---
<MainLayout
  title={data.title}
  description={data.description}
  robotsContent={robotsContent}
  ogType="article"
  bgTheme={data.bgTheme}
>
  {productLds.map((ld) => (
    <script type="application/ld+json" set:html={JSON.stringify(ld)} />
  ))}

  {isDraft && (
    <aside class="draft-banner" role="alert">
      <strong>DRAFT</strong> — this guide's "Bottom Line" section hasn't been filled in.
      Don't link to this page yet. Indexing is disabled until it's complete.
    </aside>
  )}

  {data.images?.hero && (
    <div class="guide-hero" style={`background-image: url('${data.images.hero}')`} role="img" aria-label={data.images.heroCaption || data.title}>
      <div class="guide-hero__overlay"></div>
    </div>
  )}

  <article class="guide">
    <header class="guide-header">
      <p class="kicker">Buyer's Guide</p>
      <h1 class="guide-title">{data.title}</h1>
      <p class="guide-desc">{data.description}</p>
      <div class="guide-byline">
        <div class="guide-byline__avatar">D</div>
        <div class="guide-byline__who">
          <div class="guide-byline__name">The DetailerPicks editorial team</div>
          <div class="guide-byline__role">Spec analysis &middot; verified against current Amazon listings</div>
        </div>
        <div class="guide-byline__date">
          <span class="guide-byline__date-label">Last updated</span>
          <time datetime={isoUpdated}>{formattedUpdated}</time>
        </div>
      </div>
    </header>

    {/* Bottom Line — shared component (locked 2026-05-24). Verdict box sits
        directly under the title block, above every pick/spec — matching the
        canonical mockup order (title → deck → byline → Bottom Line) and the
        review template. The DRAFT/noindex gate is position-independent.
        Single source: packages/shared-ui/src/components/BottomLine.astro */}
    <BottomLine bottomLine={data.bottomLine} isDraft={isDraft} />

    {/* ════════ AT A GLANCE ════════ */}
    <section class="section">
      <div class="section-head">
        <h2>At a glance</h2>
      </div>

      <div class="quick-grid">
        {data.products.map((p, i) => {
          const price = fmtPrice(p.priceFrom);
          const buyHref = (p as any).cloakedSlug
            ? cloakedLink({ slug: (p as any).cloakedSlug })
            : p.affiliateUrl;
          return (
            <article class="qcard">
              <a href={buyHref} class="qcard__img" rel="sponsored noopener" target="_blank" aria-label={`Check current price for ${p.name}`}>
                <Media src={(p as any).image} alt={p.name} variant="card" placeholder="🧴" />
                {price && <div class="qcard__img__price">{price}</div>}
              </a>
              <div class="qcard__body">
                <div class="qcard__persona">{p.bestFor || p.brand}</div>
                <a href={buyHref} class="qcard__product" rel="sponsored noopener" target="_blank">
                  {p.name} <span aria-hidden="true">&rarr;</span>
                </a>
                {(p as any).hook && <p class="qcard__hook">{(p as any).hook}</p>}
                <a href={`#pick-${i + 1}`} class="qcard__cta">
                  Read the full review <span class="qcard__cta__arrow" aria-hidden="true">&rarr;</span>
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    {/* ════════ THE FULL DETAIL ════════ */}
    <section class="section">
      <div class="section-head">
        <h2>The full detail</h2>
      </div>
      <p class="section-intro">
        The ranking reflects which reader segment each product fits best, based on documented chemistry and credible third-party reviewer commentary. Most premium products in this category clean adequately for weekly maintenance.
      </p>

      {data.products.map((p, i) => {
        const price = fmtPrice(p.priceFrom);
        const priceUnit = (p as any).priceUnit;
        const link = p.affiliateUrl;
        const reason = (p as any).reason;
        const productBody = (p as any).body;
        const facts = (p as any).facts;
        return (
          <article id={`pick-${i + 1}`} class="deep-card">
            <div class="deep-card__img-col">
              <div class="deep-card__img">
                <Media src={(p as any).image} alt={p.name} variant="deep" placeholder="🧴" />
              </div>
              <div class="deep-card__rank"><span>{i + 1}</span>of {totalPicks} picks</div>
            </div>

            <div class="deep-card__body">
              {p.bestFor && <div class="deep-card__persona">{p.bestFor}</div>}
              <h3 class="deep-card__heading">
                {reason && <span class="reason">{reason}</span>}
                <a class="product-link" href={link} rel="sponsored noopener" target="_blank">{p.name} <span aria-hidden="true">&rarr;</span></a>
              </h3>
              {productBody && <Fragment set:html={productBody} />}
            </div>

            <aside class="deep-card__rail">
              {price && (
                <>
                  <div class="deep-card__rail__price-label">Price from</div>
                  <div class="deep-card__rail__price">{price}{priceUnit && <small>/{priceUnit}</small>}</div>
                </>
              )}
              <a class="deep-card__rail__cta" href={link} rel="sponsored noopener" target="_blank">
                Check current price <span aria-hidden="true">&rarr;</span>
              </a>
              <div class="deep-card__rail__cta-sub">Affiliate link &middot; Amazon</div>
              {facts && Object.keys(facts).length > 0 && (
                <dl class="deep-card__rail__facts">
                  {Object.entries(facts).map(([k, v]) => (
                    <>
                      <dt>{k}</dt>
                      <dd>{v}</dd>
                    </>
                  ))}
                </dl>
              )}
            </aside>
          </article>
        );
      })}
    </section>

    {/* ════════ EDITORIAL BODY ════════
        Tables, FAQ, doctrine split, how-we-picked, etc. — everything that
        is not a per-pick block lives in the markdown body. */}
    <section class="section editorial">
      <div class="prose">
        <Content />
      </div>
    </section>

    <footer class="guide-footer">
      <div class="cta-wrap">
        <CTA href={cloakedHref} rel="sponsored noopener" target="_blank">
          See the top pick on Amazon
        </CTA>
      </div>
      <p class="updated">
        Last updated:
        <time datetime={isoUpdated}>{formattedUpdated}</time>
      </p>
    </footer>
  </article>
</MainLayout>

<style>
  /* ─── Draft banner ─── */
  .draft-banner {
    background: #fef3c7;
    border: 2px solid #d97706;
    color: #78350f;
    padding: var(--space-4);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
  }
  .draft-banner strong { font-size: var(--text-base); }

  /* ─── Article hero — capped, doesn't fill the viewport ─── */
  .guide-hero {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 6;
    max-height: 320px;
    background-size: cover;
    background-position: center;
    background-color: #14181C;
    margin-bottom: var(--space-8);
  }
  .guide-hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(20,24,28,0.10) 0%, rgba(20,24,28,0.45) 100%);
  }
  @media (max-width: 760px) {
    .guide-hero { aspect-ratio: 3 / 2; max-height: 220px; margin-bottom: var(--space-5); }
  }

  /* ─── Article container — wide for cards, narrow for prose ─── */
  .guide {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--space-6) var(--space-12);
  }
  /* Header fills the content column (criterion 5) — no narrow left cap that
     leaves dead space on the right. Long-form text gets a per-element ch cap
     below so line length stays readable while the block spans the width. */
  .guide-header {
    margin: 0 0 var(--space-10);
  }
  .kicker {
    text-transform: uppercase;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--color-paper-ink);
    margin: 0 0 var(--space-4);
    display: flex; align-items: center; gap: 14px;
  }
  .kicker::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 1px;
    background: var(--color-paper-ink);
  }
  .guide-title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(1.75rem, 3.6vw, 2.5rem);
    line-height: 1.06;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-4);
    color: var(--color-paper-ink);
  }
  .guide-desc {
    font-family: var(--font-sans);
    font-size: 1.1875rem;
    line-height: 1.6;
    color: var(--color-paper-ink);
    margin: 0 0 var(--space-6);
    max-width: 56ch;
  }

  /* Byline strip under title */
  .guide-byline {
    display: flex; align-items: center; gap: 16px;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-sage-light);
    font-size: 13px;
    color: var(--color-muted);
  }
  .guide-byline__avatar {
    width: 36px; height: 36px;
    border-radius: 999px;
    background: var(--color-forest);
    color: var(--color-paper-bright, #FBFAF7);
    display: grid; place-items: center;
    font-family: var(--font-serif);
    font-size: 18px;
    flex-shrink: 0;
  }
  .guide-byline__who { line-height: 1.4; }
  .guide-byline__name { color: var(--color-paper-ink); font-weight: 600; }
  .guide-byline__role { color: var(--color-muted); font-size: 12px; }
  .guide-byline__date {
    margin-left: auto;
    text-align: right;
    font-family: var(--font-mono, "JetBrains Mono", ui-monospace, Consolas, monospace);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .guide-byline__date-label { display: block; opacity: 0.7; font-size: 9.5px; margin-bottom: 2px; }
  @media (max-width: 600px) {
    .guide-byline__role { display: none; }
    .guide-byline__date { text-align: right; }
  }

  /* ─── Sections ─── */
  .section { margin: 0 0 var(--space-12); }
  .section-head {
    display: flex; align-items: baseline; justify-content: space-between;
    margin: 0 0 var(--space-6);
    padding-bottom: 14px;
    border-bottom: 1px solid var(--color-paper-ink);
  }
  .section-head h2 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-paper-ink);
    margin: 0;
    font-weight: 500;
  }
  .section-intro {
    max-width: 680px;
    font-size: 16px;
    line-height: 1.65;
    color: var(--color-paper-ink);
    margin: 0 0 var(--space-8);
  }

  /* ════ AT A GLANCE — quick card grid ════ */
  .quick-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }
  .qcard {
    background: var(--color-paper-bright, #FBFAF7);
    border: 1px solid var(--color-sage-light);
    border-radius: 6px;
    overflow: hidden;
    display: flex; flex-direction: column;
    transition: border-color 200ms ease, transform 200ms ease;
  }
  .qcard a { text-decoration: none; }
  .qcard:hover {
    border-color: var(--color-brass-soft, #D4B966);
    transform: translateY(-2px);
  }
  /* The card image box is the shared <Media variant="card"> (white bg, contain,
     fixed height). .qcard__img is just the link + positioning context for the
     price badge; Media owns the box. */
  .qcard__img {
    border-bottom: 1px solid var(--color-sage-light);
    position: relative;
    cursor: pointer;
    display: block;
  }
  .qcard__img :global(.media img) { transition: transform 220ms ease; }
  .qcard:hover .qcard__img :global(.media img) { transform: scale(1.03); }
  .qcard__img__price {
    position: absolute;
    top: 10px; right: 10px;
    background: var(--color-paper-ink);
    color: var(--color-paper-bright, #FBFAF7);
    font-family: var(--font-mono, "JetBrains Mono", ui-monospace, Consolas, monospace);
    font-size: 10.5px; font-weight: 600;
    padding: 3px 9px;
    border-radius: 999px;
    letter-spacing: 0.04em;
  }
  .qcard__body { padding: 18px 20px 18px; flex: 1; display: flex; flex-direction: column; }
  .qcard__persona {
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.35;
    letter-spacing: -0.005em;
    color: var(--color-paper-ink);
    margin-bottom: 10px;
    font-weight: 700;
  }
  /* qcard__product IS the product link (whole card is wrapped in <a>) — keep the
     forest accent color so it reads as a link. */
  .qcard__product {
    font-family: var(--font-serif);
    font-size: 17px; line-height: 1.25;
    color: var(--color-forest);
    margin: 0 0 12px;
    font-weight: 500;
    letter-spacing: -0.005em;
    border-bottom: 1.5px solid var(--color-brass-soft, #D4B966);
    padding-bottom: 4px;
    align-self: flex-start;
    transition: color 180ms ease, border-color 180ms ease;
  }
  .qcard:hover .qcard__product {
    color: var(--color-brass, #A07C3A);
    border-bottom-color: var(--color-brass, #A07C3A);
  }
  .qcard__hook {
    font-size: 13.5px; line-height: 1.55;
    color: var(--color-paper-ink);
    margin: 0 0 16px;
    flex: 1;
    max-width: 38ch;
    opacity: 0.85;
  }
  .qcard__cta {
    font-family: var(--font-sans);
    font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--color-paper-ink);
    padding: 10px 0 0;
    border-top: 1px solid var(--color-sage-light);
    display: flex; align-items: center; gap: 8px;
    transition: color 200ms ease;
  }
  .qcard:hover .qcard__cta { color: var(--color-brass, #A07C3A); }
  .qcard__cta__arrow { transition: transform 200ms ease; }
  .qcard:hover .qcard__cta__arrow { transform: translateX(3px); }

  /* ════ THE FULL DETAIL — expanded cards ════ */
  .deep-card {
    display: grid;
    grid-template-columns: 220px 1fr 240px;
    gap: 32px;
    align-items: start;
    padding: 32px;
    margin: 0 0 28px;
    background: var(--color-paper-bright, #FBFAF7);
    border: 1px solid var(--color-sage-light);
    border-radius: 10px;
    scroll-margin-top: 24px;
  }
  .deep-card:last-child { margin-bottom: 0; }
  .deep-card__img-col {
    display: flex; flex-direction: column; align-items: center;
  }
  /* Authored wrapper around <Media variant="deep"> — Astro scope isolation means
     a scoped rule can't target Media's root element (different component cid), so
     the box sizing + border live on this authored wrapper and Media (width:100%)
     fills it. radius+overflow so the border aligns with .media--deep's 10px radius. */
  .deep-card__img {
    width: 220px;
    border: 1px solid var(--color-sage-light);
    border-radius: 10px;
    overflow: hidden;
  }
  .deep-card__rank {
    margin-top: 18px;
    padding-top: 14px;
    border-top: 1px solid var(--color-sage-light);
    width: 100%;
    text-align: center;
    font-family: var(--font-mono, "JetBrains Mono", ui-monospace, Consolas, monospace);
    font-size: 10px; letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .deep-card__rank span {
    color: var(--color-paper-ink);
    font-family: var(--font-serif);
    font-size: 22px;
    margin-right: 6px;
    font-weight: 600;
    letter-spacing: 0;
    text-transform: none;
    vertical-align: -2px;
  }

  .deep-card__body { min-width: 0; }
  .deep-card__persona {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.35;
    letter-spacing: -0.005em;
    color: var(--color-paper-ink);
    margin-bottom: 12px;
    font-weight: 700;
  }
  .deep-card__heading {
    font-family: var(--font-serif);
    font-size: 26px;
    line-height: 1.25;
    margin: 0 0 18px;
    font-weight: 500;
    color: var(--color-paper-ink);
    letter-spacing: -0.015em;
    max-width: 32ch;
  }
  .deep-card__heading .reason {
    display: block;
    color: var(--color-muted);
    font-weight: 400;
    font-style: italic;
    font-size: 19px;
    line-height: 1.3;
    margin-bottom: 4px;
    letter-spacing: 0;
  }
  .deep-card__heading .product-link {
    color: var(--color-forest);
    font-weight: 500;
    border-bottom: 2px solid var(--color-brass-soft, #D4B966);
    text-decoration: none;
    transition: color 180ms ease, border-color 180ms ease;
  }
  .deep-card__heading .product-link:hover {
    color: var(--color-brass, #A07C3A);
    border-bottom-color: var(--color-brass, #A07C3A);
  }
  .deep-card__body :global(p) {
    font-size: 15.5px;
    line-height: 1.65;
    color: var(--color-paper-ink);
    margin: 0 0 16px;
    max-width: 62ch;
    opacity: 0.9;
  }
  .deep-card__body :global(p:last-child) { margin-bottom: 0; }
  .deep-card__body :global(ul) { margin: 0.5rem 0 0.75rem; padding-left: 1.25rem; }
  .deep-card__body :global(li) { margin-bottom: 0.3rem; line-height: 1.55; }
  .deep-card__body :global(li::marker) { color: var(--color-brass); }
  .deep-card__body :global(p a) {
    color: var(--color-forest);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: var(--color-brass-soft, #D4B966);
    text-underline-offset: 3px;
  }
  .deep-card__body :global(p a:hover) {
    color: var(--color-brass, #A07C3A);
  }

  /* Right rail: price + CTA + facts */
  .deep-card__rail {
    background: var(--color-paper-muted);
    border-radius: 6px;
    padding: 20px;
    text-align: left;
  }
  .deep-card__rail__price-label {
    font-family: var(--font-mono, "JetBrains Mono", ui-monospace, Consolas, monospace);
    font-size: 10px; letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 4px;
  }
  .deep-card__rail__price {
    font-family: var(--font-serif);
    font-size: 32px;
    color: var(--color-paper-ink);
    font-weight: 600;
    line-height: 1;
    margin-bottom: 16px;
  }
  .deep-card__rail__price small {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-muted);
    margin-left: 4px;
    font-family: var(--font-mono, "JetBrains Mono", ui-monospace, Consolas, monospace);
    letter-spacing: 0.04em;
    vertical-align: 0.15em;
  }
  .deep-card__rail__cta {
    display: block;
    background: var(--color-forest);
    color: var(--color-paper-bright, #FBFAF7);
    font-family: var(--font-sans);
    font-size: 13px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em;
    padding: 12px 18px;
    border-radius: 6px;
    text-align: center;
    margin-bottom: 12px;
    text-decoration: none;
    transition: background 200ms ease, transform 200ms ease;
  }
  .deep-card__rail__cta:hover {
    background: var(--color-brass, #A07C3A);
    transform: translateY(-1px);
  }
  .deep-card__rail__cta-sub {
    font-size: 11px;
    color: var(--color-muted);
    text-align: center;
    font-style: italic;
  }
  .deep-card__rail__facts {
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid var(--color-sage-light);
    font-size: 12px;
  }
  .deep-card__rail__facts dt {
    font-family: var(--font-mono, "JetBrains Mono", ui-monospace, Consolas, monospace);
    font-size: 9.5px; letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 2px;
  }
  .deep-card__rail__facts dd {
    margin: 0 0 10px;
    font-size: 12.5px;
    color: var(--color-paper-ink);
    line-height: 1.45;
  }
  .deep-card__rail__facts dd:last-child { margin-bottom: 0; }

  /* ════ EDITORIAL BODY (markdown content after the picks) ════
     Uses the full page width — H2 dividers, tables, and chunked-bullet panels
     all run the full container. Paragraph max-width is per-element so prose
     stays readable while tables and bullet panels get the room they need. */
  .editorial .prose {
    line-height: 1.7;
    font-size: 16px;
    color: var(--color-paper-ink);
  }
  .editorial .prose :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
