---
import { getCollection, type CollectionEntry } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import CTA from "@affkit/shared-ui/CTA.astro";
import { cloakedLink } from "@affkit/shared-utils";
import { productSchema } from "@affkit/shared-utils";

export async function getStaticPaths() {
  const entries = await getCollection("buyers-guides");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"buyers-guides">;
}

const { entry } = Astro.props;
const { data, body } = entry;
const { Content } = await entry.render();

// DRAFT detection — shared marker across review + buyers-guide piece types
const DRAFT_MARKER = "_The Bottom Line is being written._";
const isDraft = typeof body === "string" && body.includes(DRAFT_MARKER);

// One JSON-LD Product entry per listed product. Google reads each block independently.
const productLds = data.products.map((p) =>
  productSchema({
    name: p.name,
    brand: p.brand,
    sku: p.name,
    image: "",
    description: data.description,
    offerUrl: p.affiliateUrl,
  })
);

const cloakedHref = cloakedLink({ slug: entry.slug });

const robotsContent = isDraft ? "noindex, nofollow" : "index, follow";
---
<MainLayout
  title={data.title}
  description={data.description}
  robotsContent={robotsContent}
  ogType="article"
>
  {productLds.map((ld) => (
    <script type="application/ld+json" set:html={JSON.stringify(ld)} />
  ))}

  {isDraft && (
    <aside class="draft-banner" role="alert">
      <strong>DRAFT</strong> — this guide's "Bottom Line" section hasn't been filled in.
      Don't link to this page yet. Indexing is disabled until it's complete.
    </aside>
  )}

  {data.images?.hero && (
    <div class="guide-hero" style={`background-image: url('${data.images.hero}')`} role="img" aria-label={data.images.heroCaption || data.title}>
      <div class="guide-hero__overlay"></div>
    </div>
  )}

  <article class="guide">
    <header class="guide-header">
      <p class="kicker">Buyer's Guide</p>
      <h1>{data.title}</h1>
      <p class="description">{data.description}</p>
      <div class="cta-wrap">
        <CTA href={cloakedHref} rel="sponsored noopener" target="_blank">
          See the top pick on Amazon
        </CTA>
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>

    <footer class="guide-footer">
      <div class="cta-wrap">
        <CTA href={cloakedHref} rel="sponsored noopener" target="_blank">
          See the top pick on Amazon
        </CTA>
      </div>
      <p class="updated">
        Last updated:
        <time datetime={data.lastUpdated instanceof Date ? data.lastUpdated.toISOString() : String(data.lastUpdated)}>
          {data.lastUpdated instanceof Date ? data.lastUpdated.toISOString().slice(0, 10) : String(data.lastUpdated)}
        </time>
      </p>
    </footer>
  </article>
</MainLayout>

<style>
  .draft-banner {
    background: #fef3c7;
    border: 2px solid #d97706;
    color: #78350f;
    padding: var(--space-4);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
  }
  .draft-banner strong { font-size: var(--text-base); }

  /* Article hero — letterboxed editorial image with dark gradient anchor.
     Capped by max-height so it never dominates the viewport above the fold. */
  .guide-hero {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 6;
    max-height: 320px;
    background-size: cover;
    background-position: center;
    background-color: #14181C;
    margin-bottom: var(--space-8);
  }
  .guide-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(20, 24, 28, 0.10) 0%, rgba(20, 24, 28, 0.45) 100%);
  }
  @media (max-width: 760px) {
    .guide-hero { aspect-ratio: 3 / 2; max-height: 220px; margin-bottom: var(--space-5); }
  }

  /* Pick cards — product image + headline-as-link + body */
  .prose :global(.pick-card) {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--space-6);
    align-items: start;
    margin: var(--space-8) 0;
    padding: var(--space-5);
    background: var(--color-paper-muted);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-sage-light);
  }
  .prose :global(.pick-card__img) {
    width: 160px;
    height: 160px;
    background: var(--color-cream);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-sage-light);
    overflow: hidden;
    display: grid;
    place-items: center;
  }
  .prose :global(.pick-card__img img) {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    padding: 8px;
  }
  .prose :global(.pick-card__body) {
    min-width: 0;
  }
  .prose :global(.pick-card__body > h3) {
    margin-top: 0;
    margin-bottom: var(--space-3);
    font-size: 1.25rem;
    line-height: 1.25;
  }
  .prose :global(.pick-card__link) {
    color: var(--color-forest);
    font-weight: 700;
    text-decoration: none;
    border-bottom: 2px solid var(--color-brass-soft, #d4b966);
    transition: color 180ms ease, border-color 180ms ease;
  }
  .prose :global(.pick-card__link:hover) {
    color: var(--color-forest-mid, #2c5e8c);
    border-bottom-color: var(--color-forest);
  }
  /* Make product mentions inside blurbs visually distinct as affiliate links */
  .prose :global(.pick-card__body a[rel*="sponsored"]),
  .prose :global(.pick-card__body p a) {
    color: var(--color-forest);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: var(--color-brass-soft, #d4b966);
    text-underline-offset: 3px;
  }
  .prose :global(.pick-card__body p a:hover) {
    color: var(--color-forest-mid, #2c5e8c);
  }
  @media (max-width: 720px) {
    .prose :global(.pick-card) {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .prose :global(.pick-card__img) {
      width: 100%;
      height: 200px;
    }
  }

  .guide { max-width: var(--content-max); margin: 0 auto; padding: 0 var(--space-6); }
  .guide-header { margin-bottom: var(--space-8); max-width: 720px; }
  .kicker {
    text-transform: uppercase;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    color: var(--color-forest);
    margin: 0 0 var(--space-4);
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .kicker::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 1px;
    background: var(--color-forest);
  }
  h1 {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-5);
    color: var(--color-paper-ink);
  }
  .description {
    font-family: var(--font-sans);
    font-size: 1.1875rem;
    line-height: 1.55;
    color: var(--color-muted);
    margin: 0 0 var(--space-6);
    max-width: 36ch;
  }
  .cta-wrap { margin: var(--space-6) 0; }
  .prose { line-height: 1.7; }
  .prose :global(h2) {
    font-size: var(--text-2xl);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }
  .prose :global(h3) {
    font-size: var(--text-xl);
    margin-top: var(--space-6);
  }
  .guide-footer {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }
  .updated { color: var(--color-muted); font-size: var(--text-sm); }
</style>
