---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "@affkit/shared-ui/Hero.astro";
import ReviewCard from "@affkit/shared-ui/ReviewCard.astro";
import BuyersGuideCard from "@affkit/shared-ui/BuyersGuideCard.astro";
import CTA from "@affkit/shared-ui/CTA.astro";

/* ============================================================================
   CANONICAL HOMEPAGE — rebuilt from the shared component library.
   This file is byte-identical across the template and all 5 sites EXCEPT the
   PAGE block below. Structure, layout, and CSS are shared; only the per-site
   hero copy + scene photo + SEO strings change (that is the allowed per-site
   "content"). The page reads each site's content collections + tokens, so the
   skin (colors/fonts) and the cards auto-personalize with zero code change.

   Sections (the FussyBean gold-standard set):
     1. Hero            — scene photo + kicker rule + serif headline + 2 CTAs
     2. Lead            — one-paragraph editorial intro (drop cap)
     3. Featured pick   — this-month's guide (featured BuyersGuideCard)
     4. Latest reviews  — centered card grid (locked grid rule)
     5. More guides     — centered card grid
     6. Manifesto       — tokenized contrast band ("how we work")
   ========================================================================== */

/* ─── PER-SITE CONTENT (the only block that differs between sites) ─── */
const PAGE = {
  seoTitle: "GameOverGear",
  seoDescription:
    "GameOverGear compares retro gaming gear by spec and use case: controllers, arcade sticks, emulation handhelds, displays, and scalers.",
  heroKicker: "Retro gaming gear · the real feel",
  heroTitle: "Press Start again.",
  heroLede:
    "Controllers, handhelds, arcade sticks and scalers that actually feel like the originals. We line them up so the right pick is obvious.",
  heroImage:
    "https://images.unsplash.com/photo-1531525645387-7f14be1bdbbd?auto=format&fit=crop&w=2400&q=80",
  heroImageAlt: "Retro arcade cabinet glow in a dark room",
  leadBody:
    "Most retro-gear content is either a storefront pushing its own clone or a nostalgia post that never checks compatibility. We read the spec sheets, compare across brands by how you actually play, and say honestly when the budget pick is the one to get.",
};
/* ─────────────────────────────────────────────────────────────────── */

function sortByDateDesc<T extends { data: { pubDate: Date | string } }>(arr: T[]) {
  return [...arr].sort((a, b) => {
    const aTime = a.data.pubDate instanceof Date ? a.data.pubDate.getTime() : new Date(a.data.pubDate).getTime();
    const bTime = b.data.pubDate instanceof Date ? b.data.pubDate.getTime() : new Date(b.data.pubDate).getTime();
    return bTime - aTime;
  });
}

// Only published pieces reach the homepage. A piece is published once its
// Bottom Line verdict is filled (the repo's DRAFT/noindex gate). This predicate
// works across all 5 sites because every content schema shares bottomLine.verdict.
const isPublished = (e: any) =>
  e.data.bottomLine && typeof e.data.bottomLine.verdict === "string" && e.data.bottomLine.verdict.trim() !== "";

const allReviews = (await getCollection("reviews")).filter(isPublished);
const allGuides = (await getCollection("buyers-guides")).filter(isPublished);

const latestReviews = sortByDateDesc(allReviews).slice(0, 6);
const latestGuides = sortByDateDesc(allGuides);
const featuredGuide = latestGuides[0];
const otherGuides = latestGuides.slice(1, 4);
---
<MainLayout title={PAGE.seoTitle} description={PAGE.seoDescription}>
  <Hero
    title={PAGE.heroTitle}
    kicker={PAGE.heroKicker}
    tagline={PAGE.heroLede}
    image={PAGE.heroImage}
    imageAlt={PAGE.heroImageAlt}
    size="full"
  >
    <div class="hero-actions">
      {featuredGuide && (
        <CTA href={`/buyers-guides/${featuredGuide.slug}/`} variant="primary" size="lg" external={false}>
          Start with the buying guide
        </CTA>
      )}
      <CTA href="/reviews/" variant="ghost" size="lg" external={false}>
        Browse single-product reviews
      </CTA>
    </div>
  </Hero>

  {/* Pixel brand wordmark — Ray wants GAME OVER GEAR in big PS2P on the home
      page (2026-06-01). Full-width neon band under the hero. */}
  <section class="brand-marquee" aria-label="Game Over Gear">
    <div class="brand-marquee__inner">
      <span class="brand-marquee__word">GAME</span>
      <span class="brand-marquee__word">OVER</span>
      <span class="brand-marquee__word brand-marquee__word--accent">GEAR</span>
    </div>
  </section>

  <section class="lead">
    <div class="lead__inner">
      <p>{PAGE.leadBody}</p>
    </div>
  </section>

  {featuredGuide && (
    <section class="featured">
      <div class="featured__inner">
        <header class="section-head">
          <div>
            <span class="section-head__kicker">This month's pick</span>
            <h2 class="section-head__title">Start here</h2>
          </div>
          <a href="/buyers-guides/" class="section-head__link">All buying guides</a>
        </header>
        <div class="featured__card">
          <BuyersGuideCard entry={featuredGuide} featured />
        </div>
      </div>
    </section>
  )}

  <section class="reviews">
    <div class="reviews__inner">
      <header class="section-head">
        <div>
          <span class="section-head__kicker">Single-product deep dives</span>
          <h2 class="section-head__title">Latest reviews</h2>
        </div>
        {latestReviews.length > 0 && (
          <a href="/reviews/" class="section-head__link">All reviews</a>
        )}
      </header>

      {latestReviews.length === 0 ? (
        <p class="empty">New single-product reviews land every quarter. The first pieces are in the works, built from published specs, verified-buyer reports, and use-case fit.</p>
      ) : (
        <div class="reviews__grid">
          {latestReviews.map((entry) => <ReviewCard entry={entry} />)}
        </div>
      )}
    </div>
  </section>

  {otherGuides.length > 0 && (
    <section class="more-guides">
      <div class="more-guides__inner">
        <header class="section-head">
          <div>
            <span class="section-head__kicker">By use case</span>
            <h2 class="section-head__title">More buying guides</h2>
          </div>
        </header>
        <div class="more-guides__grid">
          {otherGuides.map((entry) => <BuyersGuideCard entry={entry} />)}
        </div>
      </div>
    </section>
  )}

  <section class="manifesto">
    <div class="manifesto__inner">
      <span class="manifesto__kicker">How we work</span>
      <h2 class="manifesto__title">Cross-brand and honest, by design.</h2>
      <p>
        We do not sell the products and we do not run a workshop. We read
        manufacturer spec sheets, aggregate verified-buyer reports, watch
        independent reviewer testing, and ask one question: for the person
        reading this, which pick actually fits? When the cheaper option is the
        right answer, we say so.
      </p>
      <p>
        Every buy link goes through our own redirect so we can swap retailers
        without breaking older posts. We earn a commission on Amazon purchases
        at no extra cost to you.
      </p>
      <div class="manifesto__actions">
        <CTA href="/about/" variant="ghost" external={false}>How we choose picks</CTA>
        <CTA href="/disclosure/" variant="ghost" external={false}>Affiliate disclosure</CTA>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* Pixel brand wordmark band (GAME OVER GEAR) under the hero. */
  .brand-marquee {
    background: var(--color-bg, #0d0d1a);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: clamp(26px, 5vw, 52px) var(--space-6, 24px);
    overflow: hidden;
  }
  .brand-marquee__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: baseline;
    gap: clamp(10px, 2.2vw, 26px);
    max-width: var(--container-max, 1180px);
    margin: 0 auto;
  }
  .brand-marquee__word {
    font-family: var(--font-serif); /* Press Start 2P */
    font-size: clamp(22px, 6.4vw, 60px);
    line-height: 1;
    letter-spacing: 0.02em;
    color: var(--color-paper-ink, #e8eaf0);
    text-shadow: 0 0 6px rgba(120, 200, 255, 0.35), 0 0 18px rgba(120, 200, 255, 0.18);
  }
  .brand-marquee__word--accent {
    color: var(--color-accent, #ff3db1);
    text-shadow: 0 0 8px var(--color-accent, #ff3db1), 0 0 22px var(--color-accent, #ff3db1);
  }

  /* Hero CTAs — ghost button needs paper outline on the dark veil */
  .hero-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-3);
  }
  :global(.hero--with-image) .hero-actions :global(.cta--ghost) {
    color: var(--color-paper);
    border-color: var(--color-paper);
  }
  :global(.hero--with-image) .hero-actions :global(.cta--ghost:hover) {
    background: var(--color-paper);
    color: var(--color-forest);
  }

  /* Lead — single column, sans body with serif drop cap */
  .lead {
    background: var(--color-bg);
    padding: var(--space-10) var(--space-6) var(--space-8);
  }
  .lead__inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .lead p {
    font-family: var(--font-sans);
    font-size: 18px;
    line-height: 1.6;
    color: var(--color-fg);
    margin: 0;
    font-weight: var(--weight-regular);
  }
  .lead p::first-letter {
    font-family: var(--font-serif);
    font-size: 64px;
    font-weight: var(--weight-semibold);
    color: var(--color-forest);
    float: left;
    line-height: 0.9;
    margin: 6px 12px 0 0;
  }

  /* Section heads — shared */
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--space-10);
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .section-head__kicker {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-brass);
    display: block;
    margin-bottom: var(--space-2);
  }
  .section-head__title {
    font-family: var(--font-serif);
    font-size: clamp(1.875rem, 3.2vw, 2.5rem);
    margin: 0;
    color: var(--color-forest);
    letter-spacing: var(--tracking-display);
  }
  .section-head__link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-forest);
    text-decoration: none;
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-brass);
  }
  .section-head__link:hover { color: var(--color-brass); }

  /* Featured — single guide call-out */
  .featured {
    background: var(--color-bg);
    padding: var(--space-16) var(--space-6);
  }
  .featured__inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }
  .featured__card {
    max-width: var(--content-wide);
    margin: 0 auto;
  }

  /* Reviews — centered card grid (locked grid rule: no orphan-row stretch) */
  .reviews {
    background: var(--color-paper-muted);
    padding: var(--space-16) var(--space-6);
  }
  .reviews__inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }
  .reviews__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 300px));
    justify-content: center;
    gap: var(--space-6);
  }
  @media (max-width: 720px) {
    .reviews__grid { grid-template-columns: 1fr; }
  }
  .empty {
    color: var(--color-muted);
    font-style: italic;
    font-family: var(--font-serif);
    max-width: 60ch;
  }

  /* More guides — centered card grid (locked grid rule) */
  .more-guides {
    background: var(--color-bg);
    padding: var(--space-16) var(--space-6);
  }
  .more-guides__inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }
  .more-guides__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 320px));
    justify-content: center;
    gap: var(--space-6);
  }
  @media (max-width: 720px) {
    .more-guides__grid { grid-template-columns: 1fr; }
  }

  /* Manifesto — tokenized contrast band (forest), the page's one inversion.
     Fully token-driven so it reads correctly on every skin. */
  .manifesto {
    background: var(--color-forest);
    padding: var(--space-20) var(--space-6);
  }
  .manifesto__inner {
    max-width: var(--content-max);
    margin: 0 auto;
    text-align: center;
  }
  .manifesto__kicker {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-brass-soft);
    margin-bottom: var(--space-4);
    display: inline-block;
  }
  .manifesto__title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.4vw, 2.75rem);
    margin: 0 0 var(--space-6);
    color: var(--color-paper);
    letter-spacing: -0.018em;
    font-weight: var(--weight-semibold);
  }
  .manifesto p {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-paper);
    opacity: 0.82;
    margin: 0 auto var(--space-4);
    max-width: 60ch;
  }
  .manifesto :global(.cta--ghost) {
    color: var(--color-brass-soft);
    border-color: var(--color-brass-soft);
  }
  .manifesto :global(.cta--ghost:hover) {
    background: var(--color-brass-soft);
    color: var(--color-forest);
    border-color: var(--color-brass-soft);
  }
  .manifesto__actions {
    display: inline-flex;
    gap: var(--space-3);
    justify-content: center;
    margin-top: var(--space-6);
    flex-wrap: wrap;
  }

  @media (max-width: 760px) {
    .lead { padding: var(--space-10) var(--space-4) var(--space-8); }
    .featured,
    .reviews,
    .more-guides { padding: var(--space-12) var(--space-4); }
    .manifesto { padding: var(--space-16) var(--space-4); }
  }
</style>
