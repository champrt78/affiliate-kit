---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import BuyersGuideCard from "@affkit/shared-ui/BuyersGuideCard.astro";

const entries = await getCollection("buyers-guides");
const sorted = entries.sort((a, b) => {
  const aTime = a.data.pubDate instanceof Date ? a.data.pubDate.getTime() : new Date(a.data.pubDate).getTime();
  const bTime = b.data.pubDate instanceof Date ? b.data.pubDate.getTime() : new Date(b.data.pubDate).getTime();
  return bTime - aTime;
});
---
<MainLayout
  title="Buying guides"
  description="Comparative roundups of retro gaming gear for specific use cases: controllers, arcade sticks, emulation handhelds, displays, and scalers."
>
  <header class="page-header">
    <div class="page-header__inner">
      <span class="page-header__kicker">Buying guides</span>
      <h1 class="page-header__title">Comparative roundups, by use case.</h1>
      <p class="page-header__lede">
        Retro gear lines up differently depending on the job. These guides
        compare a handful of options for one well-defined use case, then name
        the pick we think most readers should default to.
      </p>
    </div>
  </header>

  <section class="grid-section">
    <div class="grid-section__inner">
      {sorted.length === 0 ? (
        <p class="empty">No buying guides yet. New ones land every quarter.</p>
      ) : (
        <div class="grid">
          {sorted.map((entry) => <BuyersGuideCard entry={entry} />)}
        </div>
      )}
    </div>
  </section>
</MainLayout>

<style>
  .page-header {
    background: var(--color-bg);
    padding: var(--space-10) var(--space-6) var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }
  .page-header__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 300px));
    justify-content: center;
    column-gap: var(--space-10);
    align-items: end;
  }
  .page-header__kicker {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brass);
    margin-bottom: var(--space-2);
  }
  .page-header__kicker::before {
    content: "";
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--color-brass);
    vertical-align: middle;
    margin-right: 10px;
    transform: translateY(-2px);
  }
  .page-header__title {
    font-family: var(--font-serif);
    line-height: 1.45;
    color: var(--color-paper-ink);
    margin: 0;
    font-weight: var(--weight-semibold);
  }
  .page-header__lede {
    font-family: var(--font-sans);
    font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
    line-height: 1.6;
    color: var(--color-muted);
    margin: 0;
    max-width: 56ch;
    align-self: end;
    padding-bottom: 4px;
  }

  .grid-section {
    padding: var(--space-12) var(--space-6) var(--space-20);
    background: var(--color-bg);
  }
  .grid-section__inner { max-width: var(--container-max); margin: 0 auto; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 300px));
    justify-content: center;
    gap: var(--space-6);
  }
  .empty {
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-style: italic;
  }

  @media (max-width: 760px) {
    .page-header { padding: var(--space-10) var(--space-4) var(--space-5); }
    .page-header__inner { grid-template-columns: 1fr; row-gap: var(--space-3); }
    .page-header__lede { padding-bottom: 0; }
    .grid-section { padding: var(--space-10) var(--space-4) var(--space-16); }
    .grid { grid-template-columns: 1fr; }
  }

  /* Ray 2026-05-31: listing/topic page-header was a split grid (2-col, or a card-grid that trapped the H1). Single-column full-width, left-aligned, matches DTP's correct version. */
  .page-header__inner { display: block; }
  .page-header__lede { align-self: auto; padding-bottom: 0; }

</style>
