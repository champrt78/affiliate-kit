---
import MainLayout from "../layouts/MainLayout.astro";
---
<MainLayout
  title="Contact"
  description="Get in touch with GameOverGear."
>
  <article class="doc">
    <h1>Contact</h1>

    <p>
      Have a correction, a product suggestion, or feedback on a review?
      Send a note to <a href="mailto:hello@gameovergear.games">hello@gameovergear.games</a>.
    </p>

    <p>
      We read everything but can't always reply. Genuine corrections
      get fixed quickly.
    </p>
  </article>
</MainLayout>

<style>
  .doc { max-width: var(--content-max); margin: 0 auto; padding: var(--space-12) var(--space-6) var(--space-20); }
  .doc h1 { font-family: var(--font-serif); color: var(--color-paper-ink); margin-bottom: var(--space-6); line-height: 1.45; }
  .doc p { font-family: var(--font-sans); line-height: 1.7; margin: 0 0 var(--space-4); color: var(--color-paper-ink); }
  .doc a { color: var(--color-brass); }
</style>
