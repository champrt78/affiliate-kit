---
import SiteShell from "@affkit/shared-ui/SiteShell.astro";
import AffiliateDisclosure from "@affkit/shared-ui/AffiliateDisclosure.astro";
import "../styles/site.css";
import siteConfig from "../data/site-config.json";

/* GameOverGear MainLayout — renders through the shared <SiteShell> (the
   "build once, skin per site" chrome). The 1980s arcade identity (neon on
   near-black, Press Start 2P display type, CRT scanline gutter) comes from
   src/styles/site.css token overrides + the chrome color tokens it sets
   (--header-bg/--footer-bg/--nav-accent/etc.); this layout supplies the
   per-site bits SiteShell slots/props in: the GAMEOVERGEAR pixel wordmark,
   pillar-derived nav, footer columns + blurb, footer-legal disclosure, the
   retro fontsHref (Press Start 2P + VT323 + Inter), and the gutter background.

   Header treatment mirrors fussybean:
     - Homepage (transparentHeader=true) → sticky full-bleed header over the
       attract-screen hero, solidifying to near-black on scroll.
     - Interior pages (transparentHeader=false) → the standard in-panel header. */
type BgTheme = "dawn" | "canopy" | "moss" | "twilight" | "pine" | "solid";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  robotsContent?: string;
  ogType?: string;
  ogImage?: string;
  bgTheme?: BgTheme;
  transparentHeader?: boolean;
}

const {
  title,
  description,
  canonical,
  robotsContent,
  ogType,
  ogImage,
  bgTheme = "solid",
  transparentHeader = false,
} = Astro.props;

const siteName = siteConfig.site.name;
/* Press Start 2P (pixel display), VT323 (arcade labels only), Inter (readable
   body). Matches the --font-* tokens in site.css. */
const fontsHref =
  "https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&family=Inter:wght@400;500;600;700&display=swap";

/* Per-page gutter background. gog ships "solid" only for now (the arcade gutter
   gradient + CRT scanline overlay from site.css). The themeBackgrounds map
   mirrors the kit seam so future per-page scenes drop in without touching the
   shell. The neon-on-indigo gradient matches the proof-skin (body.gog --gutter). */
const themeBackgrounds: Record<BgTheme, string> = {
  dawn: "linear-gradient(135deg, #0a0814, #2a1a4d) fixed",
  canopy: "linear-gradient(135deg, #0a0814, #1a3a4d) fixed",
  moss: "linear-gradient(135deg, #0a0814, #1a4d2e) fixed",
  twilight: "linear-gradient(135deg, #0a0814, #4d1a3a) fixed",
  pine: "linear-gradient(135deg, #0a0814, #241a4d) fixed",
  /* "solid" is the arcade gutter gradient from the proof-skin
     (component-system/page.html → body.gog --gutter). */
  solid: "linear-gradient(135deg, #0a0814, #241a4d) fixed",
};
const pageBg = themeBackgrounds[bgTheme];

/* Flat-color fallback painted under pageBg (and the gutter base the shell needs).
   Matches the darker end of the gradient. */
const gutterColor = "#0a0814";

/* Primary nav: Home + each pillar (/topics/<slug>/) + About. */
const navItems = [
  { href: "/", label: "Home" },
  ...siteConfig.navigation.pillars.map((p) => ({
    href: `/topics/${p.slug}/`,
    label: p.label,
  })),
  { href: "/about/", label: "About" },
];

const footerBlurb =
  "Retro gaming gear, ranked by the way you actually play. We compare controllers, arcade sticks, handhelds, and scalers against published specs and verified-buyer reports, then link out to where you can buy them.";

const footerColumns = [
  {
    heading: "Browse",
    links: [
      { href: "/topics/controllers/", label: "Controllers" },
      { href: "/topics/arcade-sticks/", label: "Arcade sticks" },
      { href: "/topics/retro-handhelds/", label: "Handhelds" },
      { href: "/topics/displays-and-scalers/", label: "Displays &amp; scalers" },
    ],
  },
  {
    heading: "Site",
    links: [
      { href: "/buyers-guides/", label: "Buying guides" },
      { href: "/reviews/", label: "Reviews" },
      { href: "/how-we-evaluate/", label: "How we evaluate" },
      { href: "/about/", label: "About" },
    ],
  },
  {
    heading: "Fine print",
    links: [
      { href: "/disclosure/", label: "Affiliate disclosure" },
      { href: "/privacy/", label: "Privacy" },
      { href: "/contact/", label: "Contact" },
    ],
  },
];
---
<SiteShell
  title={title}
  description={description}
  canonical={canonical}
  siteName={siteName}
  robotsContent={robotsContent}
  ogType={ogType}
  ogImage={ogImage}
  themeColor="#0b0a16"
  fontsHref={fontsHref}
  navItems={navItems}
  footerColumns={footerColumns}
  footerBlurb={footerBlurb}
  pageBg={pageBg}
  gutterColor={gutterColor}
  stickyHeader={transparentHeader}
  transparentHeader={transparentHeader}
>
  {/* Brand markup authored HERE so gog's scoped .brand* CSS matches it — Astro
      scopes slot styles to the authoring component, not SiteShell. The pixel
      wordmark: GAME (cyan) OVER (magenta) GEAR (cyan). */}
  <a href="/" class="brand" slot="brand" aria-label={`${siteName} home`}>
    <span class="brand__name">GAME<b>OVER</b>GEAR</span>
  </a>

  <AffiliateDisclosure slot="footer-legal" siteName={siteName} variant="footer" />

  <slot />
</SiteShell>

<style>
  /* Brand — Press Start 2P pixel wordmark with neon glow. Lives in this layout
     (not SiteShell) because the brand markup is slotted from here; Astro scopes
     these styles to the markup THIS file authors. */
  .brand {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .brand__name {
    font-family: "Press Start 2P", monospace;
    font-size: 13px;
    line-height: 1;
    letter-spacing: 0.5px;
    color: #2ee6ff;
    text-shadow: 0 0 8px rgba(46, 230, 255, 0.6);
  }
  .brand__name b {
    color: #ff2e88;
    font-weight: 400;
    text-shadow: 0 0 8px rgba(255, 46, 136, 0.6);
  }
  @media (max-width: 480px) {
    .brand__name { font-size: 11px; }
  }
</style>
