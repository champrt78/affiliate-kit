---
import SiteShell from "@affkit/shared-ui/SiteShell.astro";
import AffiliateDisclosure from "@affkit/shared-ui/AffiliateDisclosure.astro";
import "../styles/site.css";
import siteConfig from "../data/site-config.json";

/* FussyBean MainLayout — now renders through the shared <SiteShell> (the
   "build once, skin per site" chrome). The espresso/cream/caramel "coffeeshops
   smell" identity comes from src/styles/site.css token overrides + the chrome
   color tokens it sets (--header-bg/--footer-bg/--nav-accent/etc.); this layout
   only supplies the per-site bits SiteShell slots/props in: the bean-mark brand,
   pillar-derived nav, footer columns + blurb, footer-legal disclosure, the
   coffee fontsHref, and the per-page gutter background.

   Header treatment (per the migration spec):
     - Homepage (transparentHeader=true) → sticky full-bleed header overlaying
       the Variant-C hero, going solid espresso on scroll. SiteShell renders the
       header OUTSIDE the floating panel and applies .page-shell--bleed so the
       hero spans edge to edge (no 1240px framing / gutter strips).
     - Guide / review / index (transparentHeader=false) → the standard unified
       in-panel header (the DTP floating-panel look). */
type BgTheme = "dawn" | "canopy" | "moss" | "twilight" | "pine" | "solid";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  robotsContent?: string;
  ogType?: string;
  ogImage?: string;
  bgTheme?: BgTheme;
  transparentHeader?: boolean;
}

const {
  title,
  description,
  canonical,
  robotsContent,
  ogType,
  ogImage,
  bgTheme = "solid",
  transparentHeader = false,
} = Astro.props;

const siteName = siteConfig.site.name;
const fontsHref =
  "https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,900;1,9..144,500&family=Inter:wght@400;500;600&display=swap";

/* Per-page gutter background. fussybean ships "solid" only for now (every piece
   uses bgTheme:"solid"), so the espresso GUTTER COLOR is what shows beside the
   floating panel on interior pages — it matches the Variant-C gutter from the
   component-system mockup. The themeBackgrounds map mirrors DTP's seam so future
   per-page coffee scenes drop in without touching the shell. Scene photos are
   atmosphere-only (image policy), hot-linked from Unsplash, never product shots. */
const themeBackgrounds: Record<BgTheme, string> = {
  dawn: 'linear-gradient(rgba(26,15,8,0.32), rgba(26,15,8,0.32)), url("https://images.unsplash.com/photo-1442550528053-c431ecb55509?auto=format&fit=crop&w=2000&q=80") center/cover no-repeat fixed',
  canopy: 'linear-gradient(rgba(26,15,8,0.32), rgba(26,15,8,0.32)), url("https://images.unsplash.com/photo-1453614512568-c4024d13c247?auto=format&fit=crop&w=2000&q=80") center/cover no-repeat fixed',
  moss: 'linear-gradient(rgba(26,15,8,0.32), rgba(26,15,8,0.32)), url("https://images.unsplash.com/photo-1510707577719-ae7c14805e3a?auto=format&fit=crop&w=2000&q=80") center/cover no-repeat fixed',
  twilight: 'linear-gradient(rgba(26,15,8,0.45), rgba(26,15,8,0.45)), url("https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&w=2000&q=80") center/cover no-repeat fixed',
  pine: 'linear-gradient(rgba(26,15,8,0.32), rgba(26,15,8,0.32)), url("https://images.unsplash.com/photo-1521302080334-4bebac2763a6?auto=format&fit=crop&w=2000&q=80") center/cover no-repeat fixed',
  /* "solid" is the espresso gutter GRADIENT from the Variant-C mockup
     (docs/playgrounds/component-system/page.html → body.fussybean --gutter),
     not a flat color — this is what shows beside the panel on every current
     fussybean piece. */
  solid: "linear-gradient(135deg, #2a190f, #6b5238) fixed",
};
const pageBg = themeBackgrounds[bgTheme];

/* Flat-color fallback painted under pageBg (and the gutter base color the shell
   needs). Matches the darker end of the mockup gradient. */
const gutterColor = "#2a190f";

/* Primary nav: Home + each pillar (/topics/<slug>/) + About. */
const navItems = [
  { href: "/", label: "Home" },
  ...siteConfig.navigation.pillars.map((p) => ({
    href: `/topics/${p.slug}/`,
    label: p.label,
  })),
  { href: "/about/", label: "About" },
];

const footerBlurb =
  "Home coffee gear, ranked by spec and use case, so the counter you build is the one you'll actually love. We compare machines, grinders, and brew gear and link out to where you can buy them.";

/* fussybean footer carries brand + 3 columns (4 grid items). SiteShell's footer
   is column-count-driven, so passing all 3 columns yields the espresso 4-up. */
const footerColumns = [
  {
    heading: "Browse",
    links: [
      { href: "/topics/espresso-machines/", label: "Espresso machines" },
      { href: "/topics/grinders/", label: "Grinders" },
      { href: "/topics/manual-brewing/", label: "Kettles &amp; scales" },
      { href: "/topics/fun-stuff/", label: "Gifts &amp; fun" },
    ],
  },
  {
    heading: "Site",
    links: [
      { href: "/buyers-guides/", label: "Buying guides" },
      { href: "/reviews/", label: "Reviews" },
      { href: "/how-we-evaluate/", label: "How we evaluate" },
      { href: "/about/", label: "About" },
    ],
  },
  {
    heading: "Fine print",
    links: [
      { href: "/disclosure/", label: "Affiliate disclosure" },
      { href: "/privacy/", label: "Privacy" },
      { href: "/contact/", label: "Contact" },
    ],
  },
];
---
<SiteShell
  title={title}
  description={description}
  canonical={canonical}
  siteName={siteName}
  robotsContent={robotsContent}
  ogType={ogType}
  ogImage={ogImage}
  themeColor="#241710"
  fontsHref={fontsHref}
  navItems={navItems}
  footerColumns={footerColumns}
  footerBlurb={footerBlurb}
  pageBg={pageBg}
  gutterColor={gutterColor}
  stickyHeader={transparentHeader}
  transparentHeader={transparentHeader}
>
  {/* Brand markup is authored HERE so fussybean's scoped .brand* CSS (below)
      matches it — Astro scopes slot styles to the authoring component, not
      SiteShell. SiteShell only positions the brand slot as the first flex
      child of .site-header__inner. */}
  <a href="/" class="brand" slot="brand" aria-label={`${siteName} home`}>
    <span class="brand__bean" aria-hidden="true"></span>
    <span class="brand__name">{siteName}</span>
  </a>

  <AffiliateDisclosure slot="footer-legal" siteName={siteName} variant="footer" />

  <slot />
</SiteShell>

<style>
  /* Brand — bean mark + Fraunces wordmark (Variant-C). Lives in this layout
     (not SiteShell) because the brand markup is slotted from here; Astro scopes
     these styles to the markup THIS file authors. */
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--color-brass-soft);
  }
  .brand:hover { color: #fdf4e4; }
  .brand__bean {
    width: 28px; height: 28px;
    border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
    background: radial-gradient(circle at 35% 30%, var(--color-brass), #1a0f08);
    transform: rotate(-13deg);
    position: relative;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
    flex-shrink: 0;
  }
  .brand__bean::after {
    content: "";
    position: absolute;
    left: 48%; top: 13%;
    width: 2px; height: 74%;
    background: var(--color-brass-soft);
    transform: translateX(-50%) rotate(8deg);
  }
  .brand__name {
    font-family: var(--font-serif);
    font-weight: 900;
    font-size: 25px;
    letter-spacing: -0.01em;
    color: inherit;
  }
</style>
