---
import { getCollection, type CollectionEntry } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import ReviewArticle from "@affkit/shared-ui/ReviewArticle.astro";

export async function getStaticPaths() {
  const entries = await getCollection("reviews");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"reviews">;
}

const { entry } = Astro.props;
const { data } = entry;

/* DRAFT/noindex gate — keyed off bottomLine.verdict (NOT a body marker).
   Empty/placeholder verdict => noindex,nofollow. This is what satisfies
   magic-go R5 (noindex + bottomLine co-occurrence in the page template). */
const BOTTOMLINE_PLACEHOLDER = "_The Bottom Line is being written._";
const isDraft = !data.bottomLine
  || !data.bottomLine.verdict
  || data.bottomLine.verdict.trim() === ""
  || data.bottomLine.verdict.includes(BOTTOMLINE_PLACEHOLDER);

const heroImage = data.images?.hero && data.images.hero.length > 0
  ? data.images.hero
  : "";
const robotsContent = isDraft ? "noindex, nofollow" : "index, follow";
---
<MainLayout
  title={data.title}
  description={data.description}
  robotsContent={robotsContent}
  ogType="article"
  ogImage={heroImage || undefined}
  bgTheme={data.bgTheme}
>
  <ReviewArticle
    entry={entry}
    siteName="FussyBean"
    crumbLabel="All reviews"
    crumbHref="/reviews/"
    defaultRubric="Home Coffee Gear · Review"
    methodologyHref="/how-we-evaluate/"
    methodologyLabel="How we evaluate coffee gear"
    bottomCtaHeading="Ready to look?"
    bottomCtaCopy="We use one cloaked link per product so we can swap retailers without breaking old pages. Click through goes to Amazon."
    brandInitial="F"
    editorialTeamName="The FussyBean editorial team"
    credentialLine="Spec analysis & use-case framing · verified against current manufacturer listings and Amazon reports"
  />
</MainLayout>
