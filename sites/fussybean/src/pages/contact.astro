---
import MainLayout from "../layouts/MainLayout.astro";
import ProsePage from "@affkit/shared-ui/ProsePage.astro";
---
<MainLayout
  title="Contact"
  description="Get in touch with FussyBean."
>
  <ProsePage title="Contact">
    <p>
      Have a correction, a product suggestion, or feedback on a review?
      Send a note to <a href="mailto:hello@fussybean.com">hello@fussybean.com</a>.
    </p>

    <p>
      We read everything but cannot always reply. Genuine corrections
      get fixed quickly.
    </p>
  </ProsePage>
</MainLayout>
