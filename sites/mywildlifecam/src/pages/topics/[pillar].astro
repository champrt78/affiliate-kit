---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import PageHeader from "@affkit/shared-ui/PageHeader.astro";
import ReviewCard from "@affkit/shared-ui/ReviewCard.astro";
import BuyersGuideCard from "@affkit/shared-ui/BuyersGuideCard.astro";
import siteConfig from "../../data/site-config.json";

/* ============================================================================
   CANONICAL TOPIC HUB — rebuilt from the shared component library.
   One page per navigation.pillars[] entry. Lists the spokes whose `pillar` FK
   matches, grouped by collection (guides + reviews + comparisons), each in a
   locked-rule centered card grid. Empty pillars render a friendly placeholder
   so nav never 404s. Header is the shared <PageHeader>.

   This mirrors the 3 satellite hubs (fussybean / gameovergear / starteraquarium)
   but EXTENDS them: mwc + dtp also ship a `comparisons` collection, so this file
   queries it too and renders a "Head-to-head comparisons" block. Comparisons
   have no `product`/`rating`, so ReviewCard can't type them — they render via a
   lightweight inline card that reuses the hub's own .grid/.block CSS.
   ========================================================================== */

export async function getStaticPaths() {
  return siteConfig.navigation.pillars.map((pillar) => ({
    params: { pillar: pillar.slug },
    props: { pillar },
  }));
}

interface PillarDef {
  slug: string;
  label: string;
  type: string;
  categoryPillar: string | null;
  blurb: string;
  hubKicker: string;
}

const { pillar } = Astro.props as { pillar: PillarDef };

const allReviews = await getCollection("reviews");
const allGuides = await getCollection("buyers-guides");
const allComparisons = await getCollection("comparisons");

const byDate = (a: any, b: any) => {
  const at = a.data.pubDate instanceof Date ? a.data.pubDate.getTime() : new Date(a.data.pubDate).getTime();
  const bt = b.data.pubDate instanceof Date ? b.data.pubDate.getTime() : new Date(b.data.pubDate).getTime();
  return bt - at;
};

const guides = allGuides.filter((e) => (e.data as any).pillar === pillar.slug).sort(byDate);
const reviews = allReviews.filter((e) => (e.data as any).pillar === pillar.slug).sort(byDate);
const comparisons = allComparisons.filter((e) => (e.data as any).pillar === pillar.slug).sort(byDate);
const isEmpty = guides.length === 0 && reviews.length === 0 && comparisons.length === 0;
---
<MainLayout title={pillar.label} description={pillar.blurb}>
  <PageHeader kicker={pillar.hubKicker} title={pillar.label} lede={pillar.blurb} />

  <section class="grid-section">
    <div class="grid-section__inner">
      {isEmpty ? (
        <p class="empty">
          Nothing published in this topic yet. New comparisons land every quarter,
          built from published specs, verified-buyer reviews, and use-case fit.
        </p>
      ) : (
        <>
          {guides.length > 0 && (
            <div class="block">
              <h2 class="block__title">Buying guides</h2>
              <div class="grid">
                {guides.map((entry) => <BuyersGuideCard entry={entry} />)}
              </div>
            </div>
          )}
          {reviews.length > 0 && (
            <div class="block">
              <h2 class="block__title">Reviews</h2>
              <div class="grid">
                {reviews.map((entry) => <ReviewCard entry={entry} />)}
              </div>
            </div>
          )}
          {comparisons.length > 0 && (
            <div class="block">
              <h2 class="block__title">Head-to-head comparisons</h2>
              <div class="grid">
                {comparisons.map((entry) => (
                  <article class="cmp-card">
                    <a class="cmp-card__link" href={`/comparisons/${entry.slug}/`}>
                      <span class="cmp-card__kicker">Comparison</span>
                      <h3 class="cmp-card__title">{entry.data.title}</h3>
                      {entry.data.deck && <p class="cmp-card__desc">{entry.data.deck}</p>}
                    </a>
                  </article>
                ))}
              </div>
            </div>
          )}
        </>
      )}
    </div>
  </section>
</MainLayout>

<style>
  .grid-section {
    padding: var(--space-12) var(--space-6) var(--space-20);
    background: var(--color-bg);
  }
  .grid-section__inner { max-width: var(--container-max); margin: 0 auto; }
  .block { margin-bottom: var(--space-16); }
  .block:last-child { margin-bottom: 0; }
  .block__title {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    color: var(--color-forest);
    margin: 0 0 var(--space-6);
  }
  /* Locked grid rule: capped + centered, no orphan-row stretch. */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 300px));
    justify-content: center;
    gap: var(--space-6);
  }
  .empty {
    color: var(--color-muted);
    font-family: var(--font-serif);
    font-style: italic;
    max-width: 52ch;
  }

  /* Comparison card — text-only card (comparisons have no hero/rating). Reuses
     the card surface + hover treatment of ReviewCard so the grid stays cohesive. */
  .cmp-card {
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    height: 100%;
    transition: transform var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out);
  }
  .cmp-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-sage);
  }
  .cmp-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--space-6);
    color: var(--color-fg);
    text-decoration: none;
  }
  .cmp-card__kicker {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-brass);
    margin-bottom: var(--space-3);
  }
  .cmp-card__title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    letter-spacing: -0.015em;
    color: var(--color-forest);
    margin: 0 0 var(--space-3);
  }
  .cmp-card__desc {
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    margin: 0;
  }

  @media (max-width: 760px) {
    .grid-section { padding: var(--space-10) var(--space-4) var(--space-16); }
  }
  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
