---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "@affkit/shared-ui/Hero.astro";
import ReviewCard from "@affkit/shared-ui/ReviewCard.astro";
import BuyersGuideCard from "@affkit/shared-ui/BuyersGuideCard.astro";
import CTA from "@affkit/shared-ui/CTA.astro";

function sortByDateDesc<T extends { data: { pubDate: Date | string } }>(arr: T[]) {
  return [...arr].sort((a, b) => {
    const aTime = a.data.pubDate instanceof Date ? a.data.pubDate.getTime() : new Date(a.data.pubDate).getTime();
    const bTime = b.data.pubDate instanceof Date ? b.data.pubDate.getTime() : new Date(b.data.pubDate).getTime();
    return bTime - aTime;
  });
}

const allReviews = await getCollection("reviews");
const allGuides = await getCollection("buyers-guides");

const latestReviews = sortByDateDesc(allReviews).slice(0, 6);
const latestGuides = sortByDateDesc(allGuides);
const featuredGuide = latestGuides[0];
const otherGuides = latestGuides.slice(1, 4);

const heroImage = "https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=2400&q=80";
---
<MainLayout
  title="MyWildlifeCam"
  description="Trail cameras for the backyard naturalist. Buying guides and single-product reviews from a buyer's perspective."
>
  <Hero
    title="The backyard, on camera."
    kicker="Trail cams · buyer's-eye reviews"
    tagline="We compare trail cameras the way a careful first-time buyer would. Spec, fit, and use case. The pick you'd actually live with."
    image={heroImage}
    imageAlt="Light through a misty pine forest"
    size="full"
  >
    <div class="hero-actions">
      {featuredGuide && (
        <CTA href={`/buyers-guides/${featuredGuide.slug}/`} variant="primary" size="lg" external={false}>
          Start with the buying guide
        </CTA>
      )}
      <CTA href="/reviews/" variant="ghost" size="lg" external={false}>
        Browse single-product reviews
      </CTA>
    </div>
  </Hero>

  <section class="lead">
    <div class="lead__inner">
      <p>
        Trail cameras have outgrown the deer-stand. They live on garden sheds,
        across koi ponds, above backyard bird feeders, on cabin porches. We
        sift the catalog so the right pick is obvious for the use case you
        actually have, by the spec and fit signals that matter.
      </p>
    </div>
    <div class="ornament" aria-hidden="true">
      <span class="ornament__rule"></span>
      <span class="ornament__dot"></span>
      <span class="ornament__rule"></span>
    </div>
  </section>

  {featuredGuide && (
    <section class="featured">
      <div class="featured__inner">
        <header class="section-head">
          <div>
            <span class="section-head__kicker">This month's pick</span>
            <h2 class="section-head__title">Start here</h2>
          </div>
          <a href="/buyers-guides/" class="section-head__link">All buying guides</a>
        </header>
        <div class="featured__card">
          <BuyersGuideCard entry={featuredGuide} featured />
        </div>
      </div>
    </section>
  )}

  <section class="reviews">
    <div class="reviews__inner">
      <header class="section-head">
        <div>
          <span class="section-head__kicker">Single-product deep dives</span>
          <h2 class="section-head__title">Latest reviews</h2>
        </div>
        {latestReviews.length > 0 && (
          <a href="/reviews/" class="section-head__link">All reviews</a>
        )}
      </header>

      {latestReviews.length === 0 ? (
        <p class="empty">No reviews yet. New ones land every quarter.</p>
      ) : (
        <div class="reviews__grid">
          {latestReviews.map((entry) => <ReviewCard entry={entry} />)}
        </div>
      )}
    </div>
  </section>

  {otherGuides.length > 0 && (
    <section class="more-guides">
      <div class="more-guides__inner">
        <header class="section-head">
          <div>
            <span class="section-head__kicker">By use case</span>
            <h2 class="section-head__title">More buying guides</h2>
          </div>
        </header>
        <div class="more-guides__grid">
          {otherGuides.map((entry) => <BuyersGuideCard entry={entry} />)}
        </div>
      </div>
    </section>
  )}

  <section class="manifesto">
    <div class="manifesto__inner">
      <span class="manifesto__kicker">How we work</span>
      <h2 class="manifesto__title">A buyer's-eye view, not a field test.</h2>
      <p>
        We don't claim to have field-tested every camera. We read manufacturer
        spec sheets, owner reviews, and independent teardowns, then we ask:
        for the person reading this, is this the right tool? When we do own a
        camera, we say so plainly and tell you what we learned.
      </p>
      <p>
        Every "buy" link goes through our own redirect so we can swap retailers
        without breaking older posts. We earn a commission on Amazon purchases
        at no extra cost to you.
      </p>
      <div class="manifesto__actions">
        <CTA href="/about/" variant="ghost" external={false}>How we choose picks</CTA>
        <CTA href="/disclosure/" variant="ghost" external={false}>Affiliate disclosure</CTA>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .hero-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-3);
  }
  /* On image hero, ghost CTA needs to be visible on dark backdrop */
  :global(.hero--with-image) .hero-actions :global(.cta--ghost) {
    color: var(--color-paper);
    border-color: var(--color-paper);
  }
  :global(.hero--with-image) .hero-actions :global(.cta--ghost:hover) {
    background: var(--color-paper);
    color: var(--color-forest);
  }

  /* Lead paragraph - magazine-style intro */
  .lead {
    background: var(--color-bg);
    padding: var(--space-16) var(--space-6) var(--space-12);
  }
  .lead__inner {
    max-width: var(--content-max);
    margin: 0 auto;
  }
  .lead p {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2vw, 1.625rem);
    line-height: 1.45;
    color: var(--color-forest);
    margin: 0;
    font-weight: var(--weight-regular);
    letter-spacing: -0.005em;
  }

  /* Section ornament — brass hairline with center dot */
  .ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    margin: var(--space-12) auto 0;
    max-width: 200px;
    opacity: 0.7;
  }
  .ornament__rule {
    flex: 1;
    height: 1px;
    background: var(--color-brass);
  }
  .ornament__dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-brass);
    flex-shrink: 0;
  }

  /* Section heads — shared */
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--space-10);
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .section-head__kicker {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-brass);
    display: block;
    margin-bottom: var(--space-2);
  }
  .section-head__title {
    font-family: var(--font-serif);
    font-size: clamp(1.875rem, 3.2vw, 2.5rem);
    margin: 0;
    color: var(--color-forest);
    letter-spacing: var(--tracking-display);
  }
  .section-head__link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-forest);
    text-decoration: none;
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-brass);
  }
  .section-head__link:hover {
    color: var(--color-brass);
  }

  /* Featured — single guide call-out */
  .featured {
    background: var(--color-bg);
    padding: var(--space-16) var(--space-6);
  }
  .featured__inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }
  .featured__card {
    max-width: var(--content-wide);
    margin: 0 auto;
  }

  /* Reviews section */
  .reviews {
    background: var(--color-paper-muted);
    padding: var(--space-16) var(--space-6);
  }
  .reviews__inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }
  .reviews__grid {
    display: grid;
    /* auto-fit (vs auto-fill) collapses empty tracks so 2 cards stretch to
       fill the row instead of leaving a phantom 3rd slot */
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-6);
  }
  .empty {
    color: var(--color-muted);
    font-style: italic;
    font-family: var(--font-serif);
  }

  /* More guides */
  .more-guides {
    background: var(--color-bg);
    padding: var(--space-16) var(--space-6);
  }
  .more-guides__inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }
  .more-guides__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }

  /* Manifesto */
  .manifesto {
    background:
      linear-gradient(180deg, var(--color-bg) 0%, var(--color-surface-alt) 100%);
    padding: var(--space-20) var(--space-6);
    border-top: 1px solid var(--color-border);
  }
  .manifesto__inner {
    max-width: var(--content-max);
    margin: 0 auto;
    text-align: center;
  }
  .manifesto__kicker {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-brass);
    margin-bottom: var(--space-4);
    display: inline-block;
  }
  .manifesto__title {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin: 0 0 var(--space-6);
    color: var(--color-forest);
  }
  .manifesto p {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-paper-ink);
    margin: 0 0 var(--space-4);
  }
  .manifesto__actions {
    display: inline-flex;
    gap: var(--space-3);
    justify-content: center;
    margin-top: var(--space-6);
    flex-wrap: wrap;
  }

  @media (max-width: 760px) {
    .lead { padding: var(--space-12) var(--space-4) var(--space-10); }
    .featured,
    .reviews,
    .more-guides { padding: var(--space-12) var(--space-4); }
    .manifesto { padding: var(--space-16) var(--space-4); }
  }
</style>
