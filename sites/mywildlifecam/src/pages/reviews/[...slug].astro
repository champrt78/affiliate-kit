---
import { getCollection, type CollectionEntry } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import CTA from "@affkit/shared-ui/CTA.astro";
import AffiliateDisclosure from "@affkit/shared-ui/AffiliateDisclosure.astro";
import { cloakedLink } from "@affkit/shared-utils";
import { productSchema } from "@affkit/shared-utils";

export async function getStaticPaths() {
  const entries = await getCollection("reviews");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"reviews">;
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await entry.render();

const BOTTOMLINE_PLACEHOLDER = "_The Bottom Line is being written._";
const isDraft = !data.bottomLine
  || !data.bottomLine.verdict
  || data.bottomLine.verdict.trim() === ""
  || data.bottomLine.verdict.includes(BOTTOMLINE_PLACEHOLDER);

const heroImage = data.images?.hero && data.images.hero.length > 0
  ? data.images.hero
  : "";
const heroCaption = data.images?.heroCaption
  ?? (heroImage ? `${data.product.name}. Photo: ${data.product.brand} manufacturer media kit.` : "");

const rubric = data.rubric ?? `Trail Cameras · Review`;
const deck = data.deck ?? data.description;
// Short display title for the H1 — keeps the page heading tight even when
// data.title is the longer SEO form. Falls back to data.title if product is missing.
const displayTitle = data.product?.name
  ? `${data.product.name} Review`
  : data.title;

const offerUrl = data.product.affiliate?.amazon
  ?? data.product.affiliate?.direct
  ?? undefined;

const productLd = productSchema({
  name: data.product.name,
  brand: data.product.brand,
  sku: data.product.sku ?? entry.slug,
  image: heroImage,
  description: data.description,
  offerUrl,
  price: data.product.price,
  currency: data.product.currency,
});

const faqLd = data.faq && data.faq.length > 0
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": data.faq.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer,
        },
      })),
    }
  : null;

const cloakedHref = cloakedLink({ slug: entry.slug });
const robotsContent = isDraft ? "noindex, nofollow" : "index, follow";

const formattedUpdated = data.lastUpdated instanceof Date
  ? data.lastUpdated.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })
  : String(data.lastUpdated);
const isoUpdated = data.lastUpdated instanceof Date
  ? data.lastUpdated.toISOString()
  : String(data.lastUpdated);

// Scorecard composite
const composite = data.scorecard
  ? Math.round(
      (data.scorecard.axes.reduce((sum, a) => sum + (a.score * a.weight) / 100, 0)) * 10
    ) / 10
  : null;
---
<MainLayout
  title={data.title}
  description={data.description}
  robotsContent={robotsContent}
  ogType="article"
  ogImage={heroImage || undefined}
>
  <script type="application/ld+json" set:html={JSON.stringify(productLd)} />
  {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}

  {isDraft && (
    <aside class="draft-banner" role="alert">
      <strong>DRAFT.</strong> This review's Bottom Line section hasn't been filled in.
      Don't link to this page yet. Indexing is disabled until it's complete.
    </aside>
  )}

  <article class="article">

    <header class="article-header">
      <a href="/reviews/" class="article-crumb">← All reviews</a>
      <span class="rubric">{rubric}</span>
      <h1 class="article-title">{displayTitle}</h1>
      <p class="article-deck">{deck}</p>

      <div class="byline" aria-label="Article byline">
        <span class="byline__avatar" aria-hidden="true">M</span>
        <div class="byline__who">
          <span class="byline__name">The MyWildlifeCam editorial team</span>
          <span class="byline__cred">Spec analysis &amp; use-case framing · verified against current manufacturer listings and Amazon reports</span>
        </div>
        <div class="byline__when">
          <span class="byline__label">Last updated</span>
          <time class="byline__date" datetime={isoUpdated}>{formattedUpdated}</time>
        </div>
      </div>
    </header>

    {heroImage && (
      <figure class="article-hero">
        <div class="article-hero__frame">
          <img
            src={heroImage}
            alt={data.product.name}
            loading="eager"
            decoding="async"
            style={data.images?.imageScale ? `transform: scale(${data.images.imageScale}); transform-origin: center;` : undefined}
          />
        </div>
        {heroCaption && <figcaption class="article-hero__caption">{heroCaption}</figcaption>}
      </figure>
    )}

    <div class="article-body">

      {/* Bottom Line — the callout (steal from mockup) */}
      {data.bottomLine && !isDraft && (
        <section class="bottom-line" aria-label="Bottom Line">
          <span class="bottom-line__label">Bottom Line</span>
          <p class="bottom-line__verdict">{data.bottomLine.verdict}</p>
          {data.bottomLine.supporting && Array.isArray(data.bottomLine.supporting) ? (
            <ul class="bottom-line__list">
              {data.bottomLine.supporting.map((item) => <li>{item}</li>)}
            </ul>
          ) : data.bottomLine.supporting ? (
            <p class="bottom-line__supporting">{data.bottomLine.supporting}</p>
          ) : null}
        </section>
      )}

      {/* Scorecard */}
      {data.scorecard && composite !== null && (
        <section class="scorecard" aria-label="Editorial scorecard">
          <header class="scorecard__head">
            <h2 class="scorecard__title">Editorial Scorecard</h2>
            <div class="scorecard__composite">{composite.toFixed(1)}<small>/10</small></div>
          </header>
          <ol class="scorecard__axes">
            {data.scorecard.axes.map((axis) => {
              const pct = Math.max(0, Math.min(100, (axis.score / 10) * 100));
              return (
                <li class="axis">
                  <div class="axis__name">
                    {axis.name}
                    <small>· {axis.weight}%</small>
                  </div>
                  <div class="axis__bar" aria-hidden="true">
                    <div class="axis__fill" style={`width:${pct}%`}></div>
                  </div>
                  <div class="axis__score">{axis.score.toFixed(1)}</div>
                </li>
              );
            })}
          </ol>
          {data.scorecard.note && (
            <p class="scorecard__note">{data.scorecard.note}</p>
          )}
        </section>
      )}

      {/* Decision aid: Buy it if / Don't buy it if */}
      {data.buyIf && (
        <section class="buyif" aria-label="Buy it if / Don't buy it if">
          <div class="buyif__card buyif__card--buy">
            <h3 class="buyif__heading">Buy it if</h3>
            <ul>
              {data.buyIf.buy.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="buyif__card buyif__card--skip">
            <h3 class="buyif__heading">Don't buy it if</h3>
            <ul>
              {data.buyIf.skip.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </section>
      )}

      <AffiliateDisclosure siteName="MyWildlifeCam" variant="inline" />

      {/* Markdown body — Who This Is For, At a Glance, What It Does Well, Where It Falls Short, How It Compares, Verdict */}
      <div class="prose">
        <Content />
      </div>

      {/* Flaws but not deal-breakers (steal from Wirecutter) */}
      {data.flaws && data.flaws.length > 0 && (
        <section class="flaws" aria-label="Flaws but not deal-breakers">
          <h2 class="flaws__title">Flaws but not deal-breakers</h2>
          {data.flaws.map((f) => (
            <div class="flaws__item">
              <h3 class="flaws__heading">{f.title}</h3>
              <p>{f.body}</p>
            </div>
          ))}
        </section>
      )}

      {/* FAQ (FAQPage schema emitted above) */}
      {data.faq && data.faq.length > 0 && (
        <section class="faq" aria-label="Frequently asked questions">
          <h2 class="faq__title">FAQ</h2>
          {data.faq.map((item) => (
            <details class="faq__item">
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </section>
      )}

      {/* CTA */}
      <aside class="bottomline-cta">
        <h3>Ready to look?</h3>
        <p>
          We use one cloaked link per product so we can swap retailers without
          breaking old pages. Click through goes to Amazon.
        </p>
        <CTA href={cloakedHref} variant="primary" size="lg" rel="sponsored noopener" target="_blank">
          See {data.product.name} on Amazon
        </CTA>
      </aside>

      {/* Methodology link footer (steal from RTINGS / Wirecutter / OGL) */}
      <footer class="article-footer">
        <a href="/how-we-evaluate/" class="methodology-link">How we evaluate trail cameras</a>
      </footer>

    </div>
  </article>
</MainLayout>

<style>
  .draft-banner {
    max-width: 920px;
    margin: var(--space-6) auto;
    padding: var(--space-4) var(--space-6);
    background: var(--color-brass-soft);
    border-left: 3px solid var(--color-brass);
    color: var(--color-forest);
    font-size: var(--text-sm);
  }

  /* ==== Article container — single-column centered, matches mockup ==== */
  .article {
    max-width: 920px;
    margin: 0 auto;
    padding: var(--space-12) var(--space-8) var(--space-20);
    background: var(--color-paper);
    color: var(--color-paper-ink);
  }

  /* ==== Header: crumb, rubric, h1, deck, byline ==== */
  .article-header { margin-bottom: var(--space-10); }

  .article-crumb {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: var(--space-6);
  }
  .article-crumb:hover { color: var(--color-brass); }

  .rubric {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brass);
    margin-bottom: var(--space-4);
  }
  .rubric::before {
    content: "";
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--color-brass);
    vertical-align: middle;
    margin-right: 10px;
    transform: translateY(-2px);
  }

  .article-title {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 4.5vw, 3.4rem);
    line-height: 1.05;
    letter-spacing: var(--tracking-display);
    color: var(--color-forest);
    margin: 0 0 var(--space-4);
    font-weight: var(--weight-semibold);
    font-variation-settings: "opsz" 120;
    max-width: 22ch;
    text-transform: capitalize;
  }

  .article-deck {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.125rem, 1.6vw, 1.375rem);
    line-height: 1.4;
    color: var(--color-muted);
    font-variation-settings: "opsz" 30;
    margin: 0 0 var(--space-8);
    max-width: 62ch;
    font-weight: var(--weight-regular);
  }

  /* Byline strip */
  .byline {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) 0;
    margin: 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .byline__avatar {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-full);
    background: var(--color-forest);
    color: var(--color-paper);
    display: grid;
    place-items: center;
    font-family: var(--font-serif);
    font-weight: var(--weight-semibold);
    font-size: var(--text-xl);
    line-height: 1;
  }
  .byline__who { flex: 1; display: flex; flex-direction: column; gap: 2px; line-height: 1.4; }
  .byline__name {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: var(--weight-semibold);
    color: var(--color-forest);
  }
  .byline__cred {
    font-family: var(--font-sans);
    font-size: 11.5px;
    color: var(--color-muted);
    max-width: 52ch;
  }
  .byline__when {
    margin-left: auto;
    text-align: right;
    flex-shrink: 0;
  }
  .byline__label {
    display: block;
    font-family: var(--font-sans);
    font-size: 10.5px;
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-brass);
    margin-bottom: 2px;
  }
  .byline__date {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    color: var(--color-forest);
  }
  @media (max-width: 640px) {
    .byline { flex-wrap: wrap; }
    .byline__when { margin-left: 0; text-align: left; padding-left: calc(44px + var(--space-4)); }
  }

  /* ==== Hero image + caption ==== */
  .article-hero {
    margin: 0 0 var(--space-10);
  }
  .article-hero__frame {
    background: var(--color-paper-muted);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    display: grid;
    place-items: center;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }
  .article-hero img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    mix-blend-mode: multiply;
    transition: transform var(--duration-slow) var(--ease-out);
  }
  .article-hero__caption {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-muted);
    font-style: italic;
    margin-top: var(--space-3);
    padding-left: var(--space-2);
    font-style: italic;
  }

  /* ==== Article body — capped to editorial reading width (68ch) ==== */
  .article-body {
    max-width: 68ch;
    margin: 0 auto;
  }

  /* Bottom Line callout — steal from mockup */
  .bottom-line {
    background: var(--color-cream);
    border-left: 3px solid var(--color-brass);
    padding: var(--space-6) var(--space-8);
    margin: 0 0 var(--space-10);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }
  .bottom-line__label {
    display: block;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brass);
    margin-bottom: var(--space-3);
  }
  .bottom-line__verdict {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    line-height: 1.45;
    color: var(--color-forest);
    margin: 0;
    font-weight: var(--weight-semibold);
    font-variation-settings: "opsz" 30;
  }
  .bottom-line__supporting {
    margin: var(--space-4) 0 0;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-paper-ink);
    font-weight: var(--weight-regular);
  }
  .bottom-line__list {
    margin: var(--space-4) 0 0;
    padding-left: var(--space-5);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-paper-ink);
  }
  .bottom-line__list li {
    margin-bottom: var(--space-2);
  }
  .bottom-line__list li:last-child {
    margin-bottom: 0;
  }
  .bottom-line__list li::marker {
    color: var(--color-brass);
  }

  /* Scorecard */
  .scorecard {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6) var(--space-8);
    margin: 0 0 var(--space-10);
    background: var(--color-paper);
  }
  .scorecard__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-5);
  }
  .scorecard__title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--color-forest);
    font-weight: var(--weight-semibold);
    margin: 0;
    border: 0;
    padding: 0;
  }
  .scorecard__composite {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3vw, 2.6rem);
    line-height: 1;
    color: var(--color-brass);
    font-weight: var(--weight-semibold);
    font-variation-settings: "opsz" 60;
  }
  .scorecard__composite small {
    font-size: 0.55em;
    color: var(--color-muted);
    font-weight: var(--weight-regular);
  }
  .scorecard__axes {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-3);
  }
  .axis {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: var(--space-4);
    align-items: center;
    font-size: var(--text-sm);
  }
  .axis__name {
    font-family: var(--font-sans);
    color: var(--color-forest);
    font-weight: var(--weight-medium);
  }
  .axis__name small {
    color: var(--color-muted);
    font-weight: var(--weight-regular);
    font-size: 11.5px;
    margin-left: 6px;
  }
  .axis__bar {
    width: 140px;
    height: 6px;
    background: var(--color-border);
    border-radius: 3px;
    overflow: hidden;
  }
  .axis__fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-brass), var(--color-brass-soft));
    border-radius: 3px;
  }
  .axis__score {
    font-variant-numeric: tabular-nums;
    color: var(--color-forest);
    font-weight: var(--weight-semibold);
    min-width: 42px;
    text-align: right;
  }
  .scorecard__note {
    margin: var(--space-5) 0 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-xs);
    color: var(--color-muted);
    line-height: 1.5;
    font-style: italic;
  }

  /* Buy if / Don't buy if */
  .buyif {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
    margin: 0 0 var(--space-10);
  }
  .buyif__card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5) var(--space-6);
    background: var(--color-paper);
  }
  .buyif__card--buy { border-left: 3px solid var(--color-forest); }
  .buyif__card--skip { border-left: 3px solid #8a4a3a; }
  .buyif__heading {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brass);
    margin: 0 0 var(--space-3);
    padding: 0;
    border: 0;
  }
  .buyif__card--skip .buyif__heading { color: #8a4a3a; }
  .buyif__card ul {
    margin: 0;
    padding-left: var(--space-5);
    font-size: var(--text-sm);
    line-height: 1.55;
  }
  .buyif__card li { margin-bottom: var(--space-2); color: var(--color-paper-ink); }
  .buyif__card li:last-child { margin-bottom: 0; }
  @media (max-width: 700px) {
    .buyif { grid-template-columns: 1fr; }
  }

  /* ==== Prose (markdown body) ==== */
  .prose {
    font-family: var(--font-sans);
    /* 18px / 1.65 — the AAB / Wirecutter publication-body standard */
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--color-paper-ink);
    margin-top: var(--space-8);
  }
  .prose :global(p) { margin: 0 0 var(--space-5); }
  .prose :global(h2) {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    color: var(--color-forest);
    margin: var(--space-10) 0 var(--space-4);
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border);
    font-weight: var(--weight-semibold);
    text-transform: capitalize;
  }
  .prose :global(h2):first-child { border-top: 0; padding-top: 0; margin-top: 0; }
  .prose :global(h3) {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--color-forest);
    margin: var(--space-8) 0 var(--space-3);
    font-weight: var(--weight-semibold);
    text-transform: capitalize;
  }
  .flaws__title,
  .faq__title {
    text-transform: capitalize;
  }
  .flaws__heading {
    text-transform: capitalize;
  }
  .prose :global(ul), .prose :global(ol) {
    padding-left: var(--space-6);
    margin: 0 0 var(--space-5);
  }
  .prose :global(li) { margin-bottom: var(--space-2); }
  .prose :global(strong) { color: var(--color-forest); font-weight: var(--weight-semibold); }
  .prose :global(table) { margin: var(--space-6) 0; }
  .prose :global(blockquote) {
    margin: var(--space-6) 0;
    padding: var(--space-4) var(--space-6);
    background: var(--color-surface-alt);
    border-left: 3px solid var(--color-brass);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--color-forest);
  }
  .prose :global(a) {
    color: var(--color-forest);
    font-weight: var(--weight-medium);
    text-decoration-color: var(--color-brass);
  }
  .prose :global(a:hover) { color: var(--color-brass); }

  /* Flaws but not deal-breakers */
  .flaws {
    background: rgba(160, 124, 58, 0.08);
    border-left: 3px solid var(--color-brass-soft);
    padding: var(--space-5) var(--space-7);
    margin: var(--space-10) 0;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }
  .flaws__title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--color-forest);
    margin: 0 0 var(--space-4);
    font-weight: var(--weight-semibold);
  }
  .flaws__item { margin-bottom: var(--space-4); }
  .flaws__item:last-child { margin-bottom: 0; }
  .flaws__heading {
    font-family: var(--font-sans);
