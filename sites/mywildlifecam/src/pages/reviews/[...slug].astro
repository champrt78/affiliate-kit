---
import { getCollection, type CollectionEntry } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import CTA from "@affkit/shared-ui/CTA.astro";
import AffiliateDisclosure from "@affkit/shared-ui/AffiliateDisclosure.astro";
import { cloakedLink } from "@affkit/shared-utils";
import { productSchema } from "@affkit/shared-utils";

export async function getStaticPaths() {
  const entries = await getCollection("reviews");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"reviews">;
}

const { entry } = Astro.props;
const { data, body } = entry;
const { Content } = await entry.render();

const DRAFT_MARKER = "_The Bottom Line is being written._";
const isDraft = typeof body === "string" && body.includes(DRAFT_MARKER);

const heroImage = data.images?.hero && data.images.hero.length > 0
  ? data.images.hero
  : "";

const offerUrl = data.product.affiliate?.amazon
  ?? data.product.affiliate?.direct
  ?? undefined;

const productLd = productSchema({
  name: data.product.name,
  brand: data.product.brand,
  sku: data.product.sku ?? entry.slug,
  image: heroImage,
  description: data.description,
  offerUrl,
  price: data.product.price,
  currency: data.product.currency,
});

const cloakedHref = cloakedLink({ slug: entry.slug });
const robotsContent = isDraft ? "noindex, nofollow" : "index, follow";

const formattedUpdated = data.lastUpdated instanceof Date
  ? data.lastUpdated.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })
  : String(data.lastUpdated);
const isoUpdated = data.lastUpdated instanceof Date
  ? data.lastUpdated.toISOString()
  : String(data.lastUpdated);
const rating = data.rating;
---
<MainLayout
  title={data.title}
  description={data.description}
  robotsContent={robotsContent}
  ogType="article"
  ogImage={heroImage || undefined}
>
  <script type="application/ld+json" set:html={JSON.stringify(productLd)} />

  {isDraft && (
    <aside class="draft-banner" role="alert">
      <strong>DRAFT.</strong> This review's Bottom Line section hasn't been filled in.
      Don't link to this page yet. Indexing is disabled until it's complete.
    </aside>
  )}

  <article class="review">
    <header class="review-hero">
      <div class="review-hero__inner">
        <a href="/reviews/" class="review-hero__crumb">← All reviews</a>
        <span class="review-hero__kicker">Review · {data.product.brand}</span>
        <h1 class="review-hero__title">{data.title}</h1>
        <p class="review-hero__deck">{data.description}</p>

        <dl class="review-hero__meta">
          {typeof rating === "number" && (
            <div class="review-hero__meta-row">
              <dt>Our take</dt>
              <dd>
                <span class="stars" aria-hidden="true">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <span class={i < Math.round(rating) ? "is-on" : ""}>★</span>
                  ))}
                </span>
                <span class="rating-num">{rating.toFixed(1)} / 5</span>
              </dd>
            </div>
          )}
          <div class="review-hero__meta-row">
            <dt>Last updated</dt>
            <dd><time datetime={isoUpdated}>{formattedUpdated}</time></dd>
          </div>
        </dl>
      </div>
    </header>

    <div class="review-stage">
      {heroImage && (
        <figure class="review-stage__media">
          <img src={heroImage} alt={data.product.name} loading="eager" decoding="async" />
        </figure>
      )}
    </div>

    <div class="review-layout">
      <div class="review-body">
        <AffiliateDisclosure siteName="MyWildlifeCam" variant="inline" />
        <div class="prose">
          <Content />
        </div>

        <aside class="bottomline-cta">
          <h3>Ready to look?</h3>
          <p>
            We use one cloaked link per product so we can swap retailers without
            breaking old pages. Click through goes to Amazon.
          </p>
          <CTA href={cloakedHref} variant="primary" size="lg" rel="sponsored noopener" target="_blank">
            See {data.product.name} on Amazon
          </CTA>
        </aside>
      </div>

      <aside class="review-sidebar" aria-label="Product details">
        <div class="review-sidebar__card review-sidebar__card--sticky">
          <span class="review-sidebar__brand">{data.product.brand}</span>
          <h2 class="review-sidebar__name">{data.product.name}</h2>

          <dl class="review-sidebar__specs">
            {typeof rating === "number" && (
              <>
                <dt>Our rating</dt>
                <dd>{rating.toFixed(1)} / 5</dd>
              </>
            )}
            {typeof data.product.price === "number" && (
              <>
                <dt>List price</dt>
                <dd>${data.product.price.toLocaleString()}</dd>
              </>
            )}
            {data.product.sku && (
              <>
                <dt>SKU</dt>
                <dd>{data.product.sku}</dd>
              </>
            )}
            <dt>Sourcing</dt>
            <dd>Spec-driven analysis</dd>
          </dl>

          <CTA href={cloakedHref} variant="primary" size="md" rel="sponsored noopener" target="_blank">
            Check current price
          </CTA>
        </div>
      </aside>
    </div>
  </article>
</MainLayout>

<style>
  .draft-banner {
    max-width: var(--container-max);
    margin: var(--space-6) auto;
    padding: 0 var(--space-6);
    background: var(--color-brass-soft);
    border-left: 3px solid var(--color-brass);
    color: var(--color-forest);
    font-size: var(--text-sm);
  }

  .review { background: var(--color-bg); }

  .review-hero {
    background: var(--color-paper-muted);
    padding: var(--space-12) var(--space-6) var(--space-10);
    border-bottom: 1px solid var(--color-border);
  }
  .review-hero__inner {
    max-width: var(--content-wide);
    margin: 0 auto;
  }
  .review-hero__crumb {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: var(--space-6);
  }
  .review-hero__crumb:hover { color: var(--color-brass); }
  .review-hero__kicker {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-brass);
    margin-bottom: var(--space-4);
  }
  .review-hero__title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: var(--tracking-display);
    color: var(--color-forest);
    margin: 0 0 var(--space-5);
    max-width: 24ch;
  }
  .review-hero__deck {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.125rem, 1.6vw, 1.375rem);
    line-height: var(--leading-snug);
    color: var(--color-muted);
    margin: 0 0 var(--space-8);
    max-width: 50ch;
  }
  .review-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-8);
    margin: 0;
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }
  .review-hero__meta-row { margin: 0; }
  .review-hero__meta dt {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-muted);
    font-weight: var(--weight-semibold);
    margin: 0 0 var(--space-1);
  }
  .review-hero__meta dd {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    color: var(--color-forest);
    margin: 0;
  }
  .stars { color: var(--color-sage); letter-spacing: 0.05em; margin-right: var(--space-2); }
  .stars .is-on { color: var(--color-brass); }
  .rating-num { font-weight: var(--weight-semibold); }

  /* Product hero photo */
  .review-stage {
    background: var(--color-bg);
    padding: var(--space-10) var(--space-6) 0;
  }
  .review-stage__media {
    max-width: var(--content-wide);
    margin: 0 auto;
    background: var(--color-paper-muted);
    border-radius: var(--radius-lg);
    overflow: hidden;
    padding: var(--space-10);
    display: grid;
    place-items: center;
  }
  .review-stage__media img {
    max-width: 100%;
    max-height: 480px;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  /* 2-col layout: body + sidebar */
  .review-layout {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6);
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: var(--space-12);
    align-items: flex-start;
  }

  .review-body { min-width: 0; }

  /* Prose */
  .prose {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-paper-ink);
  }
  .prose :global(p) { margin: 0 0 var(--space-5); }
  .prose :global(p:first-of-type) {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    color: var(--color-forest);
  }
  .prose :global(h2) {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    color: var(--color-forest);
    margin: var(--space-10) 0 var(--space-4);
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border);
  }
  .prose :global(h2):first-child { border-top: 0; padding-top: 0; margin-top: 0; }
  .prose :global(h3) {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--color-forest);
    margin: var(--space-8) 0 var(--space-3);
  }
  .prose :global(ul), .prose :global(ol) {
    padding-left: var(--space-6);
    margin: 0 0 var(--space-5);
  }
  .prose :global(li) { margin-bottom: var(--space-2); }
  .prose :global(strong) { color: var(--color-forest); font-weight: var(--weight-semibold); }
  .prose :global(table) { margin: var(--space-6) 0; }
  .prose :global(blockquote) {
    margin: var(--space-6) 0;
    padding: var(--space-4) var(--space-6);
    background: var(--color-surface-alt);
    border-left: 3px solid var(--color-brass);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--color-forest);
  }
  .prose :global(a) {
    color: var(--color-forest);
    font-weight: var(--weight-medium);
    text-decoration-color: var(--color-brass);
  }
  .prose :global(a:hover) { color: var(--color-brass); }

  /* Bottom-line CTA inside body */
  .bottomline-cta {
    margin-top: var(--space-12);
    padding: var(--space-8);
    background: var(--color-forest);
    color: var(--color-paper);
    border-radius: var(--radius-lg);
    text-align: center;
  }
  .bottomline-cta h3 {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    color: var(--color-paper);
    margin: 0 0 var(--space-3);
  }
  .bottomline-cta p {
    font-size: var(--text-sm);
    color: var(--color-paper);
    opacity: 0.85;
    margin: 0 0 var(--space-6);
    max-width: 44ch;
    margin-left: auto;
    margin-right: auto;
  }

  /* Sidebar */
  .review-sidebar {
    position: relative;
  }
  .review-sidebar__card {
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }
  .review-sidebar__card--sticky {
    position: sticky;
    top: calc(var(--header-height) + var(--space-6));
  }
  .review-sidebar__brand {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-brass);
    font-weight: var(--weight-semibold);
  }
  .review-sidebar__name {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--color-forest);
    margin: var(--space-2) 0 var(--space-5);
    line-height: var(--leading-tight);
  }
  .review-sidebar__specs {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-2) var(--space-4);
    margin: 0 0 var(--space-6);
    padding: var(--space-5) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-sm);
  }
  .review-sidebar__specs dt {
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-size: var(--text-xs);
    color: var(--color-muted);
    font-weight: var(--weight-semibold);
  }
  .review-sidebar__specs dd {
    margin: 0;
    color: var(--color-paper-ink);
    font-weight: var(--weight-medium);
  }

  @media (max-width: 980px) {
    .review-layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .review-sidebar__card--sticky { position: static; }
  }
  @media (max-width: 760px) {
    .review-hero { padding: var(--space-10) var(--space-4) var(--space-8); }
    .review-stage { padding: var(--space-8) var(--space-4) 0; }
    .review-stage__media { padding: var(--space-6); }
    .review-layout { padding: var(--space-10) var(--space-4); }
    .bottomline-cta { padding: var(--space-6); }
  }
</style>
