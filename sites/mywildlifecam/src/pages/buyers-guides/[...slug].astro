---
import { getCollection, type CollectionEntry } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import GuideArticle from "@affkit/shared-ui/GuideArticle.astro";
import { productSchema } from "@affkit/shared-utils";

export async function getStaticPaths() {
  const entries = await getCollection("buyers-guides");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"buyers-guides">;
}

const { entry } = Astro.props;
const { data } = entry;

/* isDraft is computed here too (deterministic from frontmatter) so MainLayout
   can flip robots to noindex. GuideArticle computes the same value for the
   in-article draft banner + BottomLine gate. */
const BOTTOMLINE_PLACEHOLDER = "_The Bottom Line is being written._";
const isDraft = !data.bottomLine
  || !data.bottomLine.verdict
  || data.bottomLine.verdict.trim() === ""
  || data.bottomLine.verdict.includes(BOTTOMLINE_PLACEHOLDER);
const robotsContent = isDraft ? "noindex, nofollow" : "index, follow";

const productLds = data.products.map((p) =>
  productSchema({
    name: p.name,
    brand: p.brand,
    sku: p.name,
    image: (p as any).image ?? "",
    description: data.description,
    offerUrl: p.affiliateUrl,
  })
);
---
<MainLayout
  title={data.title}
  description={data.description}
  robotsContent={robotsContent}
  ogType="article"
  bgTheme={data.bgTheme}
>
  {productLds.map((ld) => (
    <script type="application/ld+json" set:html={JSON.stringify(ld)} />
  ))}

  <GuideArticle
    entry={entry}
    siteName="MyWildlifeCam"
    kicker={data.rubric ?? "Trail Cameras · Buying Guide"}
    editorialTeamName="The MyWildlifeCam editorial team"
    bestForFact="Wildlife / trail monitoring"
  />
</MainLayout>
