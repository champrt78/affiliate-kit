---
import { getCollection, type CollectionEntry } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import CTA from "@affkit/shared-ui/CTA.astro";
import ProductCard from "@affkit/shared-ui/ProductCard.astro";
import AffiliateDisclosure from "@affkit/shared-ui/AffiliateDisclosure.astro";
import { cloakedLink } from "@affkit/shared-utils";
import { productSchema } from "@affkit/shared-utils";

export async function getStaticPaths() {
  const entries = await getCollection("buyers-guides");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"buyers-guides">;
}

const { entry } = Astro.props;
const { data, body } = entry;
const { Content } = await entry.render();

const DRAFT_MARKER = "_The Bottom Line is being written._";
const isDraft = typeof body === "string" && body.includes(DRAFT_MARKER);

const productLds = data.products.map((p) =>
  productSchema({
    name: p.name,
    brand: p.brand,
    sku: p.name,
    image: (p as any).image ?? "",
    description: data.description,
    offerUrl: p.affiliateUrl,
  })
);

const topPickHref = data.products[0]?.affiliateUrl
  ? cloakedLink({ slug: (data.products[0] as any).cloakedSlug ?? entry.slug })
  : cloakedLink({ slug: entry.slug });

const robotsContent = isDraft ? "noindex, nofollow" : "index, follow";

const heroImage = data.images?.hero
  ?? (data.products?.[0] as any)?.image
  ?? "";

const formattedUpdated = data.lastUpdated instanceof Date
  ? data.lastUpdated.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })
  : String(data.lastUpdated);
const isoUpdated = data.lastUpdated instanceof Date
  ? data.lastUpdated.toISOString()
  : String(data.lastUpdated);

const productCount = data.products?.length ?? 0;
---
<MainLayout
  title={data.title}
  description={data.description}
  robotsContent={robotsContent}
  ogType="article"
  ogImage={heroImage || undefined}
>
  {productLds.map((ld) => (
    <script type="application/ld+json" set:html={JSON.stringify(ld)} />
  ))}

  {isDraft && (
    <aside class="draft-banner" role="alert">
      <strong>DRAFT.</strong> This guide's Bottom Line section hasn't been filled in.
      Don't link to this page yet. Indexing is disabled until it's complete.
    </aside>
  )}

  <article class="guide">
    <header class="guide-hero">
      <div class="guide-hero__inner">
        <a href="/buyers-guides/" class="guide-hero__crumb">← All buying guides</a>
        <span class="guide-hero__kicker">Buying guide · {productCount} pick{productCount === 1 ? "" : "s"}</span>
        <h1 class="guide-hero__title">{data.title}</h1>
        <p class="guide-hero__deck">{data.description}</p>

        <div class="byline" aria-label="Article byline">
          <span class="byline__avatar" aria-hidden="true">M</span>
          <div class="byline__who">
            <span class="byline__name">The MyWildlifeCam editorial team</span>
            <span class="byline__cred">{productCount} pick{productCount === 1 ? "" : "s"} compared · spec analysis &amp; use-case framing, verified against current manufacturer listings and Amazon reports</span>
          </div>
          <div class="byline__when">
            <span class="byline__label">Last updated</span>
            <time class="byline__date" datetime={isoUpdated}>{formattedUpdated}</time>
          </div>
        </div>
      </div>
    </header>

    <section class="picks">
      <div class="picks__inner">
        <header class="picks__head">
          <span class="picks__kicker">At a glance</span>
          <h2>The picks, ranked</h2>
        </header>

        <ol class="picks__list">
          {data.products.map((product: any, idx: number) => (
            <li>
              <ProductCard
                rank={idx + 1}
                name={product.name}
                brand={product.brand}
                image={product.image}
                tagline={product.tagline}
                bestFor={product.bestFor}
                priceFrom={product.priceFrom}
                affiliateUrl={product.cloakedSlug
                  ? cloakedLink({ slug: product.cloakedSlug })
                  : product.affiliateUrl}
              />
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="guide-body">
      <div class="guide-body__inner">
        <AffiliateDisclosure siteName="MyWildlifeCam" variant="inline" />
        <div class="prose">
          <Content />
        </div>

        <aside class="bottomline-cta">
          <h3>Still on the fence?</h3>
          <p>
            Pick number one is the default for most people reading this. The full
            comparison up top is for the cases where number one isn't quite right.
          </p>
          <CTA href={topPickHref} variant="primary" size="lg" rel="sponsored noopener" target="_blank">
            See the top pick on Amazon
          </CTA>
        </aside>
      </div>
    </section>
  </article>
</MainLayout>

<style>
  .draft-banner {
    max-width: var(--container-max);
    margin: var(--space-6) auto;
    padding: var(--space-4) var(--space-6);
    background: var(--color-brass-soft);
    border-left: 3px solid var(--color-brass);
    color: var(--color-forest);
    font-size: var(--text-sm);
  }

  .guide { background: var(--color-bg); }

  /* Hero */
  .guide-hero {
    background: var(--color-paper-muted);
    padding: var(--space-12) var(--space-6) var(--space-10);
    border-bottom: 1px solid var(--color-border);
  }
  .guide-hero__inner {
    max-width: var(--content-wide);
    margin: 0 auto;
  }
  .guide-hero__crumb {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: var(--space-6);
  }
  .guide-hero__crumb:hover { color: var(--color-brass); }
  .guide-hero__kicker {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-brass);
    margin-bottom: var(--space-4);
  }
  .guide-hero__title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: var(--tracking-display);
    color: var(--color-forest);
    margin: 0 0 var(--space-5);
    max-width: 24ch;
  }
  .guide-hero__deck {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.125rem, 1.6vw, 1.375rem);
    line-height: var(--leading-snug);
    color: var(--color-muted);
    margin: 0 0 var(--space-8);
    max-width: 50ch;
  }
  /* Named byline strip (steal from Wirecutter / Strategist / AAB) */
  .byline {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) 0;
    margin: 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .byline__avatar {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-full);
    background: var(--color-forest);
    color: var(--color-paper);
    display: grid;
    place-items: center;
    font-family: var(--font-serif);
    font-weight: var(--weight-semibold);
    font-size: var(--text-xl);
    line-height: 1;
  }
  .byline__who { flex: 1; display: flex; flex-direction: column; gap: 2px; line-height: 1.4; }
  .byline__name {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-forest);
  }
  .byline__cred {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-muted);
    max-width: 52ch;
  }
  .byline__when {
    margin-left: auto;
    text-align: right;
    flex-shrink: 0;
  }
  .byline__label {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-brass);
    margin-bottom: 2px;
  }
  .byline__date {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    color: var(--color-forest);
  }
  @media (max-width: 600px) {
    .byline { flex-wrap: wrap; }
    .byline__when { margin-left: 0; text-align: left; padding-left: calc(44px + var(--space-4)); }
  }

  /* Picks list */
  .picks {
    background: var(--color-bg);
    padding: var(--space-12) var(--space-6);
  }
  .picks__inner {
    max-width: var(--content-wide);
    margin: 0 auto;
  }
  .picks__head { margin-bottom: var(--space-8); }
  .picks__kicker {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-brass);
    margin-bottom: var(--space-2);
  }
  .picks__head h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    color: var(--color-forest);
    margin: 0;
  }
  .picks__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .picks__list li { margin: 0; }

  /* Body prose */
  .guide-body {
    background: var(--color-paper-muted);
    padding: var(--space-12) var(--space-6) var(--space-16);
    border-top: 1px solid var(--color-border);
  }
  .guide-body__inner {
    max-width: var(--content-max);
    margin: 0 auto;
  }
  .prose {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-paper-ink);
  }
  .prose :global(p) { margin: 0 0 var(--space-5); }
  .prose :global(p:first-of-type) {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    color: var(--color-forest);
  }
  .prose :global(h2) {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    color: var(--color-forest);
    margin: var(--space-10) 0 var(--space-4);
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border);
  }
  /* Bottom Line callout — first h2 in prose becomes eyebrow, first blockquote becomes verdict box */
  .prose :global(h2):first-child {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-brass);
    border-top: 0;
    padding-top: 0;
    margin: 0 0 var(--space-3);
  }
  .prose :global(h2):first-child + blockquote {
    margin: 0 0 var(--space-10);
    padding: var(--space-6) var(--space-8);
    background: var(--color-cream, var(--color-paper-muted));
    border-left: 3px solid var(--color-brass);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-family: var(--font-serif);
    font-style: normal;
    font-size: var(--text-xl);
    font-weight: var(--weight-medium);
    color: var(--color-forest);
    line-height: 1.45;
  }
  .prose :global(h2):first-child + blockquote :global(p) { margin: 0; }
  .prose :global(h2):first-child + blockquote :global(p + p) {
    margin-top: var(--space-4);
    font-size: var(--text-base);
    font-weight: var(--weight-regular);
    color: var(--color-paper-ink);
    line-height: var(--leading-normal);
    font-family: var(--font-sans);
  }
  .prose :global(h3) {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--color-forest);
    margin: var(--space-8) 0 var(--space-3);
  }
  .prose :global(ul), .prose :global(ol) {
    padding-left: var(--space-6);
    margin: 0 0 var(--space-5);
  }
  .prose :global(li) { margin-bottom: var(--space-2); }
  .prose :global(strong) { color: var(--color-forest); font-weight: var(--weight-semibold); }
  .prose :global(table) { margin: var(--space-6) 0; }
  .prose :global(blockquote) {
    margin: var(--space-6) 0;
    padding: var(--space-4) var(--space-6);
    background: var(--color-surface-alt);
    border-left: 3px solid var(--color-brass);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--color-forest);
  }
  .prose :global(a) {
    color: var(--color-forest);
    font-weight: var(--weight-medium);
    text-decoration-color: var(--color-brass);
  }
  .prose :global(a:hover) { color: var(--color-brass); }

  .bottomline-cta {
    margin-top: var(--space-12);
    padding: var(--space-8);
    background: var(--color-forest);
    color: var(--color-paper);
    border-radius: var(--radius-lg);
    text-align: center;
  }
  .bottomline-cta h3 {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    color: var(--color-paper);
    margin: 0 0 var(--space-3);
  }
  .bottomline-cta p {
    font-size: var(--text-sm);
    color: var(--color-paper);
    opacity: 0.85;
    margin: 0 0 var(--space-6);
    max-width: 44ch;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 760px) {
    .guide-hero { padding: var(--space-10) var(--space-4) var(--space-8); }
    .picks { padding: var(--space-8) var(--space-4); }
    .guide-body { padding: var(--space-10) var(--space-4) var(--space-12); }
    .bottomline-cta { padding: var(--space-6); }
  }
</style>
