---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import BuyersGuideCard from "@affkit/shared-ui/BuyersGuideCard.astro";

const entries = await getCollection("buyers-guides");
const sorted = entries.sort((a, b) => {
  const aTime = a.data.pubDate instanceof Date ? a.data.pubDate.getTime() : new Date(a.data.pubDate).getTime();
  const bTime = b.data.pubDate instanceof Date ? b.data.pubDate.getTime() : new Date(b.data.pubDate).getTime();
  return bTime - aTime;
});
---
<MainLayout
  title="Buying guides"
  description="Comparative roundups of trail cameras for specific use cases: backyard, property, cellular, image quality, budget."
>
  <header class="page-header">
    <div class="page-header__inner">
      <span class="page-header__kicker">Buying guides</span>
      <h1 class="page-header__title">Comparative roundups, by use case.</h1>
      <p class="page-header__lede">
        Trail cameras line up differently depending on the job. These guides
        compare a handful of cameras for one well-defined use case, then name
        the pick we think most readers should default to.
      </p>
    </div>
  </header>

  <section class="grid-section">
    <div class="grid-section__inner">
      {sorted.length === 0 ? (
        <p class="empty">No buying guides yet. New ones land every quarter.</p>
      ) : (
        <div class="grid">
          {sorted.map((entry) => <BuyersGuideCard entry={entry} />)}
        </div>
      )}
    </div>
  </section>
</MainLayout>

<style>
  .page-header {
    background: var(--color-paper-muted);
    padding: var(--space-10) var(--space-6) var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }
  .page-header__inner {
    max-width: 920px;
    margin: 0 auto;
  }
  .page-header__kicker {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brass);
    margin-bottom: var(--space-3);
  }
  .page-header__kicker::before {
    content: "";
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--color-brass);
    vertical-align: middle;
    margin-right: 10px;
    transform: translateY(-2px);
  }
  .page-header__title {
    font-family: var(--font-serif);
    /* Section-heading size — not a hero. ~28-40px range. */
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
    line-height: 1.1;
    color: var(--color-forest);
    letter-spacing: var(--tracking-display);
    margin: 0 0 var(--space-3);
    font-weight: var(--weight-semibold);
    font-variation-settings: "opsz" 60;
    text-transform: capitalize;
  }
  .page-header__lede {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1rem, 1.3vw, 1.125rem);
    line-height: 1.5;
    color: var(--color-muted);
    margin: 0;
    max-width: 56ch;
    font-variation-settings: "opsz" 30;
  }

  .grid-section {
    padding: var(--space-12) var(--space-6) var(--space-20);
    background: var(--color-bg);
  }
  .grid-section__inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 420px));
    justify-content: center;
    gap: var(--space-6);
  }
  .empty {
    color: var(--color-muted);
    font-family: var(--font-serif);
    font-style: italic;
  }

  @media (max-width: 760px) {
    .page-header { padding: var(--space-12) var(--space-4) var(--space-10); }
    .grid-section { padding: var(--space-10) var(--space-4) var(--space-16); }
  }
</style>
