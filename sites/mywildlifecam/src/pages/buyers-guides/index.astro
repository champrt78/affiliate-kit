---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import BuyersGuideCard from "@affkit/shared-ui/BuyersGuideCard.astro";

const entries = await getCollection("buyers-guides");
const sorted = entries.sort((a, b) => {
  const aTime = a.data.pubDate instanceof Date ? a.data.pubDate.getTime() : new Date(a.data.pubDate).getTime();
  const bTime = b.data.pubDate instanceof Date ? b.data.pubDate.getTime() : new Date(b.data.pubDate).getTime();
  return bTime - aTime;
});
---
<MainLayout
  title="Buying guides"
  description="Comparative roundups of trail cameras for specific use cases — backyard, property, cellular, image quality, budget."
>
  <header class="page-header">
    <div class="page-header__inner">
      <span class="page-header__kicker">Buying guides</span>
      <h1 class="page-header__title">Comparative roundups, by use case.</h1>
      <p class="page-header__lede">
        Trail cameras line up differently depending on the job. These guides
        compare a handful of cameras for one well-defined use case, then name
        the pick we think most readers should default to.
      </p>
    </div>
  </header>

  <section class="grid-section">
    <div class="grid-section__inner">
      {sorted.length === 0 ? (
        <p class="empty">No buying guides yet. New ones land every quarter.</p>
      ) : (
        <div class="grid">
          {sorted.map((entry) => <BuyersGuideCard entry={entry} />)}
        </div>
      )}
    </div>
  </section>
</MainLayout>

<style>
  .page-header {
    background: var(--color-paper-muted);
    padding: var(--space-16) var(--space-6) var(--space-12);
    border-bottom: 1px solid var(--color-border);
  }
  .page-header__inner {
    max-width: var(--content-wide);
    margin: 0 auto;
  }
  .page-header__kicker {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-brass);
    margin-bottom: var(--space-3);
  }
  .page-header__title {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    color: var(--color-forest);
    letter-spacing: var(--tracking-display);
    margin: 0 0 var(--space-5);
  }
  .page-header__lede {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.125rem, 1.6vw, 1.375rem);
    line-height: var(--leading-snug);
    color: var(--color-muted);
    margin: 0;
    max-width: 52ch;
  }

  .grid-section {
    padding: var(--space-12) var(--space-6) var(--space-20);
    background: var(--color-bg);
  }
  .grid-section__inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
  }
  .empty {
    color: var(--color-muted);
    font-family: var(--font-serif);
    font-style: italic;
  }

  @media (max-width: 760px) {
    .page-header { padding: var(--space-12) var(--space-4) var(--space-10); }
    .grid-section { padding: var(--space-10) var(--space-4) var(--space-16); }
  }
</style>
