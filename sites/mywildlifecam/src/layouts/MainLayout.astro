---
import BaseLayout from "@affkit/shared-ui/BaseLayout.astro";
import AffiliateDisclosure from "@affkit/shared-ui/AffiliateDisclosure.astro";

/* bgTheme — photo-gutter background system (locked 2026-05-20).
   Each theme paints a forest photograph in the left/right "table" outside
   the centered cream content card. Below the container width the photo
   gracefully retreats and the cream takes the full viewport. */
type BgTheme = "dawn" | "canopy" | "moss" | "twilight" | "pine" | "solid";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  robotsContent?: string;
  ogType?: string;
  ogImage?: string;
  bgTheme?: BgTheme;
}

const { title, description, canonical, robotsContent, ogType, ogImage, bgTheme = "dawn" } = Astro.props;
const siteName = "MyWildlifeCam";
const navItems = [
  { href: "/", label: "Home" },
  { href: "/buyers-guides/", label: "Guides" },
  { href: "/reviews/", label: "Reviews" },
  { href: "/about/", label: "About" },
];
const currentPath = Astro.url.pathname;
---
<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  siteName={siteName}
  robotsContent={robotsContent}
  ogType={ogType}
  ogImage={ogImage}
>
  <a href="#main" class="skip-link">Skip to content</a>

  <header class="site-header" data-site-header>
    <div class="site-header__inner">
      <a href="/" class="brand">
        <span class="brand__mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 18c2-1 4-1 6 0s4 1 6 0 4-1 6 0" />
            <path d="M3 13c2-1 4-1 6 0s4 1 6 0 4-1 6 0" />
            <path d="M12 4c1.5 2 3.5 4 3.5 6.5S13.5 14 12 14s-3.5-1-3.5-3.5S10.5 6 12 4z" />
          </svg>
        </span>
        <span class="brand__type">
          <span class="brand__name">MyWildlifeCam</span>
          <span class="brand__tag">Trail cameras for the backyard</span>
        </span>
      </a>

      <nav class="site-nav" aria-label="Primary">
        {navItems.map(item => (
          <a
            href={item.href}
            class={currentPath === item.href ? "site-nav__link is-active" : "site-nav__link"}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <button class="nav-toggle" aria-expanded="false" aria-controls="mobile-nav" aria-label="Open menu" data-nav-toggle>
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
      </button>
    </div>

    <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile" data-mobile-nav>
      {navItems.map(item => (
        <a href={item.href} class="mobile-nav__link">{item.label}</a>
      ))}
    </nav>
  </header>

  <main id="main" tabindex="-1" class={`bg-theme bg-theme--${bgTheme}`}>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="site-footer__inner">
      <div class="site-footer__brand">
        <span class="site-footer__name">MyWildlifeCam</span>
        <p class="site-footer__blurb">
          A buyer's-eye look at trail cameras for backyards, properties, and curious neighbors.
          We compare specs, frame fit, and link out to where you can actually buy them.
        </p>
      </div>

      <div class="site-footer__col">
        <h4>Explore</h4>
        <a href="/buyers-guides/">Buying guides</a>
        <a href="/reviews/">Single-product reviews</a>
        <a href="/how-we-evaluate/">How we evaluate</a>
        <a href="/about/">About this site</a>
      </div>

      <div class="site-footer__col">
        <h4>Fine print</h4>
        <a href="/disclosure/">Affiliate disclosure</a>
        <a href="/privacy/">Privacy</a>
        <a href="/contact/">Contact</a>
      </div>
    </div>

    <div class="site-footer__base">
      <AffiliateDisclosure siteName={siteName} variant="footer" />
      <p class="site-footer__copy">© {new Date().getFullYear()} {siteName}. All rights reserved.</p>
    </div>
  </footer>
</BaseLayout>

<script is:inline>
  (function () {
    const header = document.querySelector("[data-site-header]");
    const toggle = document.querySelector("[data-nav-toggle]");
    const mobileNav = document.querySelector("[data-mobile-nav]");

    if (header) {
      let ticking = false;
      const onScroll = () => {
        if (window.scrollY > 12) {
          header.classList.add("is-scrolled");
        } else {
          header.classList.remove("is-scrolled");
        }
        ticking = false;
      };
      window.addEventListener("scroll", () => {
        if (!ticking) {
          window.requestAnimationFrame(onScroll);
          ticking = true;
        }
      }, { passive: true });
      onScroll();
    }

    if (toggle && mobileNav) {
      toggle.addEventListener("click", () => {
        const expanded = toggle.getAttribute("aria-expanded") === "true";
        toggle.setAttribute("aria-expanded", String(!expanded));
        toggle.setAttribute("aria-label", expanded ? "Open menu" : "Close menu");
        mobileNav.classList.toggle("is-open", !expanded);
        document.body.classList.toggle("nav-open", !expanded);
      });
    }
  })();
</script>

<style>
  /* Skip link */
  .skip-link {
    position: absolute;
    left: var(--space-4);
    top: -3rem;
    background: var(--color-forest);
    color: var(--color-paper);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    text-decoration: none;
    z-index: 100;
    transition: top var(--duration-fast) var(--ease-out);
  }
  .skip-link:focus { top: var(--space-4); }

  /* Sticky header */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(245, 240, 230, 0.85);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid transparent;
    transition: background var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out);
  }
  .site-header.is-scrolled {
    background: rgba(245, 240, 230, 0.94);
    border-bottom-color: var(--color-sage-light);
    box-shadow: var(--shadow-sm);
  }
  /* Dark-mode header overrides removed — see tokens.css comment. */

  .site-header__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-6);
    height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  /* Brand mark + type */
  .brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--color-forest);
  }
  .brand:hover { color: var(--color-brass); }
  .brand__mark {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-full);
    background: var(--color-forest);
    color: var(--color-paper);
    flex-shrink: 0;
  }
  .brand__type {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .brand__name {
    font-family: var(--font-serif);
    font-weight: var(--weight-semibold);
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-display);
  }
  .brand__tag {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-muted);
    margin-top: 3px;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    font-weight: var(--weight-medium);
  }

  /* Desktop nav */
  .site-nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }
  .site-nav__link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-paper-ink);
    text-decoration: none;
    letter-spacing: 0.01em;
    padding: var(--space-2) 0;
    position: relative;
  }
  .site-nav__link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: var(--color-brass);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-base) var(--ease-out);
  }
  .site-nav__link:hover { color: var(--color-forest); }
  .site-nav__link:hover::after { transform: scaleX(1); }
  .site-nav__link.is-active { color: var(--color-forest); }
  .site-nav__link.is-active::after { transform: scaleX(1); }

  /* Mobile toggle */
  .nav-toggle {
    display: none;
    background: none;
    border: 0;
    padding: var(--space-2);
    cursor: pointer;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
  }
  .nav-toggle__bar {
    width: 22px;
    height: 2px;
    background: var(--color-forest);
    border-radius: 1px;
    transition: transform var(--duration-base) var(--ease-out),
                opacity var(--duration-base) var(--ease-out);
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle__bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle__bar:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle__bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile drawer */
  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: var(--space-2) var(--space-6) var(--space-6);
    background: var(--color-paper);
    border-top: 1px solid var(--color-sage-light);
  }
  .mobile-nav.is-open { display: flex; }
  .mobile-nav__link {
    padding: var(--space-4) 0;
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: var(--weight-medium);
    color: var(--color-paper-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-sage-light);
  }
  .mobile-nav__link:last-child { border-bottom: 0; }

  @media (max-width: 760px) {
    .site-nav { display: none; }
    .nav-toggle { display: flex; }
    .brand__tag { display: none; }
    .site-header__inner { padding: 0 var(--space-4); gap: var(--space-3); }
  }

  /* Main content — photo-gutter background system.
     Each theme paints a forest photo on `main`, then masks the middle
     container-width stripe with cream so the content card sits on top
     of the photo only in the gutters. Below container width the photo
     retreats and cream takes the full viewport. */
  main {
    min-height: 60vh;
    position: relative;
    isolation: isolate;
    background-color: var(--color-forest);
    background-size: cover;
    background-position: center;
    background-attachment: scroll;
  }
  /* Cream center stripe — masks the photo across the widest content
     container used on MWC (guide article = 1280px). Reviews live inside
     this stripe at 920px max-width; the extra cream on either side just
     reads as more breathing room. Sits behind direct slot children via z-index. */
  main.bg-theme::before {
    content: "";
    position: absolute;
    inset: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(100%, 1280px);
    background: var(--color-paper);
    z-index: 0;
    pointer-events: none;
  }
  main.bg-theme > * {
    position: relative;
    z-index: 1;
  }
  /* Below the cream-stripe width the photo can't fit a gutter at all —
     cream takes the full viewport. */
  @media (max-width: 1280px) {
    main.bg-theme::before { width: 100%; }
  }

  /* Solid fallback — forest gutters, no photo (M1 baseline) */
  main.bg-theme--solid {
    background-image: none;
  }

  /* Dawn — misty woods at dawn (N1, default). Soft, low-contrast scene
     that fades to its own ambient grey. */
  main.bg-theme--dawn {
    background-image: url("https://images.pexels.com/photos/15222306/pexels-photo-15222306.jpeg?auto=compress&cs=tinysrgb&w=1600&h=1200&fit=crop");
  }

  /* Canopy — forest canopy looking up (N2). Open / sky feel. */
  main.bg-theme--canopy {
    background-image: url("https://images.pexels.com/photos/12067501/pexels-photo-12067501.jpeg?auto=compress&cs=tinysrgb&w=1600&h=1200&fit=crop");
  }

  /* Moss — forest floor / moss (N4). Grounded, earthy. */
  main.bg-theme--moss {
    background-image: url("https://images.pexels.com/photos/12623932/pexels-photo-12623932.jpeg?auto=compress&cs=tinysrgb&w=1600&h=1200&fit=crop");
  }

  /* Twilight — tree silhouette at twilight (N5). Night / covert / stealth. */
  main.bg-theme--twilight {
    background-image: url("https://images.pexels.com/photos/5688636/pexels-photo-5688636.jpeg?auto=compress&cs=tinysrgb&w=1600&h=1200&fit=crop");
  }

  /* Pine — pine dawn with fade-to-cream vignette (N6). The gradient
     itself paints the cream center across a 1280px-wide stripe (matches
     the guide article width), so the ::before mask is suppressed. */
  main.bg-theme--pine {
    background-image:
      linear-gradient(
        to right,
        rgba(31, 61, 47, 0) 0%,
        rgba(31, 61, 47, 0) calc(50% - 650px),
        rgba(250, 247, 239, 0.85) calc(50% - 640px),
        var(--color-paper) calc(50% - 630px),
        var(--color-paper) calc(50% + 630px),
        rgba(250, 247, 239, 0.85) calc(50% + 640px),
        rgba(31, 61, 47, 0) calc(50% + 650px),
        rgba(31, 61, 47, 0) 100%
      ),
      url("https://images.pexels.com/photos/29154771/pexels-photo-29154771.jpeg?auto=compress&cs=tinysrgb&w=1600&h=1200&fit=crop");
    background-size: cover, cover;
    background-position: center, center;
  }
  main.bg-theme--pine::before { display: none; }

  /* Footer */
  .site-footer {
    margin-top: var(--space-24);
    background: var(--color-forest);
    color: var(--color-paper);
  }
  .site-footer__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-16) var(--space-6) var(--space-10);
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-12);
  }
  .site-footer__brand .site-footer__name {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: var(--weight-semibold);
    color: var(--color-paper);
    letter-spacing: var(--tracking-display);
    display: block;
    margin-bottom: var(--space-3);
  }
  .site-footer__blurb {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-paper);
    opacity: 0.75;
    max-width: 32rem;
    margin: 0;
  }
  .site-footer__col h4 {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-brass-soft);
    margin-bottom: var(--space-4);
  }
  .site-footer__col a {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-paper);
    text-decoration: none;
    padding: var(--space-1) 0;
    opacity: 0.85;
    transition: opacity var(--duration-fast) var(--ease-out),
                color var(--duration-fast) var(--ease-out);
  }
  .site-footer__col a:hover {
    opacity: 1;
    color: var(--color-brass-soft);
  }
  .site-footer__base {
    border-top: 1px solid rgba(245, 240, 230, 0.15);
    padding: var(--space-6);
    max-width: var(--container-max);
    margin: 0 auto;
  }
  .site-footer__copy {
    text-align: center;
    font-size: var(--text-xs);
    color: var(--color-paper);
    opacity: 0.6;
    margin: var(--space-4) 0 0;
    letter-spacing: var(--tracking-wide);
  }

  @media (max-width: 760px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      padding: var(--space-12) var(--space-4) var(--space-8);
    }
  }

  /* Lock scroll when mobile nav open */
  :global(body.nav-open) { overflow: hidden; }
</style>
