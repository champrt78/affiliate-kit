---
import SiteShell from "@affkit/shared-ui/SiteShell.astro";
import AffiliateDisclosure from "@affkit/shared-ui/AffiliateDisclosure.astro";
// MWC's palette is the shared-styles default; this file only sets the
// SiteShell chrome seams (forest footer) so the migrated shell keeps MWC's
// forest identity. See the file header for what it does / doesn't override.
import "../styles/site-tokens.css";

/* bgTheme — per-page forest gutter theme. Defaults to "dawn" when omitted.
   Six options locked 2026-05-23 from the N-photo-gutters playground:
     dawn       — misty woods (default, friendly broad-audience pages)
     canopy     — forest canopy up (open/sky, cellular cams)
     moss       — forest floor (grounded, entry-level)
     twilight   — tree silhouettes (covert/stealth/no-glow content)
     pine       — pine dawn fade (quiet, methodology, about pages)
     solid      — no photo, forest green (legal/admin pages)
   The string is resolved here and handed to SiteShell as `pageBg`; the shell
   injects it via its documented head-slot inline-style cascade workaround so
   the gutter photo shows beside the floating panel. */
type BgTheme = "dawn" | "canopy" | "moss" | "twilight" | "pine" | "solid";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  robotsContent?: string;
  ogType?: string;
  ogImage?: string;
  bgTheme?: BgTheme;
}

const { title, description, canonical, robotsContent, ogType, ogImage, bgTheme = "dawn" } = Astro.props;
const siteName = "MyWildlifeCam";

/* Resolve bgTheme → CSS background value. Pexels CDN hot-links (per the
   image policy in CLAUDE.md: scene/atmosphere only, never product hero).
   The forest-green fallback color is passed separately to SiteShell as
   `gutterColor` so the gutters stay dark while the photo loads. The CSS
   `background` shorthand can't carry a bare color as its own layer, so the
   color is NOT in these strings (see SiteShell's cascade note). */
const themeBackgrounds: Record<typeof bgTheme, string> = {
  dawn: 'url("https://images.pexels.com/photos/15222306/pexels-photo-15222306.jpeg?auto=compress&cs=tinysrgb&w=1600") center/cover no-repeat fixed',
  canopy: 'url("https://images.pexels.com/photos/12067501/pexels-photo-12067501.jpeg?auto=compress&cs=tinysrgb&w=1600") center/cover no-repeat fixed',
  moss: 'url("https://images.pexels.com/photos/12623932/pexels-photo-12623932.jpeg?auto=compress&cs=tinysrgb&w=1600") center/cover no-repeat fixed',
  twilight: 'url("https://images.pexels.com/photos/5688636/pexels-photo-5688636.jpeg?auto=compress&cs=tinysrgb&w=1600") center/cover no-repeat fixed',
  pine: 'url("https://images.pexels.com/photos/29154771/pexels-photo-29154771.jpeg?auto=compress&cs=tinysrgb&w=1600") center/cover no-repeat fixed',
  solid: "none",
};
const pageBg = themeBackgrounds[bgTheme];

const navItems = [
  { href: "/", label: "Home" },
  { href: "/buyers-guides/", label: "Guides" },
  { href: "/reviews/", label: "Reviews" },
  { href: "/about/", label: "About" },
];

const footerBlurb =
  "A buyer's-eye look at trail cameras for backyards, properties, and curious neighbors. We compare specs, frame fit, and link out to where you can actually buy them.";

const footerColumns = [
  {
    heading: "Explore",
    links: [
      { href: "/buyers-guides/", label: "Buying guides" },
      { href: "/reviews/", label: "Single-product reviews" },
      { href: "/how-we-evaluate/", label: "How we evaluate" },
      { href: "/about/", label: "About this site" },
    ],
  },
  {
    heading: "Fine print",
    links: [
      { href: "/disclosure/", label: "Affiliate disclosure" },
      { href: "/privacy/", label: "Privacy" },
      { href: "/contact/", label: "Contact" },
    ],
  },
];

// Elevated-nature register — Fraunces + Inter Tight (BaseLayout's default).
const fontsHref = "https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Inter+Tight:wght@400;500;600;700&display=swap";
---
<SiteShell
  title={title}
  description={description}
  canonical={canonical}
  siteName={siteName}
  robotsContent={robotsContent}
  ogType={ogType}
  ogImage={ogImage}
  themeColor="#1F3D2F"
  fontsHref={fontsHref}
  navItems={navItems}
  footerColumns={footerColumns}
  footerBlurb={footerBlurb}
  pageBg={pageBg}
  gutterColor="#1F3D2F"
>
  {/* Brand markup is authored HERE so MWC's scoped .brand* CSS (below) matches
      it — Astro scopes slot styles to the authoring component, not SiteShell.
      Keeps MWC's SVG leaf-mark + two-line wordmark. */}
  <a href="/" class="brand" slot="brand">
    <span class="brand__mark" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 18c2-1 4-1 6 0s4 1 6 0 4-1 6 0" />
        <path d="M3 13c2-1 4-1 6 0s4 1 6 0 4-1 6 0" />
        <path d="M12 4c1.5 2 3.5 4 3.5 6.5S13.5 14 12 14s-3.5-1-3.5-3.5S10.5 6 12 4z" />
      </svg>
    </span>
    <span class="brand__type">
      <span class="brand__name">MyWildlifeCam</span>
      <span class="brand__tag">Trail cameras for the backyard</span>
    </span>
  </a>

  <AffiliateDisclosure slot="footer-legal" siteName={siteName} variant="footer" />

  <slot />
</SiteShell>

<style>
  /* Brand: forest leaf-mark + two-line wordmark. Lives in this layout (not
     SiteShell) because the brand markup is slotted from here — Astro scopes
     these styles to the markup THIS file authors. SiteShell only positions the
     brand slot as the first flex child of .site-header__inner. */
  .brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--color-forest);
  }
  .brand:hover { color: var(--color-brass); }
  .brand__mark {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-full);
    background: var(--color-forest);
    color: var(--color-paper);
    flex-shrink: 0;
  }
  .brand__type {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .brand__name {
    font-family: var(--font-serif);
    font-weight: var(--weight-semibold);
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-display);
  }
  .brand__tag {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-muted);
    margin-top: 3px;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    font-weight: var(--weight-medium);
  }
  @media (max-width: 760px) {
    .brand__tag { display: none; }
  }
</style>
