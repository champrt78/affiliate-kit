---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "md" | "lg";
  external?: boolean;
  rel?: string;
  target?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  external = true,
  rel,
  target,
} = Astro.props;
const resolvedRel = rel ?? (external ? "nofollow sponsored noopener" : undefined);
const resolvedTarget = target ?? (external ? "_blank" : undefined);
---
<a
  href={href}
  class:list={["cta", `cta--${variant}`, `cta--${size}`]}
  rel={resolvedRel}
  target={resolvedTarget}
>
  <span class="cta__label"><slot /></span>
  {external && (
    <svg class="cta__arrow" viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
      <path d="M3 8h9.5M9 4.5l3.5 3.5L9 11.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )}
</a>

<style>
  .cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-weight: var(--weight-bold, 700);
    letter-spacing: 0.01em;
    text-decoration: none;
    border-radius: var(--radius-button, 8px);
    border: 1px solid transparent;
    transition: background var(--duration-base) var(--ease-out),
                color var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out),
                transform var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out);
    white-space: normal;
    max-width: 100%;
    text-align: center;
  }
  .cta:hover { transform: translateY(-1px); }
  .cta:active { transform: translateY(0); }
  .cta__arrow {
    transition: transform var(--duration-base) var(--ease-out);
    flex-shrink: 0;
  }
  .cta:hover .cta__arrow { transform: translateX(3px); }

  /* Sizes */
  .cta--md {
    padding: 13px var(--space-5);
    font-size: 14px;
  }
  .cta--lg {
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-base);
  }

  /* Primary — accent fill, paper text (mockup 10) */
  .cta--primary {
    background: var(--color-brass);
    color: var(--color-accent-fg, var(--color-paper));
    box-shadow: var(--shadow-button);
  }
  .cta--primary:hover {
    filter: brightness(0.94);
    color: var(--color-accent-fg, var(--color-paper));
    box-shadow: var(--shadow-button-hover);
  }

  /* Secondary — forest button */
  .cta--secondary {
    background: var(--color-forest);
    color: var(--color-paper);
  }
  .cta--secondary:hover {
    background: var(--color-forest-mid);
    color: var(--color-paper);
  }

  /* Ghost — outline */
  .cta--ghost {
    background: transparent;
    color: var(--color-forest);
    border-color: var(--color-forest);
  }
  .cta--ghost:hover {
    background: var(--color-forest);
    color: var(--color-paper);
  }
</style>
