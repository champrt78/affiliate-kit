---
/* <ComparisonArticle entry={...} /> — head-to-head "X vs Y" comparison page.
   Revenue plan 2026-06-01: the highest-ROI new content type (converts 2-5x
   informational). Structure follows the research: comparison TABLE + VERDICT
   high up (answer before the scroll), then per-product "who should buy" cards,
   deal-breakers, editorial prose, FAQ, footer CTA.

   GATE: `verdict.verdict` empty/placeholder => isDraft => the wrapper sets
   robots noindex (same gate as guides/reviews). The verdict (winner call) is
   Ray's to write. Token-mapped so it auto-skins per site. */
import type { CollectionEntry } from "astro:content";
import Media from "./Media.astro";
import FaqList from "./FaqList.astro";
import MethodBox from "./MethodBox.astro";
import CTA from "./CTA.astro";
import { cloakedLink, productSchema } from "@affkit/shared-utils";

interface Props {
  entry: CollectionEntry<"comparisons">;
  siteName?: string;
  crumbLabel?: string;
  crumbHref?: string;
  editorialTeamName?: string;
  credentialLine?: string;
  bottomCtaLabel?: string;
}
const {
  entry,
  siteName = "DetailerPicks",
  crumbLabel = "All comparisons",
  crumbHref = "/comparisons/",
  editorialTeamName = "The DetailerPicks editorial team",
  credentialLine = "Spec analysis · verified-buyer reports · independent teardowns. We don't take payment from brands.",
  bottomCtaLabel = "See the winner on Amazon",
} = Astro.props;

const { data } = entry;
const { Content } = await entry.render();

const BOTTOMLINE_PLACEHOLDER = "_The Bottom Line is being written._";
const verdict = (data as any).verdict as { verdict: string; supporting?: string | string[] } | undefined;
const isDraft = !verdict || !verdict.verdict || verdict.verdict.trim() === "" || verdict.verdict.includes(BOTTOMLINE_PLACEHOLDER);

const products = data.products as any[];
const winnerName = (data as any).winner as string | undefined;
const isWinner = (p: any) => winnerName && p.name === winnerName;

const fmtPrice = (n?: number) =>
  (typeof n === "number" && n > 0)
    ? `$${n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`
    : null;

const cloaked = (p: any) => {
  // prefer a cloaked /go/<slug> if the affiliate link is a bare amazon URL handled elsewhere;
  // otherwise use the affiliateUrl directly.
  return p.affiliateUrl;
};

// Union of all fact keys across products → comparison-table rows (order: first
// product's keys first, then any extras from others).
const factKeys: string[] = [];
for (const p of products) {
  for (const k of Object.keys(p.facts ?? {})) if (!factKeys.includes(k)) factKeys.push(k);
}

const rubric = (data as any).rubric ?? "Head-to-head";
const deck = (data as any).deck ?? data.description;
const dealBreakers = (data as any).dealBreakers as string[] | undefined;
const faq = (data as any).faq as Array<{ question: string; answer: string }> | undefined;

const heroImage = data.images?.hero;
const fmtUpdated = data.lastUpdated instanceof Date
  ? data.lastUpdated.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })
  : String(data.lastUpdated);
const isoUpdated = data.lastUpdated instanceof Date ? data.lastUpdated.toISOString() : String(data.lastUpdated);
const brandInitial = siteName.charAt(0);

// FAQPage JSON-LD
const faqLd = faq && faq.length > 0 ? {
  "@context": "https://schema.org", "@type": "FAQPage",
  mainEntity: faq.map((f) => ({ "@type": "Question", name: f.question, acceptedAnswer: { "@type": "Answer", text: f.answer } })),
} : null;

// Product JSON-LD per compared product (AIO citation eligibility; guides+reviews
// already emit this — comparisons were missing it).
const productLds = products.map((p) => productSchema({
  name: p.name,
  brand: p.brand,
  sku: p.name,
  image: p.image ?? "",
  description: data.description,
  offerUrl: p.affiliateUrl,
}));
---
{faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}
{productLds.map((ld) => <script type="application/ld+json" set:html={JSON.stringify(ld)} />)}

{isDraft && (
  <aside class="draft-banner" role="alert">
    <strong>DRAFT.</strong> This comparison's verdict hasn't been written. Don't link to it yet; indexing is disabled until it's complete.
  </aside>
)}

<article class="cmp">
  {heroImage && (
    <div class="cmp-hero" style={`background-image:url('${heroImage}')`}>
      <div class="cmp-hero__overlay"></div>
    </div>
  )}

  <section class="band">
    <div class="band__inner">
      <header class="cmp-head">
        <a href={crumbHref} class="cmp-crumb">&larr; {crumbLabel}</a>
        <span class="rubric">{rubric}</span>
        <h1 class="cmp-title">{data.title}</h1>
        <p class="cmp-deck">{deck}</p>
        <div class="byline" aria-label="Article byline">
          <span class="byline__avatar" aria-hidden="true">{brandInitial}</span>
          <div class="byline__who">
            <span class="byline__name">{editorialTeamName}</span>
            <span class="byline__cred">{credentialLine}</span>
          </div>
          <div class="byline__when">
            <span class="byline__label">Last updated</span>
            <time class="byline__date" datetime={isoUpdated}>{fmtUpdated}</time>
          </div>
        </div>
      </header>

      {/* ── VERDICT (winner call) — high up, answer before the scroll ── */}
      {!isDraft && verdict && (
        <section class="verdict" aria-label="Our verdict">
          <span class="verdict__label">The verdict</span>
          <p class="verdict__lead">{verdict.verdict}</p>
          {Array.isArray(verdict.supporting)
            ? <ul class="verdict__list">{(verdict.supporting as string[]).map((s) => <li>{s}</li>)}</ul>
            : verdict.supporting ? <p class="verdict__supporting">{verdict.supporting}</p> : null}
        </section>
      )}

      <MethodBox siteName={siteName} />

      {/* ── Comparison table — products as columns, facts as rows, winner highlighted ── */}
      <section class="cmp-table-wrap" aria-label="Side-by-side comparison">
        <table class="cmp-table">
          <thead>
            <tr>
              <th class="cmp-table__rowhead"></th>
              {products.map((p) => (
                <th class:list={["cmp-table__col", isWinner(p) && "is-winner"]}>
                  {isWinner(p) && <span class="cmp-table__pick">Our pick</span>}
                  <span class="cmp-table__name">{p.name}</span>
                  <span class="cmp-table__brand">{p.brand}</span>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            <tr>
              <th class="cmp-table__rowhead">Price</th>
              {products.map((p) => (
                <td class:list={[isWinner(p) && "is-winner"]}>{fmtPrice(p.priceFrom) ?? "Check price"}{p.priceUnit && fmtPrice(p.priceFrom) && <small>/{p.priceUnit}</small>}</td>
              ))}
            </tr>
            {factKeys.map((k) => (
              <tr>
                <th class="cmp-table__rowhead">{k}</th>
                {products.map((p) => (
                  <td class:list={[isWinner(p) && "is-winner"]}>{(p.facts ?? {})[k] ?? "—"}</td>
                ))}
              </tr>
            ))}
            <tr class="cmp-table__cta-row">
              <th class="cmp-table__rowhead"></th>
              {products.map((p) => (
                <td class:list={[isWinner(p) && "is-winner"]}>
                  <a class="cmp-table__cta" href={cloaked(p)} rel="nofollow sponsored noopener" target="_blank">See on Amazon &rarr;</a>
                </td>
              ))}
            </tr>
          </tbody>
        </table>
      </section>

      {/* ── Who should buy which — one card per product ── */}
      <section class="cmp-picks" aria-label="Who should buy which">
        {products.map((p) => (
          <article class:list={["cmp-pick", isWinner(p) && "is-winner"]}>
            <div class="cmp-pick__media">
              {p.image
                ? <Media src={p.image} alt={p.name} variant="hero" width={500} height={500} loading="lazy" />
                : <div class="cmp-pick__ph">product image</div>}
            </div>
            <div class="cmp-pick__body">
              {isWinner(p) && <span class="cmp-pick__badge">Our pick</span>}
              <h2 class="cmp-pick__name">Buy the {p.name} if</h2>
              {p.bestFor && <p class="cmp-pick__bestfor">{p.bestFor}</p>}
              {p.body && <div class="cmp-pick__prose" set:html={p.body}></div>}
              <div class="cmp-pick__foot">
                {fmtPrice(p.priceFrom) && <span class="cmp-pick__price">{fmtPrice(p.priceFrom)}</span>}
                <a class="cmp-pick__cta" href={cloaked(p)} rel="nofollow sponsored noopener" target="_blank">See {p.brand} on Amazon &rarr;</a>
              </div>
            </div>
          </article>
        ))}
      </section>

      {dealBreakers && dealBreakers.length > 0 && (
        <section class="cmp-dealbreakers" aria-label="Deal-breakers">
          <h2>Deal-breakers</h2>
          <ul>{dealBreakers.map((d) => <li>{d}</li>)}</ul>
        </section>
      )}

      {/* ── Editorial body (markdown) ── */}
      <div class="prose"><Content /></div>
    </div>
  </section>

  {faq && faq.length > 0 && <FaqList faq={faq} />}

  <footer class="band cmp-footer">
    <div class="band__inner">
      <div class="cta-wrap">
        <CTA href={winnerName ? cloaked(products.find(isWinner) ?? products[0]) : products[0].affiliateUrl} rel="nofollow sponsored noopener" target="_blank">
          {bottomCtaLabel}
        </CTA>
      </div>
      <p class="updated">Last updated: <time datetime={isoUpdated}>{fmtUpdated}</time></p>
    </div>
  </footer>
</article>

<style>
  .draft-banner { background:#fef3c7; border:2px solid #d97706; color:#78350f; padding:var(--space-4); border-radius:var(--radius-md); margin:var(--space-4); font-size:var(--text-sm); }
  .cmp-hero { width:100%; aspect-ratio:16/6; max-height:300px; background-size:cover; background-position:center; background-color:var(--color-paper-ink); position:relative; }
  .cmp-hero__overlay { position:absolute; inset:0; background:linear-gradient(180deg, rgba(20,24,28,.10), rgba(20,24,28,.45)); }
  .band { padding: var(--space-12,3rem) var(--space-8,2rem); }
  .band__inner { max-width: 1040px; margin: 0 auto; }

  .cmp-crumb { font-family:var(--font-sans); font-size:13px; color:var(--color-muted); text-decoration:none; }
  .rubric { display:block; font-family:var(--font-sans); font-size:12px; letter-spacing:.14em; text-transform:uppercase; color:var(--color-brass); margin:14px 0 8px; font-weight:var(--weight-semibold,600); }
  .cmp-title { font-family:var(--font-serif); font-size:clamp(28px,3.6vw,40px); line-height:1.15; letter-spacing:-.02em; color:var(--color-paper-ink); margin:0 0 10px; }
  .cmp-deck { font-family:var(--font-serif); font-style:italic; font-size:19px; line-height:1.45; color:var(--color-muted); margin:0 0 20px; max-width:60ch; }

  .byline { display:flex; align-items:center; gap:12px; padding:14px 0; border-top:1px solid var(--color-border); border-bottom:1px solid var(--color-border); margin-bottom:var(--space-8); }
  .byline__avatar { width:38px; height:38px; border-radius:999px; background:var(--color-forest); color:var(--color-paper); display:flex; align-items:center; justify-content:center; font-family:var(--font-serif); font-size:18px; }
  .byline__who { display:flex; flex-direction:column; }
  .byline__name { font-family:var(--font-sans); font-weight:var(--weight-semibold,600); font-size:14px; color:var(--color-paper-ink); }
  .byline__cred { font-family:var(--font-sans); font-size:12px; color:var(--color-muted); max-width:60ch; }
  .byline__when { margin-left:auto; text-align:right; }
  .byline__label { display:block; font-family:var(--font-sans); font-size:10px; letter-spacing:.12em; text-transform:uppercase; color:var(--color-muted); }
  .byline__date { font-family:var(--font-sans); font-size:13px; color:var(--color-paper-ink); }

  .verdict { background:var(--color-paper-muted); border-top:3px solid var(--color-brass); border-radius:var(--radius-card,14px); padding:var(--pad-card,20px) 24px; margin-bottom:var(--space-8); }
  .verdict__label { font-family:var(--font-sans); font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--color-brass); font-weight:var(--weight-bold,700); }
  .verdict__lead { font-family:var(--font-serif); font-size:21px; line-height:1.4; color:var(--color-paper-ink); margin:8px 0 0; }
  .verdict__supporting { font-family:var(--font-sans); font-size:15px; line-height:1.6; color:var(--color-paper-ink); opacity:.9; margin:12px 0 0; }
  .verdict__list { margin:12px 0 0; padding-left:20px; } .verdict__list li { font-family:var(--font-sans); font-size:15px; line-height:1.55; margin-bottom:8px; }

  .cmp-table-wrap { overflow-x:auto; margin-bottom:var(--space-10); }
  .cmp-table { width:100%; min-width:520px; border-collapse:separate; border-spacing:0; border:1px solid var(--color-border); border-radius:var(--radius-button,8px); overflow:hidden; font-family:var(--font-sans); }
  .cmp-table th, .cmp-table td { padding:12px 16px; border-bottom:1px solid var(--color-border); text-align:left; vertical-align:middle; font-size:14px; }
  .cmp-table tr:last-child th, .cmp-table tr:last-child td { border-bottom:0; }
  .cmp-table__rowhead { font-weight:var(--weight-semibold,600); color:var(--color-muted); font-size:11px; text-transform:uppercase; letter-spacing:.08em; width:128px; background:var(--color-paper-muted); }
  .cmp-table__col { vertical-align:bottom; }
  .cmp-table__col .cmp-table__name { display:block; font-family:var(--font-serif); font-size:17px; color:var(--color-paper-ink); }
  .cmp-table__col .cmp-table__brand { display:block; font-size:12px; color:var(--color-muted); }
  .cmp-table__pick { display:inline-block; background:var(--award-gold,#C9A227); color:var(--award-gold-ink,#2A2008); font-size:10px; font-weight:var(--weight-bold,700); text-transform:uppercase; letter-spacing:.1em; padding:2px 8px; border-radius:999px; margin-bottom:6px; }
  .cmp-table td.is-winner, .cmp-table th.is-winner { background:color-mix(in srgb, var(--award-gold,#C9A227) 12%, transparent); }
  .cmp-table__cta { display:inline-block; background:var(--color-accent,var(--color-brass)); color:var(--color-accent-fg,#fff); font-weight:var(--weight-bold,700); font-size:13px; padding:9px 14px; border-radius:var(--radius-button,8px); text-decoration:none; }
  .cmp-table__cta:hover { filter:brightness(1.06); color:var(--color-accent-fg,#fff); }

  .cmp-picks { display:flex; flex-direction:column; gap:20px; margin-bottom:var(--space-10); }
  .cmp-pick { display:grid; grid-template-columns:200px 1fr; gap:24px; align-items:start; background:var(--color-paper); border:1px solid var(--color-border); border-radius:var(--radius-card,14px); box-shadow:var(--shadow-card); padding:20px; }
  .cmp-pick.is-winner { border-color:var(--award-gold,#C9A227); }
  .cmp-pick__media { width:100%; height:170px; background:var(--media-bg,#fff); border:1px solid var(--color-border); border-radius:var(--radius-lg,10px); display:flex; align-items:center; justify-content:center; padding:12px; }
  .cmp-pick__media :global(img) { max-width:100%; max-height:100%; width:auto; height:auto; object-fit:contain; }
  .cmp-pick__ph { color:var(--color-muted-soft,#9aa0a6); font-size:12px; font-family:var(--font-sans); }
  .cmp-pick__badge { display:inline-block; background:var(--award-gold,#C9A227); color:var(--award-gold-ink,#2A2008); font-size:10px; font-weight:var(--weight-bold,700); text-transform:uppercase; letter-spacing:.1em; padding:2px 9px; border-radius:999px; margin-bottom:8px; }
  .cmp-pick__name { font-family:var(--font-serif); font-size:22px; line-height:1.2; color:var(--color-paper-ink); margin:0 0 8px; }
  .cmp-pick__bestfor { font-family:var(--font-sans); font-size:15px; font-weight:var(--weight-semibold,600); color:var(--color-paper-ink); margin:0 0 10px; }
  .cmp-pick__prose :global(p) { font-family:var(--font-sans); font-size:15px; line-height:1.65; color:var(--color-paper-ink); opacity:.9; margin:0 0 12px; }
  .cmp-pick__foot { display:flex; align-items:center; gap:16px; flex-wrap:wrap; margin-top:8px; }
  .cmp-pick__price { font-family:var(--font-serif); font-size:22px; color:var(--color-paper-ink); }
  .cmp-pick__cta { background:var(--color-forest); color:var(--color-brand-fg,var(--color-paper)); font-family:var(--font-sans); font-weight:var(--weight-bold,700); font-size:14px; padding:11px 18px; border-radius:var(--radius-button,8px); text-decoration:none; box-shadow:var(--shadow-button); }
  .cmp-pick__cta:hover { filter:brightness(1.06); color:var(--color-brand-fg,var(--color-paper)); }

  .cmp-dealbreakers { margin-bottom:var(--space-10); }
  .cmp-dealbreakers h2 { font-family:var(--font-serif); font-size:24px; color:var(--color-paper-ink); margin:0 0 12px; padding-bottom:10px; border-bottom:1px solid var(--color-paper-ink); }
  .cmp-dealbreakers ul { padding-left:20px; } .cmp-dealbreakers li { font-family:var(--font-sans); font-size:15px; line-height:1.6; margin-bottom:8px; color:var(--color-paper-ink); }

  .prose { max-width:680px; margin-inline:auto; line-height:1.7; font-size:16px; color:var(--color-paper-ink); }
  .prose :global(h2) { font-family:var(--font-serif); font-size:1.5rem; margin:var(--space-10) 0 var(--space-5); color:var(--color-paper-ink); padding-bottom:12px; border-bottom:1px solid var(--color-paper-ink); }
  .prose :global(p) { margin:0 0 18px; }

  .cmp-footer { background:var(--color-paper-muted); text-align:center; }
  .cta-wrap { display:flex; justify-content:center; margin-bottom:12px; }
  .updated { font-family:var(--font-sans); font-size:12px; color:var(--color-muted); }

  @media (max-width:760px) {
    .band { padding: var(--space-10,2.5rem) var(--space-5,1.25rem); }
    .cmp-pick { grid-template-columns:1fr; }
    .cmp-pick__media { max-width:240px; margin:0 auto; }
  }
</style>
