---
interface Row {
  product: string;
  values: string[];
  ctaHref?: string;
}

interface Props {
  headers: string[];
  rows: Row[];
}

const { headers, rows } = Astro.props;
const showCtaCol = rows.some((r) => r.ctaHref);
---
<div class="comparison">
  <div class="comparison__scroll">
    <table class="comparison__table">
      <thead>
        <tr>
          <th class="comparison__th comparison__th--product">Product</th>
          {headers.map((h) => <th class="comparison__th">{h}</th>)}
          {showCtaCol && <th class="comparison__th comparison__th--cta">Where to buy</th>}
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr class="comparison__row">
            <td class="comparison__cell comparison__cell--product">{row.product}</td>
            {row.values.map((v) => <td class="comparison__cell">{v}</td>)}
            {showCtaCol && (
              <td class="comparison__cell comparison__cell--cta">
                {row.ctaHref ? (
                  <a
                    href={row.ctaHref}
                    class="comparison__cta"
                    rel="nofollow sponsored noopener"
                    target="_blank"
                  >
                    Check price
                  </a>
                ) : (
                  <span class="comparison__dash">·</span>
                )}
              </td>
            )}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<style>
  .comparison {
    margin: var(--space-8) 0;
  }
  .comparison__scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card, 14px);
  }
  .comparison__table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    min-width: 36rem;
  }
  .comparison__th {
    background: var(--color-forest);
    color: var(--color-paper);
    font-family: var(--font-sans);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-size: var(--text-xs);
    padding: var(--space-4) var(--space-4);
    text-align: left;
    white-space: nowrap;
  }
  .comparison__th--product { min-width: 12rem; }
  .comparison__row:nth-child(even) { background: var(--color-paper-muted); }
  .comparison__cell {
    padding: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    vertical-align: middle;
    color: var(--color-paper-ink);
    line-height: var(--leading-snug);
  }
  .comparison__row:last-child .comparison__cell { border-bottom: 0; }
  .comparison__cell--product {
    font-family: var(--font-serif);
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
    color: var(--color-forest);
    letter-spacing: -0.01em;
  }
  .comparison__cta {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-5);
    background: var(--color-brass);
    color: var(--color-accent-fg, var(--color-paper));
    border-radius: var(--radius-button, 8px);
    font-family: var(--font-sans);
    font-weight: var(--weight-bold, 700);
    text-decoration: none;
    font-size: var(--text-sm);
    letter-spacing: 0.01em;
    white-space: nowrap;
    box-shadow: var(--shadow-button);
    transition: filter var(--duration-fast) var(--ease-out),
                transform var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out);
  }
  .comparison__cta:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
    box-shadow: var(--shadow-button-hover);
    color: var(--color-accent-fg, var(--color-paper));
  }
  .comparison__dash {
    color: var(--color-muted);
  }
</style>
