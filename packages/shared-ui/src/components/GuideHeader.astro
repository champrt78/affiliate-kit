---
/* <GuideHeader ... /> — full-width editorial buying-guide header.
   Mockup: docs/playgrounds/library/12-section-header.html (v2, full-width).

   Big serif title spans the component on one line (serif skins). A two-column
   band under it pairs the lede with a "What's inside" quick-facts panel
   (picks compared / price range / best for). A full-width byline footer closes
   the block. Token-mapped to the real color and font token system so it
   auto-skins per site.

   Crumb + kicker are optional; facts derived by the caller from products. */
interface Fact {
  k: string;
  v: string;
}

interface Props {
  kicker?: string;
  crumbHref?: string;
  crumbLabel?: string;
  title: string;
  lede: string;
  facts?: Fact[];
  bylineName: string;
  bylineRole?: string;
  bylineInitial?: string;
  updatedIso?: string;
  updatedLabel?: string;
}

const {
  kicker,
  crumbHref,
  crumbLabel = "All buying guides",
  title,
  lede,
  facts = [],
  bylineName,
  bylineRole = "Verified against current manufacturer listings",
  bylineInitial = bylineName.replace(/^The\s+/i, "").charAt(0).toUpperCase(),
  updatedIso,
  updatedLabel,
} = Astro.props;
---
<section class="gh">
  <div class="gh__inner">
    {(crumbHref || kicker) && (
      <div class="gh__topline">
        {crumbHref ? (
          <a class="gh__crumb" href={crumbHref}>&larr; {crumbLabel}</a>
        ) : <span></span>}
        {kicker && <span class="gh__kicker">{kicker}</span>}
      </div>
    )}
    <h1 class="gh__title">{title}</h1>
    <div class="gh__band">
      <p class="gh__lede" set:html={lede}></p>
      {facts.length > 0 && (
        <div class="gh__facts">
          <div class="gh__facts-head">What's inside</div>
          {facts.map((f) => (
            <div class="gh__fact">
              <span class="gh__fact-k">{f.k}</span>
              <span class="gh__fact-v" set:html={f.v}></span>
            </div>
          ))}
        </div>
      )}
    </div>
    <div class="gh__byline">
      <div class="gh__who">
        <div class="gh__avatar">{bylineInitial}</div>
        <div>
          <div class="gh__name">{bylineName}</div>
          <div class="gh__role">{bylineRole}</div>
        </div>
      </div>
      {updatedLabel && (
        <div class="gh__date">
          <div class="gh__date-label">Updated</div>
          <time datetime={updatedIso}>{updatedLabel}</time>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .gh {
    background: var(--color-paper);
    padding: var(--space-10, 2.5rem) var(--space-12, 3.5rem) var(--space-7, 1.75rem);
  }
  .gh__inner { max-width: 1104px; margin: 0 auto; }

  .gh__topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: var(--space-4, 1rem);
  }
  .gh__crumb {
    font-family: var(--font-sans);
    font-size: 12.5px;
    color: var(--color-muted);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .gh__crumb:hover { color: var(--color-accent, var(--color-brass)); }
  .gh__kicker {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: var(--weight-bold, 700);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent, var(--color-brass));
  }
  .gh__kicker::before {
    content: "";
    width: 26px;
    height: 2px;
    background: var(--color-accent, var(--color-brass));
    display: block;
    flex-shrink: 0;
  }

  .gh__title {
    font-family: var(--font-serif);
    font-size: clamp(32px, 3.9vw, 45px);
    font-weight: var(--weight-semibold, 600);
    line-height: 1.04;
    letter-spacing: -0.02em;
    color: var(--color-forest);
    white-space: nowrap;
  }

  .gh__band {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 40px;
    align-items: start;
    margin-top: var(--space-5, 1.25rem);
  }
  .gh__lede {
    font-family: var(--font-sans);
    font-size: 18.5px;
    line-height: 1.58;
    color: var(--color-muted);
    margin: 0;
  }
  .gh__lede :global(b) { color: var(--color-paper-ink); font-weight: var(--weight-semibold, 600); }

  .gh__facts {
    background: var(--color-paper-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card, 14px);
    padding: 16px 18px;
  }
  .gh__facts-head {
    font-family: var(--font-sans);
    font-size: 10.5px;
    font-weight: var(--weight-bold, 700);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    padding-bottom: 10px;
    margin-bottom: 4px;
    border-bottom: 1px solid var(--color-border);
  }
  .gh__fact {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 14px;
    padding: 7px 0;
  }
  .gh__fact + .gh__fact { border-top: 1px solid var(--color-border); }
  .gh__fact-k {
    font-family: var(--font-sans);
    font-size: 12.5px;
    color: var(--color-muted);
    white-space: nowrap;
  }
  .gh__fact-v {
    font-family: var(--font-sans);
    font-size: 13.5px;
    font-weight: var(--weight-bold, 700);
    color: var(--color-paper-ink);
    text-align: right;
  }

  .gh__byline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    flex-wrap: wrap;
    margin-top: var(--space-6, 1.5rem);
    padding-top: 18px;
    border-top: 1px solid var(--color-border);
  }
  .gh__who { display: flex; align-items: center; gap: 12px; }
  .gh__avatar {
    width: 38px;
    height: 38px;
    border-radius: var(--radius-full, 999px);
    background: var(--color-forest);
    color: var(--color-brand-fg, var(--color-paper));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-weight: var(--weight-semibold, 600);
    font-size: 15px;
    flex-shrink: 0;
  }
  .gh__name {
    font-family: var(--font-sans);
    font-weight: var(--weight-bold, 700);
    font-size: 14px;
    color: var(--color-paper-ink);
  }
  .gh__role {
    font-family: var(--font-sans);
    font-size: 12.5px;
    color: var(--color-muted);
    margin-top: 2px;
  }
  .gh__date { text-align: right; }
  .gh__date-label {
    font-family: var(--font-sans);
    font-size: 10.5px;
    font-weight: var(--weight-bold, 700);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .gh__date time {
    display: block;
    font-family: var(--font-sans);
    font-size: 13.5px;
    color: var(--color-paper-ink);
    margin-top: 2px;
  }

  @media (max-width: 820px) {
    .gh { padding: var(--space-8, 2rem) var(--space-6, 1.5rem) var(--space-6, 1.5rem); }
    .gh__title { white-space: normal; font-size: clamp(28px, 8vw, 36px); }
    .gh__band { grid-template-columns: 1fr; gap: 22px; }
  }
</style>
