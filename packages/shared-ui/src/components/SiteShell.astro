---
/**
 * <SiteShell ... /> — the shared presentation shell.
 *
 * Owns the "build once, skin per site" page chrome that used to be copy-pasted
 * into every site's ~470-line MainLayout.astro:
 *   - the skip-link
 *   - the full-width header band (brand slot + nav from `navItems`)
 *   - the footer (columns from `footerColumns` + a base/legal row)
 *   - the nav-toggle + (formerly per-site) scroll JS — defined ONCE here
 *   - the floating content-panel wrapper (`.page-shell`, the DTP look)
 *   - the per-page gutter background (themeBackgrounds + the head-slot
 *     inline-style cascade workaround documented below)
 *
 * It wraps `<BaseLayout>` (which owns <html>/<head>/fonts/JSON-LD-friendly head
 * slot). Sites pass per-site identity via props/slots — nothing of the page
 * structure is duplicated per site anymore.
 *
 * SLOT-SCOPING NOTE (load-bearing): Astro scopes a component's `<style>` to the
 * markup that component AUTHORS. The `brand` slot's markup is authored by the
 * CALLING site (e.g. DTP's MainLayout passes `Detailer<em>Picks</em>`), so its
 * `.brand*` CSS must live in the CALLER, not here. SiteShell only POSITIONS the
 * brand slot as the first flex child of `.site-header__inner`. Everything else
 * (nav, footer, panel) is authored AND styled here.
 *
 * Step 2 (2026-05-29): only DetailerPicks renders through this shell. MWC and
 * fussybean keep their own MainLayout→BaseLayout path (their chrome genuinely
 * differs — sticky full-bleed header, no zoom panel). They migrate in Step 3.
 *
 * HARDENING (2026-05-29, per CE architecture review): the shell now carries
 * all 5 sites' chrome topology without forking. Three classes of seam, all
 * DEFAULTING to DTP's exact current behavior so DTP is pixel-identical:
 *   1. Chrome COLOR tokens — `--header-bg`, `--footer-bg`, `--footer-fg`,
 *      `--header-border`, `--nav-link` — each resolved `var(--x, <DTP value>)`.
 *      A site reskins chrome by setting these in its site-tokens.css :root.
 *   2. Footer grid is COLUMN-COUNT-driven (`--footer-cols` = footerColumns.length)
 *      with a 900px intermediate breakpoint that is GATED to ≥3 footer columns
 *      so DTP (2 cols) never enters it. fussybean (3 cols) gets the 2-up step.
 *   3. `stickyHeader` (default false) — when true the header moves OUTSIDE the
 *      zoom panel and goes position:sticky with backdrop-blur + an is-scrolled
 *      restyle (MWC/fussybean). zoom on .page-shell is unreliable for sticky
 *      children, so the sticky branch renders a STRUCTURALLY DIFFERENT tree
 *      (header outside .page-shell, panel un-zoomed). `transparentHeader`
 *      (default false) overlays the header for a homepage hero.
 * The default branch (stickyHeader=false) renders the exact same DOM tree as
 * before — see the conditional in the markup. Don't merge the two branches.
 */
import BaseLayout from "./BaseLayout.astro";

export interface NavItem {
  href: string;
  label: string;
}
export interface FooterColumn {
  heading: string;
  links: Array<{ href: string; label: string }>;
}

interface Props {
  // --- BaseLayout passthrough (page <head>) ---
  title: string;
  description: string;
  canonical?: string;
  siteName: string;
  robotsContent?: string;
  themeColor?: string;
  ogType?: string;
  ogImage?: string;
  fontsHref?: string;

  // --- Shell chrome ---
  /** Primary + mobile nav links. */
  navItems: NavItem[];
  /** Footer link columns (rendered after the brand blurb column). */
  footerColumns?: FooterColumn[];
  /** Footer brand blurb (first column, under the site name). */
  footerBlurb?: string;
  /**
   * Per-page gutter background. Pass a ready CSS `background` shorthand value
   * (the site resolves its own themeBackgrounds map and passes the string), or
   * "none" for a solid-color page. The shell injects it via the documented
   * head-slot inline-style cascade workaround so the gutter photo shows beside
   * the floating panel. Defaults to "none".
   */
  pageBg?: string;
  /**
   * Solid fallback / gutter base color painted under the photo (and shown when
   * pageBg is "none"). Defaults to the kit ink (#14181C).
   */
  gutterColor?: string;

  /**
   * Sticky full-bleed header (MWC / fussybean). Default false = DTP's
   * in-panel, non-sticky header. When true the header is rendered OUTSIDE the
   * zoom'd .page-shell (position:sticky inside a `zoom` panel is unreliable),
   * the panel zoom is disabled, and a scroll handler toggles `is-scrolled` on
   * the header. The site's site-tokens.css owns the actual sticky look
   * (backdrop-blur, scrolled bg) via the chrome color tokens + its own scoped
   * CSS — the shell only supplies position:sticky + the is-scrolled hook.
   */
  stickyHeader?: boolean;
  /**
   * Transparent / overlay header for a homepage hero (fussybean homepage).
   * Default false = DTP. Only meaningful alongside stickyHeader; adds the
   * `site-header--transparent` modifier so a site's CSS can paint it
   * transparent and re-solidify it on scroll. The shell ships a minimal
   * transparent treatment; per-site polish lives in site-tokens.css.
   */
  transparentHeader?: boolean;
}

const {
  title,
  description,
  canonical,
  siteName,
  robotsContent,
  themeColor,
  ogType,
  ogImage,
  fontsHref,
  navItems,
  footerColumns = [],
  footerBlurb,
  pageBg = "none",
  gutterColor = "#14181C",
  stickyHeader = false,
  transparentHeader = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
const year = new Date().getFullYear();

// Footer grid is column-count-driven: brand column (2fr) + one 1fr per footer
// link column. DTP has 2 footer columns → "2fr 1fr 1fr" (identical to the old
// hardcoded value). Emitted as --footer-cols on the inner + a data attr that
// gates the 900px intermediate breakpoint (so DTP's 2 cols never enter it).
// Floored at 1: a consumer that omits footerColumns would otherwise yield
// `repeat(0, 1fr)`, which some CSS engines treat as invalid and drop the whole
// grid-template-columns declaration. Floor keeps the grid valid (brand-only).
const footerColCount = Math.max(1, footerColumns.length);
---
<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  siteName={siteName}
  robotsContent={robotsContent}
  ogType={ogType}
  ogImage={ogImage}
  themeColor={themeColor}
  fontsHref={fontsHref}
>
  {/* Per-page body bg + cascade workaround. Astro's define:vars scopes a var
      to the component's wrapping element, so :global(body)'s var() lookup can't
      see it. Inject a per-render <style is:inline> into the head slot that
      hardcodes the bg string, with the gutter color as a SEPARATE
      background-color so it survives the `background` shorthand's bg-color reset.
      (Order matters: the background-color declaration must come AFTER the
      shorthand.) Don't move this into a scoped <style> below — that compiles
      into the linked CSS file which loads AFTER this inline head style and would
      override it with an unresolved var() → invalid → blank gutter. The bug this
      prevents: the silent blank-gutter regression (DTP, 2026-05-23). */}
  <Fragment slot="head">
    <style is:inline set:html={`body { background: ${pageBg}; background-color: ${gutterColor}; }`}></style>
    <slot name="head" />
  </Fragment>

  <a href="#main" class="skip-link">Skip to content</a>

  {/* When stickyHeader: header lives OUTSIDE .page-shell so position:sticky
      isn't trapped inside the unreliable zoom context, and the panel zoom is
      disabled (.page-shell--flat). Default (DTP): header lives INSIDE the
      zoom'd panel, exactly as before. */}
  {stickyHeader && (
    <header
      class:list={["site-header", "is-sticky", transparentHeader && "is-transparent"]}
      data-site-header
      data-sticky
    >
      <div class="site-header__inner">
        <slot name="brand" />
        <nav class="site-nav" aria-label="Primary">
          {navItems.map((item) => (
            <a
              href={item.href}
              class={currentPath === item.href ? "site-nav__link is-active" : "site-nav__link"}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <button class="nav-toggle" aria-expanded="false" aria-controls="mobile-nav" aria-label="Open menu" data-nav-toggle>
          <span class="nav-toggle__bar"></span>
          <span class="nav-toggle__bar"></span>
          <span class="nav-toggle__bar"></span>
        </button>
      </div>
      <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile" data-mobile-nav>
        {navItems.map((item) => (
          <a href={item.href} class="mobile-nav__link">{item.label}</a>
        ))}
      </nav>
    </header>
  )}

  {/* The whole content panel floats on the gutter photo and scales as one unit.
      zoom:var(--page-scale) on .page-shell scales header + main + footer
      uniformly; the gutter photo shows beside the header too. zoom (not
      transform:scale) keeps normal document flow + centering and avoids a
      transformed stacking context. When stickyHeader is true, the panel is
      flattened (.page-shell--flat drops the zoom) so the now-external sticky
      header isn't out of sync with a scaled panel. */}
  <div class:list={["page-shell", stickyHeader && "page-shell--flat", transparentHeader && "page-shell--bleed"]}>
    {!stickyHeader && (
      <header class="site-header">
        <div class="site-header__inner">
          <slot name="brand" />

          <nav class="site-nav" aria-label="Primary">
            {navItems.map((item) => (
              <a
                href={item.href}
                class={currentPath === item.href ? "site-nav__link is-active" : "site-nav__link"}
              >
                {item.label}
              </a>
            ))}
          </nav>

          <button class="nav-toggle" aria-expanded="false" aria-controls="mobile-nav" aria-label="Open menu" data-nav-toggle>
            <span class="nav-toggle__bar"></span>
            <span class="nav-toggle__bar"></span>
            <span class="nav-toggle__bar"></span>
          </button>
        </div>

        <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile" data-mobile-nav>
          {navItems.map((item) => (
            <a href={item.href} class="mobile-nav__link">{item.label}</a>
          ))}
        </nav>
      </header>
    )}

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner" data-footer-cols={footerColCount} style={`--footer-cols: ${footerColCount};`}>
        <div class="site-footer__brand">
          <span class="site-footer__name">{siteName}</span>
          {footerBlurb && <p class="site-footer__blurb">{footerBlurb}</p>}
        </div>

        {footerColumns.map((col) => (
          <div class="site-footer__col">
            <h4>{col.heading}</h4>
            {col.links.map((link) => (
              <a href={link.href} set:html={link.label}></a>
            ))}
          </div>
        ))}
      </div>

      <div class="site-footer__base">
        <slot name="footer-legal" />
        <p class="site-footer__copy">© {year} {siteName}. All rights reserved.</p>
      </div>
    </footer>
  </div>{/* .page-shell — floating content panel */}
</BaseLayout>

<script is:inline>
  (function () {
    const toggle = document.querySelector("[data-nav-toggle]");
    const mobileNav = document.querySelector("[data-mobile-nav]");

    if (toggle && mobileNav) {
      toggle.addEventListener("click", () => {
        const expanded = toggle.getAttribute("aria-expanded") === "true";
        toggle.setAttribute("aria-expanded", String(!expanded));
        toggle.setAttribute("aria-label", expanded ? "Open menu" : "Close menu");
        mobileNav.classList.toggle("is-open", !expanded);
        document.body.classList.toggle("nav-open", !expanded);
      });
    }

    // Sticky-header scroll restyle — re-homed from MWC/fussybean MainLayouts.
    // Only wires up when stickyHeader rendered a [data-sticky] header; on DTP
    // (default, no data-sticky) the selector misses and this is a no-op, so
    // DTP gets zero new behavior. The inline script can't read Astro props, so
    // the data-sticky attribute is the prop's runtime signal.
    const stickyHeader = document.querySelector("[data-site-header][data-sticky]");
    if (stickyHeader) {
      let ticking = false;
      const onScroll = () => {
        if (window.scrollY > 12) stickyHeader.classList.add("is-scrolled");
        else stickyHeader.classList.remove("is-scrolled");
        ticking = false;
      };
      window.addEventListener(
        "scroll",
        () => {
          if (!ticking) {
            window.requestAnimationFrame(onScroll);
            ticking = true;
          }
        },
        { passive: true }
      );
      onScroll();
    }
  })();
</script>

<style>
  /* The floating content panel. Header + main + footer all live INSIDE this
     panel — the gutter photo shows beside the WHOLE panel (header included).
     zoom scales the entire panel uniformly (calmer read). --page-scale is a
     real kit token (shared-styles/tokens.css); a site overrides it in its own
     site-tokens.css to change the per-site scale. Fallback 0.95 matches the
     token so the panel never renders unscaled if the token fails to load. */
  .page-shell {
    zoom: var(--page-scale, 0.95);
    max-width: 1240px;
    margin: 0 auto;
    min-height: 100vh;
    background: var(--color-bg);
    box-shadow:
      0 0 0 1px rgba(20, 24, 28, 0.06),
      0 24px 60px -16px rgba(20, 24, 28, 0.35);
  }
  main {
    min-height: 60vh;
    padding: 0;
    /* main is transparent; the .page-shell panel carries the surface so the
       body-bg photo shows in the gutters beside the panel. */
    background: transparent;
  }
  /* Mobile: panel takes full width so the photo doesn't show on small screens,
     and we drop the zoom so phone text isn't double-shrunk under the browser's
     own text scaling. */
  @media (max-width: 760px) {
    .page-shell { max-width: none; box-shadow: none; zoom: 1; }
  }
  /* stickyHeader sites: the header is external + sticky, so a scaled panel
     would desync from it. Flatten the zoom. (No effect on DTP — default
     branch never gets this class.) */
  .page-shell--flat { zoom: 1; }
  /* transparentHeader sites (homepage hero only): the floating 1240px panel
     would frame the full-bleed hero with espresso gutter strips + a drop
     shadow — a regression from the approved Variant-C edge-to-edge hero. Drop
     the max-width + shadow so the panel spans the viewport. KEEP background so
     the body sections below the hero (e.g. the latte pillar tiles) stay on the
     page surface, not the espresso gutter. Gated on transparentHeader, which
     only the homepage passes, so interior pages keep the floating panel. No
     effect on DTP (never passes transparentHeader). */
  .page-shell--bleed {
    max-width: none;
    box-shadow: none;
  }

  /* Skip link */
  .skip-link {
    position: absolute;
    left: var(--space-4);
    top: -3rem;
    background: var(--color-forest);
    color: var(--color-paper);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    text-decoration: none;
    z-index: 100;
    transition: top var(--duration-fast) var(--ease-out);
  }
  .skip-link:focus { top: var(--space-4); }

  /* Header — full panel width. Lives INSIDE .page-shell, so it spans the
     floating panel edge-to-edge with the gutter photo beside it. Not sticky:
     the panel header scrolls with the panel, and position:sticky inside a
     zoom'd panel is unreliable. Logo pins far-left, nav far-right via the
     panel's own padding (--space-8), NOT clamped to a narrow article shell. */
  /* Chrome color tokens (hardening 2026-05-29). Each resolves to DTP's exact
     current value when the site doesn't set the var, so DTP is unchanged. A
     per-site site-tokens.css reskins chrome by setting --header-bg /
     --header-border / --footer-bg / --footer-fg / --nav-link in :root. */
  .site-header {
    background: var(--header-bg, var(--color-cream));
    border-bottom: 1px solid var(--header-border, var(--color-sage-light));
  }
  /* stickyHeader=true: external sticky band with backdrop-blur. Inert on DTP
     (default branch never carries .is-sticky). The site supplies the scrolled
     restyle (bg/blur/shadow) via its own scoped CSS keyed on
     `.site-header.is-scrolled`; the shell only supplies the positioning +
     a sane default blur so an un-themed sticky header still works. */
  .site-header.is-sticky {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    transition: background var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out);
  }
  /* transparentHeader=true: overlay the header on a homepage hero. Goes solid
     again on scroll (.is-scrolled, set by the gated script). Site CSS can
     override the scrolled bg via --header-bg. */
  .site-header.is-transparent {
    position: absolute;
    left: 0;
    right: 0;
    background: transparent;
    border-bottom-color: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }
  .site-header.is-transparent.is-scrolled {
    position: sticky;
    background: var(--header-bg, var(--color-cream));
    border-bottom-color: var(--header-border, var(--color-sage-light));
  }
  .site-header__inner {
    padding: 0 var(--space-8);
    height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  /* Desktop nav */
  .site-nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }
  .site-nav__link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--nav-link, var(--color-paper-ink));
    text-decoration: none;
    letter-spacing: 0.01em;
    padding: var(--space-2) 0;
    position: relative;
  }
  /* Nav accent (hover/active color + underline) is tokenized so a site whose
     --color-forest equals its header-bg (fussybean: both espresso → invisible
     hover) can override it. Defaults to --color-forest so DTP is unchanged. */
  .site-nav__link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: var(--nav-accent, var(--color-forest));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-base) var(--ease-out);
  }
  .site-nav__link:hover { color: var(--nav-accent, var(--color-forest)); }
  .site-nav__link:hover::after { transform: scaleX(1); }
  .site-nav__link.is-active { color: var(--nav-accent, var(--color-forest)); }
  .site-nav__link.is-active::after { transform: scaleX(1); }

  /* Mobile toggle */
  .nav-toggle {
    display: none;
    background: none;
    border: 0;
    padding: var(--space-2);
    cursor: pointer;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
  }
  /* Toggle bars are tokenized for the same reason as --nav-accent: a site whose
     --color-paper-ink ≈ its --header-bg (fussybean: espresso on espresso) would
     render an invisible hamburger. Defaults to --color-paper-ink so DTP is
     unchanged. */
  .nav-toggle__bar {
    width: 22px;
    height: 2px;
    background: var(--nav-toggle-bar, var(--color-paper-ink));
    border-radius: 1px;
    transition: transform var(--duration-base) var(--ease-out),
                opacity var(--duration-base) var(--ease-out);
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle__bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle__bar:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle__bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile drawer */
  /* Mobile drawer is tokenized so a dark-chrome site (fussybean espresso) keeps
     its drawer on-skin instead of flipping to the light --color-paper default.
     Each falls back to DTP's exact current value. */
  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: var(--space-2) var(--space-6) var(--space-6);
    background: var(--mobile-nav-bg, var(--color-paper));
    border-top: 1px solid var(--header-border, var(--color-sage-light));
  }
  .mobile-nav.is-open { display: flex; }
  .mobile-nav__link {
    padding: var(--space-4) 0;
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: var(--weight-medium);
    color: var(--nav-link, var(--color-paper-ink));
    text-decoration: none;
    border-bottom: 1px solid var(--header-border, var(--color-sage-light));
  }
  .mobile-nav__link:last-child { border-bottom: 0; }

  @media (max-width: 760px) {
    .site-nav { display: none; }
    .nav-toggle { display: flex; }
    .site-header__inner { padding: 0 var(--space-4); gap: var(--space-3); }
  }

  /* Footer */
  .site-footer {
    margin-top: var(--space-24);
    background: var(--footer-bg, var(--color-paper-muted));
    color: var(--footer-fg, var(--color-paper-ink));
    border-top: 1px solid var(--header-border, var(--color-sage-light));
  }
  /* Column-count-driven: brand (2fr) + one 1fr per footer link column.
     --footer-cols is set inline from footerColumns.length. DTP has 2 columns →
     "2fr 1fr 1fr" — byte-identical to the old hardcoded value. The fallback 2
     keeps it sane if the inline var ever fails to arrive. */
  .site-footer__inner {
    padding: var(--space-16) var(--space-8) var(--space-10);
    display: grid;
    grid-template-columns: 2fr repeat(var(--footer-cols, 2), 1fr);
    gap: var(--space-12);
  }
  /* Intermediate breakpoint for wide footers (fussybean's 3 columns → 2-up).
     GATED to ≥3 footer columns so DTP (data-footer-cols="2") never enters the
     760–900 window — its only footer breakpoint stays the 760px collapse. */
  @media (max-width: 900px) {
    .site-footer__inner[data-footer-cols="3"],
    .site-footer__inner[data-footer-cols="4"] {
      grid-template-columns: 1fr 1fr;
    }
  }
  /* Footer sub-element colors are ALSO tokenized (beyond --footer-fg) so a
     light-on-dark footer (MWC forest / fussybean espresso) can be fully
     reskinned without forking. Each defaults to DTP's exact current value:
       --footer-name → --color-paper-ink   (brand wordmark)
       --footer-blurb → --color-muted       (brand blurb)
       --footer-heading → --color-brass     (column h4)
       --footer-link / --footer-link-hover → --color-paper-ink / --color-brass
     DTP sets none of these, so its render is unchanged. */
  .site-footer__brand .site-footer__name {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: var(--weight-semibold);
    color: var(--footer-name, var(--color-paper-ink));
    letter-spacing: -0.012em;
    display: block;
    margin-bottom: var(--space-3);
  }
  .site-footer__blurb {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--footer-blurb, var(--color-muted));
    max-width: 32rem;
    margin: 0;
  }
  .site-footer__col h4 {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--footer-heading, var(--color-brass));
    margin-bottom: var(--space-4);
  }
  .site-footer__col a {
    display: block;
    font-size: var(--text-sm);
    color: var(--footer-link, var(--color-paper-ink));
    text-decoration: none;
    padding: var(--space-1) 0;
    opacity: 0.85;
    transition: opacity var(--duration-fast) var(--ease-out),
                color var(--duration-fast) var(--ease-out);
  }
  .site-footer__col a:hover {
    opacity: 1;
    color: var(--footer-link-hover, var(--color-brass));
  }
  /* Base/legal row aligns to the panel — same horizontal padding (--space-8) as
     the footer columns above it. CLEANUP (P1): previously this row used
     `max-width: var(--container-max); margin: 0 auto`, centering it to 1152px
     while the columns spanned the 1240px panel with --space-8 padding — a stale
