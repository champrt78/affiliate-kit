---
/**
 * <SiteShell ... /> — the shared presentation shell.
 *
 * Owns the "build once, skin per site" page chrome that used to be copy-pasted
 * into every site's ~470-line MainLayout.astro:
 *   - the skip-link
 *   - the full-width header band (brand slot + nav from `navItems`)
 *   - the footer (columns from `footerColumns` + a base/legal row)
 *   - the nav-toggle + (formerly per-site) scroll JS — defined ONCE here
 *   - the floating content-panel wrapper (`.page-shell`, the DTP look)
 *   - the per-page gutter background (themeBackgrounds + the head-slot
 *     inline-style cascade workaround documented below)
 *
 * It wraps `<BaseLayout>` (which owns <html>/<head>/fonts/JSON-LD-friendly head
 * slot). Sites pass per-site identity via props/slots — nothing of the page
 * structure is duplicated per site anymore.
 *
 * SLOT-SCOPING NOTE (load-bearing): Astro scopes a component's `<style>` to the
 * markup that component AUTHORS. The `brand` slot's markup is authored by the
 * CALLING site (e.g. DTP's MainLayout passes `Detailer<em>Picks</em>`), so its
 * `.brand*` CSS must live in the CALLER, not here. SiteShell only POSITIONS the
 * brand slot as the first flex child of `.site-header__inner`. Everything else
 * (nav, footer, panel) is authored AND styled here.
 *
 * Step 2 (2026-05-29): only DetailerPicks renders through this shell. MWC and
 * fussybean keep their own MainLayout→BaseLayout path (their chrome genuinely
 * differs — sticky full-bleed header, no zoom panel). They migrate in Step 3.
 */
import BaseLayout from "./BaseLayout.astro";

export interface NavItem {
  href: string;
  label: string;
}
export interface FooterColumn {
  heading: string;
  links: Array<{ href: string; label: string }>;
}

interface Props {
  // --- BaseLayout passthrough (page <head>) ---
  title: string;
  description: string;
  canonical?: string;
  siteName: string;
  robotsContent?: string;
  themeColor?: string;
  ogType?: string;
  ogImage?: string;
  fontsHref?: string;

  // --- Shell chrome ---
  /** Primary + mobile nav links. */
  navItems: NavItem[];
  /** Footer link columns (rendered after the brand blurb column). */
  footerColumns?: FooterColumn[];
  /** Footer brand blurb (first column, under the site name). */
  footerBlurb?: string;
  /**
   * Per-page gutter background. Pass a ready CSS `background` shorthand value
   * (the site resolves its own themeBackgrounds map and passes the string), or
   * "none" for a solid-color page. The shell injects it via the documented
   * head-slot inline-style cascade workaround so the gutter photo shows beside
   * the floating panel. Defaults to "none".
   */
  pageBg?: string;
  /**
   * Solid fallback / gutter base color painted under the photo (and shown when
   * pageBg is "none"). Defaults to the kit ink (#14181C).
   */
  gutterColor?: string;
}

const {
  title,
  description,
  canonical,
  siteName,
  robotsContent,
  themeColor,
  ogType,
  ogImage,
  fontsHref,
  navItems,
  footerColumns = [],
  footerBlurb,
  pageBg = "none",
  gutterColor = "#14181C",
} = Astro.props;

const currentPath = Astro.url.pathname;
const year = new Date().getFullYear();
---
<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  siteName={siteName}
  robotsContent={robotsContent}
  ogType={ogType}
  ogImage={ogImage}
  themeColor={themeColor}
  fontsHref={fontsHref}
>
  {/* Per-page body bg + cascade workaround. Astro's define:vars scopes a var
      to the component's wrapping element, so :global(body)'s var() lookup can't
      see it. Inject a per-render <style is:inline> into the head slot that
      hardcodes the bg string, with the gutter color as a SEPARATE
      background-color so it survives the `background` shorthand's bg-color reset.
      (Order matters: the background-color declaration must come AFTER the
      shorthand.) Don't move this into a scoped <style> below — that compiles
      into the linked CSS file which loads AFTER this inline head style and would
      override it with an unresolved var() → invalid → blank gutter. The bug this
      prevents: the silent blank-gutter regression (DTP, 2026-05-23). */}
  <Fragment slot="head">
    <style is:inline set:html={`body { background: ${pageBg}; background-color: ${gutterColor}; }`}></style>
    <slot name="head" />
  </Fragment>

  <a href="#main" class="skip-link">Skip to content</a>

  {/* The whole content panel floats on the gutter photo and scales as one unit.
      zoom:var(--page-scale) on .page-shell scales header + main + footer
      uniformly; the gutter photo shows beside the header too. zoom (not
      transform:scale) keeps normal document flow + centering and avoids a
      transformed stacking context. */}
  <div class="page-shell">
    <header class="site-header">
      <div class="site-header__inner">
        <slot name="brand" />

        <nav class="site-nav" aria-label="Primary">
          {navItems.map((item) => (
            <a
              href={item.href}
              class={currentPath === item.href ? "site-nav__link is-active" : "site-nav__link"}
            >
              {item.label}
            </a>
          ))}
        </nav>

        <button class="nav-toggle" aria-expanded="false" aria-controls="mobile-nav" aria-label="Open menu" data-nav-toggle>
          <span class="nav-toggle__bar"></span>
          <span class="nav-toggle__bar"></span>
          <span class="nav-toggle__bar"></span>
        </button>
      </div>

      <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile" data-mobile-nav>
        {navItems.map((item) => (
          <a href={item.href} class="mobile-nav__link">{item.label}</a>
        ))}
      </nav>
    </header>

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__brand">
          <span class="site-footer__name">{siteName}</span>
          {footerBlurb && <p class="site-footer__blurb">{footerBlurb}</p>}
        </div>

        {footerColumns.map((col) => (
          <div class="site-footer__col">
            <h4>{col.heading}</h4>
            {col.links.map((link) => (
              <a href={link.href} set:html={link.label}></a>
            ))}
          </div>
        ))}
      </div>

      <div class="site-footer__base">
        <slot name="footer-legal" />
        <p class="site-footer__copy">© {year} {siteName}. All rights reserved.</p>
      </div>
    </footer>
  </div>{/* .page-shell — floating content panel */}
</BaseLayout>

<script is:inline>
  (function () {
    const toggle = document.querySelector("[data-nav-toggle]");
    const mobileNav = document.querySelector("[data-mobile-nav]");

    if (toggle && mobileNav) {
      toggle.addEventListener("click", () => {
        const expanded = toggle.getAttribute("aria-expanded") === "true";
        toggle.setAttribute("aria-expanded", String(!expanded));
        toggle.setAttribute("aria-label", expanded ? "Open menu" : "Close menu");
        mobileNav.classList.toggle("is-open", !expanded);
        document.body.classList.toggle("nav-open", !expanded);
      });
    }
  })();
</script>

<style>
  /* The floating content panel. Header + main + footer all live INSIDE this
     panel — the gutter photo shows beside the WHOLE panel (header included).
     zoom scales the entire panel uniformly (calmer read). --page-scale is a
     real kit token (shared-styles/tokens.css); a site overrides it in its own
     site-tokens.css to change the per-site scale. Fallback 0.95 matches the
     token so the panel never renders unscaled if the token fails to load. */
  .page-shell {
    zoom: var(--page-scale, 0.95);
    max-width: 1240px;
    margin: 0 auto;
    min-height: 100vh;
    background: var(--color-bg);
    box-shadow:
      0 0 0 1px rgba(20, 24, 28, 0.06),
      0 24px 60px -16px rgba(20, 24, 28, 0.35);
  }
  main {
    min-height: 60vh;
    padding: 0;
    /* main is transparent; the .page-shell panel carries the surface so the
       body-bg photo shows in the gutters beside the panel. */
    background: transparent;
  }
  /* Mobile: panel takes full width so the photo doesn't show on small screens,
     and we drop the zoom so phone text isn't double-shrunk under the browser's
     own text scaling. */
  @media (max-width: 760px) {
    .page-shell { max-width: none; box-shadow: none; zoom: 1; }
  }

  /* Skip link */
  .skip-link {
    position: absolute;
    left: var(--space-4);
    top: -3rem;
    background: var(--color-forest);
    color: var(--color-paper);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    text-decoration: none;
    z-index: 100;
    transition: top var(--duration-fast) var(--ease-out);
  }
  .skip-link:focus { top: var(--space-4); }

  /* Header — full panel width. Lives INSIDE .page-shell, so it spans the
     floating panel edge-to-edge with the gutter photo beside it. Not sticky:
     the panel header scrolls with the panel, and position:sticky inside a
     zoom'd panel is unreliable. Logo pins far-left, nav far-right via the
     panel's own padding (--space-8), NOT clamped to a narrow article shell. */
  .site-header {
    background: var(--color-cream);
    border-bottom: 1px solid var(--color-sage-light);
  }
  .site-header__inner {
    padding: 0 var(--space-8);
    height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  /* Desktop nav */
  .site-nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }
  .site-nav__link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-paper-ink);
    text-decoration: none;
    letter-spacing: 0.01em;
    padding: var(--space-2) 0;
    position: relative;
  }
  .site-nav__link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: var(--color-forest);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-base) var(--ease-out);
  }
  .site-nav__link:hover { color: var(--color-forest); }
  .site-nav__link:hover::after { transform: scaleX(1); }
  .site-nav__link.is-active { color: var(--color-forest); }
  .site-nav__link.is-active::after { transform: scaleX(1); }

  /* Mobile toggle */
  .nav-toggle {
    display: none;
    background: none;
    border: 0;
    padding: var(--space-2);
    cursor: pointer;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
  }
  .nav-toggle__bar {
    width: 22px;
    height: 2px;
    background: var(--color-paper-ink);
    border-radius: 1px;
    transition: transform var(--duration-base) var(--ease-out),
                opacity var(--duration-base) var(--ease-out);
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle__bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle__bar:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle__bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile drawer */
  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: var(--space-2) var(--space-6) var(--space-6);
    background: var(--color-paper);
    border-top: 1px solid var(--color-sage-light);
  }
  .mobile-nav.is-open { display: flex; }
  .mobile-nav__link {
    padding: var(--space-4) 0;
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: var(--weight-medium);
    color: var(--color-paper-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-sage-light);
  }
  .mobile-nav__link:last-child { border-bottom: 0; }

  @media (max-width: 760px) {
    .site-nav { display: none; }
    .nav-toggle { display: flex; }
    .site-header__inner { padding: 0 var(--space-4); gap: var(--space-3); }
  }

  /* Footer */
  .site-footer {
    margin-top: var(--space-24);
    background: var(--color-paper-muted);
    color: var(--color-paper-ink);
    border-top: 1px solid var(--color-sage-light);
  }
  .site-footer__inner {
    padding: var(--space-16) var(--space-8) var(--space-10);
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-12);
  }
  .site-footer__brand .site-footer__name {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: var(--weight-semibold);
    color: var(--color-paper-ink);
    letter-spacing: -0.012em;
    display: block;
    margin-bottom: var(--space-3);
  }
  .site-footer__blurb {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-muted);
    max-width: 32rem;
    margin: 0;
  }
  .site-footer__col h4 {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-brass);
    margin-bottom: var(--space-4);
  }
  .site-footer__col a {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-paper-ink);
    text-decoration: none;
    padding: var(--space-1) 0;
    opacity: 0.85;
    transition: opacity var(--duration-fast) var(--ease-out),
                color var(--duration-fast) var(--ease-out);
  }
  .site-footer__col a:hover {
    opacity: 1;
    color: var(--color-brass);
  }
  /* Base/legal row aligns to the panel — same horizontal padding (--space-8) as
     the footer columns above it. CLEANUP (P1): previously this row used
     `max-width: var(--container-max); margin: 0 auto`, centering it to 1152px
     while the columns spanned the 1240px panel with --space-8 padding — a stale
     mismatch where the legal row sat narrower/misaligned vs the footer above.
     This is the ONE intentional visual delta in the DTP migration. */
  .site-footer__base {
    border-top: 1px solid var(--color-sage-light);
    padding: var(--space-6) var(--space-8);
  }
  .site-footer__copy {
    text-align: center;
    font-size: var(--text-xs);
    color: var(--color-muted);
    margin: var(--space-4) 0 0;
    letter-spacing: var(--tracking-wide);
  }

  @media (max-width: 760px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      padding: var(--space-12) var(--space-4) var(--space-8);
    }
    .site-footer__base { padding: var(--space-6) var(--space-4); }
  }

  /* Lock scroll when mobile nav open */
  :global(body.nav-open) { overflow: hidden; }
</style>
