---
interface Props {
  rank: number;
  name: string;
  brand: string;
  image?: string;
  tagline?: string;
  bestFor?: string;
  priceFrom?: number;
  affiliateUrl: string;
}

const {
  rank,
  name,
  brand,
  image,
  tagline,
  bestFor,
  priceFrom,
  affiliateUrl,
} = Astro.props;
const formattedPrice = typeof priceFrom === "number"
  ? `from $${priceFrom.toLocaleString()}`
  : null;
---
<article class="product-card" id={`pick-${rank}`}>
  <div class="product-card__rank-col">
    <div class="product-card__rank">
      <span class="product-card__rank-label">Pick</span>
      <span class="product-card__rank-num">{rank}</span>
    </div>
  </div>

  <div class="product-card__media">
    {image ? (
      <img src={image} alt={name} loading="lazy" decoding="async" />
    ) : (
      <div class="product-card__placeholder" aria-hidden="true">
        <span>{brand}</span>
      </div>
    )}
  </div>

  <div class="product-card__body">
    <span class="product-card__brand">{brand}</span>
    <h3 class="product-card__name">{name}</h3>
    {tagline && <p class="product-card__tagline">{tagline}</p>}

    <dl class="product-card__facts">
      {bestFor && (
        <>
          <dt>Best for</dt>
          <dd>{bestFor}</dd>
        </>
      )}
      {formattedPrice && (
        <>
          <dt>Price</dt>
          <dd>{formattedPrice}</dd>
        </>
      )}
    </dl>

    <a
      href={affiliateUrl}
      class="product-card__cta"
      rel="nofollow sponsored noopener"
      target="_blank"
    >
      <span>Check current price</span>
      <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
        <path d="M3 8h9.5M9 4.5l3.5 3.5L9 11.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
  </div>
</article>

<style>
  .product-card {
    display: grid;
    grid-template-columns: 80px 1.1fr 1fr;
    gap: var(--space-6);
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    margin: var(--space-8) 0;
    align-items: stretch;
    box-shadow: var(--shadow-sm);
  }

  .product-card__rank-col {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .product-card__rank {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background: var(--color-forest);
    color: var(--color-paper);
    border-radius: var(--radius-full);
    flex-shrink: 0;
  }
  .product-card__rank-label {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-brass-soft);
    line-height: 1;
  }
  .product-card__rank-num {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: var(--weight-semibold);
    line-height: 1;
    margin-top: 2px;
  }

  .product-card__media {
    background: var(--color-paper);
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    display: grid;
    place-items: center;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
  }
  .product-card__media img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .product-card__placeholder {
    color: var(--color-forest);
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
  }

  .product-card__body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
  }

  .product-card__brand {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-brass);
    margin-bottom: var(--space-2);
  }

  .product-card__name {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    letter-spacing: -0.018em;
    color: var(--color-forest);
    margin: 0 0 var(--space-3);
  }

  .product-card__tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-base);
    color: var(--color-muted);
    line-height: var(--leading-snug);
    margin: 0 0 var(--space-4);
  }

  .product-card__facts {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-1) var(--space-3);
    font-size: var(--text-sm);
    margin: 0 0 var(--space-5);
  }
  .product-card__facts dt {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-muted);
    font-weight: var(--weight-semibold);
    align-self: center;
  }
  .product-card__facts dd {
    margin: 0;
    color: var(--color-paper-ink);
    font-weight: var(--weight-medium);
  }

  .product-card__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--color-brass);
    color: var(--color-paper);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-weight: var(--weight-semibold);
    font-size: var(--text-sm);
    text-decoration: none;
    transition: background var(--duration-base) var(--ease-out),
                transform var(--duration-fast) var(--ease-out);
  }
  .product-card__cta:hover {
    background: var(--color-brass-hover);
    color: var(--color-paper);
    transform: translateY(-1px);
  }
  .product-card__cta svg { transition: transform var(--duration-base) var(--ease-out); }
  .product-card__cta:hover svg { transform: translateX(3px); }

  @media (max-width: 760px) {
    .product-card {
      grid-template-columns: 1fr;
      gap: var(--space-4);
      padding: var(--space-5);
    }
    .product-card__rank-col {
      flex-direction: row;
      width: 100%;
    }
    .product-card__rank {
      width: 52px;
      height: 52px;
      flex-direction: row;
      gap: var(--space-1);
    }
    .product-card__rank-label { font-size: 0.65rem; }
    .product-card__rank-num { font-size: 1.4rem; margin-top: 0; }
    .product-card__media { aspect-ratio: 16 / 10; }
    .product-card__name { font-size: var(--text-xl); }
  }
</style>
