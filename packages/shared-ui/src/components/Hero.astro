---
interface Props {
  title: string;
  tagline?: string;
}
const { title, tagline } = Astro.props;
---
<section class="hero">
  <h1>{title}</h1>
  {tagline && <p class="tagline">{tagline}</p>}
</section>

<style>
  .hero {
    padding: var(--space-12) 0 var(--space-8);
    text-align: center;
  }
  .hero h1 {
    font-size: var(--text-4xl);
    margin: 0 0 var(--space-4);
    line-height: 1.1;
  }
  .tagline {
    color: var(--color-muted);
    font-size: var(--text-lg);
    margin: 0;
  }
</style>
