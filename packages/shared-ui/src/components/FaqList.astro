---
/* <FaqList faq={...} /> — FAQ block.
   Mockup: docs/playgrounds/library/09-faq.html.

   Centered accent eyebrow + serif heading, then an accordion of Q&A items using
   native <details>/<summary> so it works without JS (open by default for SEO +
   no-JS readers; the marker toggles the +/−). Held to a readable ~65ch measure.
   Token-mapped to auto-skin per site. Fed from frontmatter `data.faq`. */
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  faq: FaqItem[];
  heading?: string;
  eyebrow?: string;
}

const { faq, heading = "Common questions", eyebrow = "FAQ" } = Astro.props;
---
{faq && faq.length > 0 && (
  <section class="faq" aria-label="Frequently asked questions">
    <div class="faq__inner">
      <span class="faq__eyebrow">{eyebrow}</span>
      <h2 class="faq__heading">{heading}</h2>
      <div class="faq__list">
        {faq.map((item) => (
          <details class="faq__item">
            <summary class="faq__q">
              <span class="faq__q-text">{item.question}</span>
              <span class="faq__icon" aria-hidden="true"></span>
            </summary>
            <p class="faq__a">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .faq {
    background: var(--color-paper);
    padding: var(--space-12, 3rem) var(--space-8, 2rem) var(--space-12, 3rem);
  }
  .faq__inner { max-width: 65ch; margin: 0 auto; }
  .faq__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: var(--weight-bold, 700);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-accent, var(--color-brass));
    margin-bottom: 10px;
  }
  .faq__eyebrow::before {
    content: "";
    width: 26px;
    height: 2px;
    background: var(--color-accent, var(--color-brass));
    display: inline-block;
    flex-shrink: 0;
  }
  .faq__heading {
    font-family: var(--font-serif);
    font-weight: var(--weight-semibold, 600);
    /* 26px (was 36px) — 36 read as 1.5x the 24px section heads elsewhere and
       looked oversized (readability review). */
    font-size: 26px;
    letter-spacing: -0.015em;
    color: var(--color-forest);
    text-align: center;
    line-height: 1.15;
  }
  .faq__list { margin-top: 30px; }

  .faq__item { border-bottom: 1px solid var(--color-border); }
  .faq__item:first-child { border-top: 1px solid var(--color-border); }
  .faq__q {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    cursor: pointer;
    padding: 20px 2px 6px;
    list-style: none;
  }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__q-text {
    font-family: var(--font-serif);
    font-weight: var(--weight-semibold, 600);
    font-size: 22px;
    letter-spacing: -0.01em;
    color: var(--color-paper-ink);
    line-height: 1.3;
  }
  .faq__icon {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    border-radius: var(--radius-full, 999px);
    background: var(--color-brass-soft);
    color: var(--color-forest);
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: var(--weight-bold, 700);
    line-height: 24px;
    text-align: center;
    user-select: none;
  }
  .faq__icon::before { content: "−"; }
  .faq__item:not([open]) .faq__icon::before { content: "+"; }
  .faq__a {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-muted);
    padding: 0 40px 22px 2px;
    margin: 0;
  }
</style>
