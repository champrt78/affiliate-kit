---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"buyers-guides">;
  featured?: boolean;
}

const { entry, featured = false } = Astro.props;
const { data, slug } = entry;
const href = `/buyers-guides/${slug}/`;
const pubDate = data.pubDate instanceof Date
  ? data.pubDate.toISOString().slice(0, 10)
  : String(data.pubDate);
const formattedDate = data.pubDate instanceof Date
  ? data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })
  : pubDate;
const productCount = data.products?.length ?? 0;
// Hero images: prefer the multi-image array (mag 1+2 layout) when present,
// fall back to single hero, then to the first product's image. Multi-image
// triggers the magazine layout only on featured cards.
const heroImages = (data.images as any)?.heroImages as string[] | undefined;
const heroImage = data.images?.hero ?? (data.products?.[0] as any)?.image ?? null;
const useMag = featured && heroImages && heroImages.length >= 3;
---
<article class:list={["guide-card", featured && "guide-card--featured", useMag && "guide-card--mag"]}>
  <a href={href} class="guide-card__link">
    {useMag ? (
      <div class="guide-card__media guide-card__media--mag">
        <div class="mag-feature" style={`background-image:url('${heroImages![0]}')`}></div>
        <div class="mag-small mag-small--1" style={`background-image:url('${heroImages![1]}')`}></div>
        <div class="mag-small mag-small--2" style={`background-image:url('${heroImages![2]}')`}></div>
      </div>
    ) : heroImage && (
      <div class="guide-card__media">
        <img src={heroImage} alt={data.title} width="1600" height="1200" loading="lazy" decoding="async" />
      </div>
    )}
    <div class="guide-card__body">
      <span class="guide-card__kicker">Buying Guide</span>
      <h3 class="guide-card__title">{data.title}</h3>
      <p class="guide-card__desc">{data.description}</p>
      <div class="guide-card__meta">
        <span class="guide-card__count">
          {productCount} pick{productCount === 1 ? "" : "s"} compared
        </span>
        <time class="guide-card__date" datetime={pubDate}>{formattedDate}</time>
      </div>
    </div>
  </a>
</article>

<style>
  .guide-card {
    background: var(--color-forest);
    color: var(--color-paper);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out);
    height: 100%;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .guide-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }
  .guide-card__link {
    color: inherit;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .guide-card__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-paper-muted);
  }
  .guide-card__media img {
    width: 100%;
    height: 100%;
    /* cover (not contain) because guide hero is a full photograph, not a
       product PNG — let it bleed to the edges */
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }
  .guide-card:hover .guide-card__media img { transform: scale(1.04); }

  .guide-card__body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .guide-card__kicker {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-brass-soft);
    margin-bottom: var(--space-3);
  }

  .guide-card__title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    letter-spacing: -0.015em;
    color: var(--color-paper);
    margin: 0 0 var(--space-3);
  }

  .guide-card__desc {
    color: var(--color-paper);
    opacity: 0.78;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-4);
    flex: 1;
  }

  .guide-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--text-xs);
    color: var(--color-paper);
    opacity: 0.7;
    letter-spacing: var(--tracking-wide);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(245, 240, 230, 0.15);
  }
  .guide-card__count { font-weight: var(--weight-medium); }
  .guide-card__date { text-transform: uppercase; }

  /* Featured */
  .guide-card--featured .guide-card__media { aspect-ratio: 21 / 9; }
  .guide-card--featured .guide-card__title { font-size: var(--text-2xl); }

  /* Magazine 1+2 hero — large feature image on left, two stacked smaller on right.
     Activates when featured AND heroImages[] has 3+ entries. */
  .guide-card__media--mag {
    aspect-ratio: 21 / 9;
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 2px;
    background: var(--color-paper);
    overflow: hidden;
  }
  .guide-card__media--mag .mag-feature {
    grid-row: 1 / span 2;
    background-size: cover;
    background-position: center;
  }
  .guide-card__media--mag .mag-small {
    background-size: cover;
    background-position: center;
  }

  /* Ray 2026-05-31: hard cap so the card image box can never balloon, regardless of grid context. */
  .guide-card__media { max-height: 280px; }
  .review-card__media, .review-card__image, .product-card__media { max-height: 280px; }

</style>
