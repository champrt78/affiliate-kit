---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"buyers-guides">;
}

const { entry } = Astro.props;
const { data, slug } = entry;
const href = `/buyers-guides/${slug}/`;
const pubDate = data.pubDate instanceof Date
  ? data.pubDate.toISOString().slice(0, 10)
  : String(data.pubDate);
const productCount = data.products?.length ?? 0;
---
<article class="guide-card">
  <a href={href} class="card-link">
    <div class="badge">Buyer's Guide</div>
    <div class="meta">
      <h3>{data.title}</h3>
      <p class="desc">{data.description}</p>
      <div class="row">
        <span class="count">{productCount} product{productCount === 1 ? "" : "s"} compared</span>
        <time datetime={pubDate}>{pubDate}</time>
      </div>
    </div>
  </a>
</article>

<style>
  .guide-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-surface);
    transition: transform 150ms ease, box-shadow 150ms ease;
  }
  .guide-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }
  .card-link {
    color: var(--color-fg);
    text-decoration: none;
    display: block;
    padding: var(--space-4);
  }
  .badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--space-1) var(--space-2);
    background: var(--color-brand, #d97706);
    color: var(--color-brand-fg, #fff);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-3);
  }
  .meta h3 {
    margin: 0 0 var(--space-2);
    font-size: var(--text-lg);
    line-height: 1.3;
  }
  .desc {
    margin: 0 0 var(--space-3);
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: 1.4;
  }
  .row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
</style>
