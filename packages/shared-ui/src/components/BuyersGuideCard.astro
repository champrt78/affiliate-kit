---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"buyers-guides">;
  featured?: boolean;
}

const { entry, featured = false } = Astro.props;
const { data, slug } = entry;
const href = `/buyers-guides/${slug}/`;
const pubDate = data.pubDate instanceof Date
  ? data.pubDate.toISOString().slice(0, 10)
  : String(data.pubDate);
const formattedDate = data.pubDate instanceof Date
  ? data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })
  : pubDate;
const productCount = data.products?.length ?? 0;
// Prefer the buying-guide hero (typically a photographic Unsplash/brand-kit
// image suitable for cover-fit) over the first product's image (typically a
// transparent product PNG that doesn't render well with object-fit: cover).
const heroImage = data.images?.hero ?? (data.products?.[0] as any)?.image ?? null;
---
<article class:list={["guide-card", featured && "guide-card--featured"]}>
  <a href={href} class="guide-card__link">
    {heroImage && (
      <div class="guide-card__media">
        <img src={heroImage} alt={data.title} loading="lazy" decoding="async" />
      </div>
    )}
    <div class="guide-card__body">
      <span class="guide-card__kicker">Buying Guide</span>
      <h3 class="guide-card__title">{data.title}</h3>
      <p class="guide-card__desc">{data.description}</p>
      <div class="guide-card__meta">
        <span class="guide-card__count">
          {productCount} pick{productCount === 1 ? "" : "s"} compared
        </span>
        <time class="guide-card__date" datetime={pubDate}>{formattedDate}</time>
      </div>
    </div>
  </a>
</article>

<style>
  .guide-card {
    background: var(--color-forest);
    color: var(--color-paper);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out);
    height: 100%;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .guide-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }
  .guide-card__link {
    color: inherit;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .guide-card__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-paper-muted);
  }
  .guide-card__media img {
    width: 100%;
    height: 100%;
    /* cover (not contain) because guide hero is a full photograph, not a
       product PNG — let it bleed to the edges */
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }
  .guide-card:hover .guide-card__media img { transform: scale(1.04); }

  .guide-card__body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .guide-card__kicker {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-brass-soft);
    margin-bottom: var(--space-3);
  }

  .guide-card__title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    letter-spacing: -0.015em;
    color: var(--color-paper);
    margin: 0 0 var(--space-3);
  }

  .guide-card__desc {
    color: var(--color-paper);
    opacity: 0.78;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-4);
    flex: 1;
  }

  .guide-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--text-xs);
    color: var(--color-paper);
    opacity: 0.7;
    letter-spacing: var(--tracking-wide);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(245, 240, 230, 0.15);
  }
  .guide-card__count { font-weight: var(--weight-medium); }
  .guide-card__date { text-transform: uppercase; }

  /* Featured */
  .guide-card--featured .guide-card__media { aspect-ratio: 21 / 9; }
  .guide-card--featured .guide-card__title { font-size: var(--text-2xl); }
</style>
