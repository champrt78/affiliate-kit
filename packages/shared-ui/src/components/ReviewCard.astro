---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"reviews">;
  featured?: boolean;
}

const { entry, featured = false } = Astro.props;
const { data, slug } = entry;
const href = `/reviews/${slug}/`;
const hero = data.images?.hero && data.images.hero.length > 0 ? data.images.hero : null;
// Note: data.images.imageScale is still consumed by ReviewArticle.astro for
// the in-article hero (a different use case). We deliberately do NOT apply
// it on the index card — the fixed-height normalization below produces
// consistent visible sizes across all 4 cards regardless of source PNG.
const pubDate = data.pubDate instanceof Date
  ? data.pubDate.toISOString().slice(0, 10)
  : String(data.pubDate);
const rating = data.rating;
const formattedDate = data.pubDate instanceof Date
  ? data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })
  : pubDate;
---
<article class:list={["review-card", featured && "review-card--featured"]}>
  <a href={href} class="review-card__link">
    <div class="review-card__media">
      {hero ? (
        <img
          src={hero}
          alt={data.product.name}
          width="1200"
          height="1200"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="review-card__placeholder" aria-hidden="true">
          <span>{data.product.brand}</span>
        </div>
      )}
    </div>
    <div class="review-card__body">
      <span class="review-card__kicker">Review · {data.product.brand}</span>
      <h3 class="review-card__title">{data.title}</h3>
      <p class="review-card__desc">{data.description}</p>
      <div class="review-card__meta">
        {typeof rating === "number" && (
          <span class="review-card__rating" aria-label={`Rated ${rating} out of 5`}>
            <span class="review-card__stars" aria-hidden="true">
              {Array.from({ length: 5 }).map((_, i) => (
                <span class={i < Math.round(rating) ? "is-on" : ""}>★</span>
              ))}
            </span>
            <span class="review-card__rating-num">{rating.toFixed(1)}</span>
          </span>
        )}
        <time class="review-card__date" datetime={pubDate}>{formattedDate}</time>
      </div>
    </div>
  </a>
</article>

<style>
  .review-card {
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out);
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .review-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-sage);
  }
  .review-card__link {
    color: var(--color-fg);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .review-card__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-paper-muted);
    position: relative;
    /* flex (not grid) centering so the img's percentage max-height resolves.
       Under grid + place-items:center, a single auto-placed item's area is
       indefinite for % max-height, so the height cap evaporated and portrait
       products were bound only by max-width, overflowing the box top/bottom
       (I7 "card thumbs crop tall products"). aspect-ratio gives the flex
       container a definite height for the cap to resolve against. */
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-8);
  }
  .review-card__media img {
    /* Constrain to both axes so tall portrait products (e.g. 718x1053
       cameras with mounting brackets) don't overflow the card vertically.
       max-height now binds because the flex container above has a definite
       height (via aspect-ratio). object-fit: contain keeps the product whole. */
    max-width: 88%;
    max-height: 88%;
    width: auto;
    height: auto;
    object-fit: contain;
    /* multiply: white pixels in source PNGs (e.g. retailer composites with
       hard-white backgrounds) blend into the cream card so all products
       sit on a consistent visual ground regardless of source-image padding */
    mix-blend-mode: multiply;
    transition: transform var(--duration-slow) var(--ease-out);
  }
  .review-card:hover .review-card__media img {
    transform: scale(1.03);
  }
  .review-card__placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    color: var(--color-forest);
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: var(--weight-semibold);
    background:
      radial-gradient(ellipse at top, var(--color-paper-muted), var(--color-paper));
  }

  .review-card__body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .review-card__kicker {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-brass);
    margin-bottom: var(--space-3);
  }

  .review-card__title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    letter-spacing: -0.015em;
    color: var(--color-forest);
    margin: 0 0 var(--space-3);
  }

  .review-card__desc {
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-4);
    flex: 1;
  }

  .review-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: var(--tracking-wide);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .review-card__rating {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }
  .review-card__stars {
    color: var(--color-sage);
    letter-spacing: 0.05em;
  }
  .review-card__stars .is-on { color: var(--color-brass); }
  .review-card__rating-num {
    color: var(--color-forest);
    font-weight: var(--weight-semibold);
  }
  .review-card__date {
    text-transform: uppercase;
  }

  /* Featured variant — wider, taller media */
  .review-card--featured .review-card__media { aspect-ratio: 16 / 9; }
  .review-card--featured .review-card__title { font-size: var(--text-2xl); }
</style>
