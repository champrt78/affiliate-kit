---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"reviews">;
}

const { entry } = Astro.props;
const { data, slug } = entry;
const href = `/reviews/${slug}/`;
const hero = data.images?.hero && data.images.hero.length > 0 ? data.images.hero : null;
const pubDate = data.pubDate instanceof Date
  ? data.pubDate.toISOString().slice(0, 10)
  : String(data.pubDate);
const rating = data.rating;
---
<article class="review-card">
  <a href={href} class="card-link">
    {hero ? (
      <img src={hero} alt={data.product.name} loading="lazy" class="hero" />
    ) : (
      <div class="hero placeholder" aria-hidden="true">
        <span>{data.product.brand}</span>
      </div>
    )}
    <div class="meta">
      <h3>{data.title}</h3>
      <p class="desc">{data.description}</p>
      <div class="row">
        {typeof rating === "number" ? (
          <span class="rating" aria-label={`Rated ${rating} out of 5`}>
            {"★".repeat(Math.round(rating))}<span class="rating-num">{rating.toFixed(1)}</span>
          </span>
        ) : null}
        <time datetime={pubDate}>{pubDate}</time>
      </div>
    </div>
  </a>
</article>

<style>
  .review-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-surface);
    transition: transform 150ms ease, box-shadow 150ms ease;
  }
  .review-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }
  .card-link {
    color: var(--color-fg);
    text-decoration: none;
    display: block;
  }
  .hero {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    background: var(--color-muted-bg, #f3f4f6);
  }
  .hero.placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-size: var(--text-sm);
  }
  .meta {
    padding: var(--space-4);
  }
  .meta h3 {
    margin: 0 0 var(--space-2);
    font-size: var(--text-lg);
    line-height: 1.3;
  }
  .desc {
    margin: 0 0 var(--space-3);
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: 1.4;
  }
  .row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .rating { color: var(--color-brand, #d97706); }
  .rating-num { margin-left: var(--space-2); color: var(--color-muted); }
</style>
