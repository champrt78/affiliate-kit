---
/* <ProsePage title kicker? lede?> ...prose... </ProsePage> — shared shell for
   the simple text pages (about / contact / disclosure / privacy). One editorial
   header (kicker + serif title + lede) over a token-mapped prose body. The COPY
   is per-site (each site keeps its real legal/about text in the slot); only the
   shell + typography are shared, so every text page reads identically skinned.

   Prose styling is leveled up from gameovergear's rich `.doc` treatment (the
   richest of the five): accent-colored h2s, list rows as left-ruled cards,
   inline code chips, accent links. All token-mapped so it auto-skins — including
   the inverted gog skin (--color-forest → light ink keeps headings readable on
   the near-black surface; the brass slot carries the neon accent).

   Header is optional-granular: pass only `title` for a bare page (contact), or
   add `kicker` + `lede` for the fuller editorial header (about / methodology). */
interface Props {
  title: string;
  kicker?: string;
  lede?: string;
}

const { title, kicker, lede } = Astro.props;
---
<article class="doc">
  <header class="doc-header">
    {kicker && <span class="doc-kicker">{kicker}</span>}
    <h1>{title}</h1>
    {lede && <p class="doc-lede" set:html={lede}></p>}
  </header>
  <div class="doc-body">
    <slot />
  </div>
</article>

<style>
  .doc {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6) var(--space-20);
  }
  .doc-header { margin-bottom: var(--space-8); }
  .doc-kicker {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brass);
    margin-bottom: var(--space-3);
  }
  .doc h1 {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    color: var(--color-forest);
    margin: 0 0 var(--space-4);
    line-height: 1.2;
    letter-spacing: var(--tracking-display);
  }
  .doc-lede {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--color-muted);
    margin: 0;
    max-width: 56ch;
    line-height: 1.6;
  }

  /* Prose body — styles flow into slotted markup via :global within .doc-body. */
  .doc-body :global(h2) {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    color: var(--color-brass);
    margin: var(--space-10) 0 var(--space-3);
    line-height: 1.3;
  }
  .doc-body :global(h3) {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--color-forest);
    margin: var(--space-8) 0 var(--space-2);
    line-height: 1.3;
  }
  .doc-body :global(p) {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.7;
    margin: 0 0 var(--space-4);
    color: var(--color-fg);
  }
  .doc-body :global(a) {
    color: var(--color-brass);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .doc-body :global(a:hover) { color: var(--color-brass-hover, var(--color-forest)); }
  .doc-body :global(ul) {
    list-style: none;
    padding: 0;
    margin: var(--space-5) 0;
  }
  .doc-body :global(li) {
    font-family: var(--font-sans);
    padding: 16px 22px;
    margin: 0 0 14px;
    background: var(--color-cream);
    border-left: 3px solid var(--color-brass);
    border-radius: 0 6px 6px 0;
    line-height: 1.6;
    color: var(--color-fg);
  }
  .doc-body :global(li strong) { color: var(--color-brass); }
  .doc-body :global(code) {
    font-family: var(--font-mono, ui-monospace, Consolas, monospace);
    background: var(--color-cream);
    color: var(--color-brass);
    padding: 0 var(--space-1);
    border-radius: var(--radius-sm, 4px);
    font-size: 0.92em;
  }
</style>
