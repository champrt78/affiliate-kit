---
/**
 * <ReviewArticle entry={entry} ... />
 *
 * Shared component for single-product review pages. Site renderers wrap this
 * inside their own <MainLayout> (which handles per-site header / footer /
 * palette tokens) and pass per-site overrides for the article-level
 * customization points (rubric label, crumb, methodology link, etc).
 *
 * Defaults are set for mywildlifecam (trail-cam vertical) so the existing
 * site keeps working with `<ReviewArticle entry={entry} />`. Satellite sites
 * override what they need.
 */
import type { CollectionEntry } from "astro:content";
import CTA from "./CTA.astro";
import AffiliateDisclosure from "./AffiliateDisclosure.astro";
import BottomLine from "./BottomLine.astro";
import Media from "./Media.astro";
import { cloakedLink, productSchema } from "@affkit/shared-utils";

interface Props {
  entry: CollectionEntry<"reviews">;
  // Per-site customization (all optional)
  siteName?: string;
  crumbLabel?: string;
  crumbHref?: string;
  defaultRubric?: string;
  methodologyHref?: string;
  methodologyLabel?: string;
  bottomCtaHeading?: string;
  bottomCtaCopy?: string;
  brandInitial?: string;
  editorialTeamName?: string;
  credentialLine?: string;
}

const {
  entry,
  siteName = "MyWildlifeCam",
  crumbLabel = "All reviews",
  crumbHref = "/reviews/",
  defaultRubric = "Trail Cameras · Review",
  methodologyHref = "/how-we-evaluate/",
  methodologyLabel = "How we evaluate trail cameras",
  bottomCtaHeading = "Ready to look?",
  bottomCtaCopy = "We use one cloaked link per product so we can swap retailers without breaking old pages. Click through goes to Amazon.",
  brandInitial = "M",
  editorialTeamName = "The MyWildlifeCam editorial team",
  credentialLine = "Spec analysis & use-case framing · verified against current manufacturer listings and Amazon reports",
} = Astro.props;

const { data } = entry;
const { Content } = await entry.render();

const BOTTOMLINE_PLACEHOLDER = "_The Bottom Line is being written._";
const isDraft = !data.bottomLine
  || !data.bottomLine.verdict
  || data.bottomLine.verdict.trim() === ""
  || data.bottomLine.verdict.includes(BOTTOMLINE_PLACEHOLDER);

const heroImage = data.images?.hero && data.images.hero.length > 0
  ? data.images.hero
  : "";
const heroCaption = data.images?.heroCaption
  ?? (heroImage ? `${data.product.name}. Photo: ${data.product.brand} manufacturer media kit.` : "");

const rubric = (data as any).rubric ?? defaultRubric;
const deck = (data as any).deck ?? data.description;
const displayTitle = data.product?.name
  ? `${data.product.name} Review`
  : data.title;

const offerUrl = data.product.affiliate?.amazon
  ?? data.product.affiliate?.direct
  ?? undefined;

const productLd = productSchema({
  name: data.product.name,
  brand: data.product.brand,
  sku: data.product.sku ?? entry.slug,
  image: heroImage,
  description: data.description,
  offerUrl,
  price: data.product.price,
  currency: data.product.currency,
});

const faqData = (data as any).faq as Array<{ question: string; answer: string }> | undefined;
const faqLd = faqData && faqData.length > 0
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqData.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": { "@type": "Answer", "text": item.answer },
      })),
    }
  : null;

const cloakedHref = cloakedLink({ slug: entry.slug });

const formattedUpdated = data.lastUpdated instanceof Date
  ? data.lastUpdated.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })
  : String(data.lastUpdated);
const isoUpdated = data.lastUpdated instanceof Date
  ? data.lastUpdated.toISOString()
  : String(data.lastUpdated);

const scorecard = (data as any).scorecard as {
  axes: Array<{ name: string; weight: number; score: number }>;
  note?: string;
} | undefined;
const composite = scorecard
  ? Math.round(
      (scorecard.axes.reduce((sum, a) => sum + (a.score * a.weight) / 100, 0)) * 10
    ) / 10
  : null;

const bottomLine = (data as any).bottomLine as {
  verdict: string;
  supporting?: string | string[];
} | undefined;

const buyIf = (data as any).buyIf as { buy: string[]; skip: string[] } | undefined;
const flaws = (data as any).flaws as Array<{ title: string; body: string }> | undefined;
// NOTE: per-piece images.imageScale is now intentionally unused on the hero.
// The shared <Media variant="hero"> contains the product in a definite box, so
// it can never overflow/crop regardless of source proportion — the structural
// fix for the "half the product" hero bug (I1) that the old transform:scale
// clamp worked around. The frontmatter field is left in place but no-ops.
---
<script type="application/ld+json" set:html={JSON.stringify(productLd)} />
{faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}

{isDraft && (
  <aside class="draft-banner" role="alert">
    <strong>DRAFT.</strong> This review's Bottom Line section hasn't been filled in.
    Don't link to this page yet. Indexing is disabled until it's complete.
  </aside>
)}

<article class="article">

  <header class="article-header">
    <a href={crumbHref} class="article-crumb">← {crumbLabel}</a>
    <span class="rubric">{rubric}</span>
    <h1 class="article-title">{displayTitle}</h1>
    <p class="article-deck">{deck}</p>

    <div class="byline" aria-label="Article byline">
      <span class="byline__avatar" aria-hidden="true">{brandInitial}</span>
      <div class="byline__who">
        <span class="byline__name">{editorialTeamName}</span>
        <span class="byline__cred">{credentialLine}</span>
      </div>
      <div class="byline__when">
        <span class="byline__label">Last updated</span>
        <time class="byline__date" datetime={isoUpdated}>{formattedUpdated}</time>
      </div>
    </div>
  </header>

  {heroImage && (
    <figure class="article-hero">
      <a href={cloakedHref} class="article-hero__frame" rel="sponsored noopener" target="_blank" aria-label={`Check current price for ${data.product.name}`}>
        {/* Product hero → shared <Media variant="hero"> (white bg, contain, the
            whole product shows, never cropped). The clickable frame + price pill
            wrap it. imageScale clamp is no longer needed: contain on a definite
            box can't overflow, so the "half the product" hero bug (I1) can't
            recur structurally. */}
        <Media src={heroImage} alt={data.product.name} variant="hero" width={1600} height={1000} loading="eager" />
        <span class="article-hero__price-tag" aria-hidden="true">
          See on Amazon <span class="article-hero__price-arrow">&rarr;</span>
        </span>
      </a>
      {heroCaption && <figcaption class="article-hero__caption">{heroCaption}</figcaption>}
    </figure>
  )}

  <div class="article-body">

    <BottomLine bottomLine={bottomLine} isDraft={isDraft} />

    {scorecard && composite !== null && (
      <section class="scorecard" aria-label="Editorial scorecard">
        <header class="scorecard__head">
          <h2 class="scorecard__title">Editorial Scorecard</h2>
          <div class="scorecard__composite">{composite.toFixed(1)}<small>/10</small></div>
        </header>
        <ol class="scorecard__axes">
          {scorecard.axes.map((axis) => {
            const pct = Math.max(0, Math.min(100, (axis.score / 10) * 100));
            return (
              <li class="axis">
                <div class="axis__name">
                  {axis.name}
                  <small>· {axis.weight}%</small>
                </div>
                <div class="axis__bar" aria-hidden="true">
                  <div class="axis__fill" style={`width:${pct}%`}></div>
                </div>
                <div class="axis__score">{axis.score.toFixed(1)}</div>
              </li>
            );
          })}
        </ol>
        {scorecard.note && <p class="scorecard__note">{scorecard.note}</p>}
      </section>
    )}

    {buyIf && (
      <section class="buyif" aria-label="Buy it if / Don't buy it if">
        <div class="buyif__card buyif__card--buy">
          <h3 class="buyif__heading">Buy it if</h3>
          <ul>{buyIf.buy.map((item) => <li>{item}</li>)}</ul>
        </div>
        <div class="buyif__card buyif__card--skip">
          <h3 class="buyif__heading">Don't buy it if</h3>
          <ul>{buyIf.skip.map((item) => <li>{item}</li>)}</ul>
        </div>
      </section>
    )}

    <AffiliateDisclosure siteName={siteName} variant="inline" />

    <div class="prose">
      <Content />
    </div>

    {flaws && flaws.length > 0 && (
      <section class="flaws" aria-label="Flaws but not deal-breakers">
        <h2 class="flaws__title">Flaws but not deal-breakers</h2>
        {flaws.map((f) => (
          <div class="flaws__item">
            <h3 class="flaws__heading">{f.title}</h3>
            <p>{f.body}</p>
          </div>
        ))}
      </section>
    )}

    {faqData && faqData.length > 0 && (
      <section class="faq" aria-label="Frequently asked questions">
        <h2 class="faq__title">FAQ</h2>
        {faqData.map((item) => (
          <details class="faq__item">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </section>
    )}

    <aside class="bottomline-cta">
      <h3>{bottomCtaHeading}</h3>
      <p>{bottomCtaCopy}</p>
      <CTA href={cloakedHref} variant="primary" size="lg" rel="sponsored noopener" target="_blank">
        See {data.product.name} on Amazon
      </CTA>
    </aside>

    <footer class="article-footer">
      <a href={methodologyHref} class="methodology-link">{methodologyLabel}</a>
    </footer>

  </div>
</article>

<style>
  .draft-banner {
    max-width: 920px;
    margin: var(--space-6) auto;
    padding: var(--space-4) var(--space-6);
    background: var(--color-brass-soft);
    border-left: 3px solid var(--color-brass);
    color: var(--color-forest);
    font-size: var(--text-sm);
  }

  .article {
    max-width: 920px;
    margin: 0 auto;
    padding: var(--space-12) var(--space-8) var(--space-20);
    background: var(--color-paper);
    color: var(--color-paper-ink);
  }

  .article-header { margin-bottom: var(--space-10); }

  .article-crumb {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: var(--space-6);
  }
  .article-crumb:hover { color: var(--color-brass); }

  .rubric {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brass);
    margin-bottom: var(--space-4);
  }
  .rubric::before {
    content: "";
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--color-brass);
    vertical-align: middle;
    margin-right: 10px;
    transform: translateY(-2px);
  }

  .article-title {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 4.5vw, 3.4rem);
    line-height: 1.05;
    letter-spacing: var(--tracking-display);
    color: var(--color-forest);
    margin: 0 0 var(--space-4);
    font-weight: var(--weight-semibold);
    font-variation-settings: "opsz" 120;
    max-width: 22ch;
    text-transform: capitalize;
  }

  .article-deck {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.125rem, 1.6vw, 1.375rem);
    line-height: 1.4;
    color: var(--color-muted);
    font-variation-settings: "opsz" 30;
    margin: 0 0 var(--space-8);
    max-width: 62ch;
    font-weight: var(--weight-regular);
  }

  .byline {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) 0;
    margin: 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .byline__avatar {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-full);
    background: var(--color-forest);
    color: var(--color-paper);
    display: grid;
    place-items: center;
    font-family: var(--font-serif);
    font-weight: var(--weight-semibold);
    font-size: var(--text-xl);
    line-height: 1;
  }
  .byline__who { flex: 1; display: flex; flex-direction: column; gap: 2px; line-height: 1.4; }
  .byline__name {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: var(--weight-semibold);
    color: var(--color-forest);
  }
  .byline__cred {
    font-family: var(--font-sans);
    font-size: 11.5px;
    color: var(--color-muted);
    max-width: 52ch;
  }
  .byline__when { margin-left: auto; text-align: right; flex-shrink: 0; }
  .byline__label {
    display: block;
    font-family: var(--font-sans);
    font-size: 10.5px;
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-brass);
    margin-bottom: 2px;
  }
  .byline__date {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    color: var(--color-forest);
  }
  @media (max-width: 640px) {
    .byline { flex-wrap: wrap; }
    .byline__when { margin-left: 0; text-align: left; padding-left: calc(44px + var(--space-4)); }
  }

  .article-hero { margin: 0 0 var(--space-10); }
  /* The product hero box is the shared <Media variant="hero"> (white bg,
     contain, definite clamp height). .article-hero__frame is the clickable
     affiliate link + positioning context for the price pill; Media owns the
     box and containment. */
  .article-hero__frame {
    display: block;
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    text-decoration: none;
    cursor: pointer;
    transition: border-color var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out);
  }
  .article-hero__frame:hover {
    border-color: var(--color-brass);
    box-shadow: var(--shadow-md);
  }
  .article-hero__frame :global(.media img) {
    transition: transform var(--duration-slow) var(--ease-out);
  }
  .article-hero__frame:hover :global(.media img) {
    transform: scale(1.02);
  }
  /* Affordance pill — sits in the top-right of the hero, makes it visually
     obvious the whole image is a clickable affiliate link. */
  .article-hero__price-tag {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    background: var(--color-forest);
    color: var(--color-paper);
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 8px 14px;
    border-radius: var(--radius-full);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    box-shadow: var(--shadow-sm);
    transition: background var(--duration-base) var(--ease-out);
  }
  .article-hero__frame:hover .article-hero__price-tag {
    background: var(--color-brass);
  }
  .article-hero__price-arrow {
    transition: transform var(--duration-base) var(--ease-out);
  }
  .article-hero__frame:hover .article-hero__price-arrow {
    transform: translateX(3px);
  }
  .article-hero__caption {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-muted);
    font-style: italic;
    margin-top: var(--space-3);
    padding-left: var(--space-2);
  }

  .article-body {
    max-width: 68ch;
    margin: 0 auto;
  }

  .bottom-line {
    background: var(--color-cream);
    border-left: 3px solid var(--color-brass);
    padding: var(--space-6) var(--space-8);
    margin: 0 0 var(--space-10);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }
  .bottom-line__label {
    display: block;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brass);
    margin-bottom: var(--space-3);
  }
  .bottom-line__verdict {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    line-height: 1.45;
    margin: 0;
    font-variation-settings: "opsz" 30;
  }
  .bottom-line__verdict + .bottom-line__verdict {
    margin-top: var(--space-3);
  }
  /* Primary line: the strong recommendation ("Buy it if you..."). Forest
     semibold — same treatment Bottom Line verdicts had before the split. */
  .bottom-line__verdict--primary {
    color: var(--color-forest);
    font-weight: var(--weight-semibold);
  }
  /* Counter line: the caveat ("Skip it if you..."). Muted ink, regular weight.
     Visually distinct from the primary so the two halves of the pivot read
     as separate beats, not one run-on sentence. */
  .bottom-line__verdict--counter {
    color: var(--color-paper-ink);
    font-weight: var(--weight-regular);
    opacity: 0.85;
  }
  .bottom-line__supporting {
    margin: var(--space-4) 0 0;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-paper-ink);
    font-weight: var(--weight-regular);
  }
  .bottom-line__list {
    margin: var(--space-4) 0 0;
    padding-left: var(--space-5);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-paper-ink);
  }
  .bottom-line__list li { margin-bottom: var(--space-2); }
  .bottom-line__list li:last-child { margin-bottom: 0; }
  .bottom-line__list li::marker { color: var(--color-brass); }

  .scorecard {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6) var(--space-8);
    margin: 0 0 var(--space-10);
    background: var(--color-paper);
  }
  .scorecard__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-5);
  }
  .scorecard__title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--color-forest);
    font-weight: var(--weight-semibold);
    margin: 0;
    border: 0;
    padding: 0;
  }
  .scorecard__composite {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3vw, 2.6rem);
    line-height: 1;
    color: var(--color-brass);
    font-weight: var(--weight-semibold);
    font-variation-settings: "opsz" 60;
  }
  .scorecard__composite small {
    font-size: 0.55em;
    color: var(--color-muted);
    font-weight: var(--weight-regular);
  }
  .scorecard__axes { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--space-3); }
  .axis {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: var(--space-4);
    align-items: center;
    font-size: var(--text-sm);
  }
  .axis__name {
    font-family: var(--font-sans);
    color: var(--color-forest);
    font-weight: var(--weight-medium);
  }
  .axis__name small {
    color: var(--color-muted);
    font-weight: var(--weight-regular);
    font-size: 11.5px;
    margin-left: 6px;
  }
  .axis__bar {
    width: 140px;
    height: 6px;
    background: var(--color-border);
    border-radius: 3px;
    overflow: hidden;
  }
  .axis__fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-brass), var(--color-brass-soft));
    border-radius: 3px;
  }
  .axis__score {
    font-variant-numeric: tabular-nums;
    color: var(--color-forest);
    font-weight: var(--weight-semibold);
    min-width: 42px;
    text-align: right;
  }
  .scorecard__note {
    margin: var(--space-5) 0 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-xs);
    color: var(--color-muted);
    line-height: 1.5;
    font-style: italic;
  }

  .buyif {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
    margin: 0 0 var(--space-10);
  }
  .buyif__card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5) var(--space-6);
    background: var(--color-paper);
  }
  .buyif__card--buy { border-left: 3px solid var(--color-forest); }
  .buyif__card--skip { border-left: 3px solid #8a4a3a; }
  .buyif__heading {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brass);
    margin: 0 0 var(--space-3);
    padding: 0;
    border: 0;
  }
  .buyif__card--skip .buyif__heading { color: #8a4a3a; }
  .buyif__card ul {
    margin: 0;
    padding-left: var(--space-5);
    font-size: var(--text-sm);
    line-height: 1.55;
  }
  .buyif__card li { margin-bottom: var(--space-2); color: var(--color-paper-ink); }
  .buyif__card li:last-child { margin-bottom: 0; }
  @media (max-width: 700px) {
    .buyif { grid-template-columns: 1fr; }
  }

  .prose {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--color-paper-ink);
    margin-top: var(--space-8);
  }
  .prose :global(p) { margin: 0 0 var(--space-5); }
  .prose :global(h2) {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    color: var(--color-forest);
    margin: var(--space-10) 0 var(--space-4);
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border);
    font-weight: var(--weight-semibold);
    text-transform: capitalize;
  }
  .prose :global(h2):first-child { border-top: 0; padding-top: 0; margin-top: 0; }
  .prose :global(h3) {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--color-forest);
    margin: var(--space-8) 0 var(--space-3);
    font-weight: var(--weight-semibold);
    text-transform: capitalize;
  }
  .flaws__title,
