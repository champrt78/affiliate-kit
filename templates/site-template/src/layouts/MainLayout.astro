---
import SiteShell from "@affkit/shared-ui/SiteShell.astro";
import AffiliateDisclosure from "@affkit/shared-ui/AffiliateDisclosure.astro";
// Per-site palette/font token overrides. Create this file when you spawn the
// site; it sets --color-*, --font-*, and (optionally) --page-scale.
// import "../styles/site-tokens.css";

/* Per-page gutter theme. A site defines its own themeBackgrounds map of CSS
   `background` shorthand values (scene/atmosphere photos only — never product
   hero, per the image policy). The shell paints the body and floats the cream
   page-shell on top; mobile collapses the shell to full-width. */
type BgTheme = "default" | "solid";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  robotsContent?: string;
  ogType?: string;
  ogImage?: string;
  bgTheme?: BgTheme;
}

const { title, description, canonical, robotsContent, ogType, ogImage, bgTheme = "solid" } = Astro.props;
const siteName = "__SITE_NAME__";

/* Resolve bgTheme → CSS `background` shorthand value. Add real photo layers per
   the site's visual direction. "solid" → "none" (gutter shows gutterColor). */
const themeBackgrounds: Record<typeof bgTheme, string> = {
  default: "none",
  solid: "none",
};
const pageBg = themeBackgrounds[bgTheme];

const navItems = [
  { href: "/", label: "Home" },
  { href: "/buyers-guides/", label: "Guides" },
  { href: "/reviews/", label: "Reviews" },
  { href: "/about/", label: "About" },
];

const footerBlurb =
  "__SITE_NAME__ — short one-line description of what the site covers and how it helps.";

const footerColumns = [
  {
    heading: "Explore",
    links: [
      { href: "/buyers-guides/", label: "Buying guides" },
      { href: "/reviews/", label: "Single-product reviews" },
      { href: "/how-we-evaluate/", label: "How we evaluate" },
      { href: "/about/", label: "About this site" },
    ],
  },
  {
    heading: "Fine print",
    links: [
      { href: "/disclosure/", label: "Affiliate disclosure" },
      { href: "/privacy/", label: "Privacy" },
      { href: "/contact/", label: "Contact" },
    ],
  },
];
---
<SiteShell
  title={title}
  description={description}
  canonical={canonical}
  siteName={siteName}
  robotsContent={robotsContent}
  ogType={ogType}
  ogImage={ogImage}
  navItems={navItems}
  footerColumns={footerColumns}
  footerBlurb={footerBlurb}
  pageBg={pageBg}
>
  {/* Brand markup is authored HERE so this layout's scoped .brand* CSS matches
      it — Astro scopes slot styles to the authoring component, not SiteShell.
      Swap in the site's real wordmark / mark per its visual direction. */}
  <a href="/" class="brand" slot="brand">
    <span class="brand__name">__SITE_NAME__</span>
  </a>

  <AffiliateDisclosure slot="footer-legal" siteName={siteName} variant="footer" />

  <slot />
</SiteShell>

<style>
  /* Brand wordmark. Lives in this layout (not SiteShell) because the brand
     markup is slotted from here — Astro scopes these styles to the markup THIS
     file authors. Restyle per the site's visual direction. */
  .brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-paper-ink, var(--color-fg));
  }
  .brand__name {
    font-family: var(--font-serif);
    font-weight: var(--weight-semibold);
    font-size: var(--text-xl);
    letter-spacing: -0.01em;
  }
</style>
